// Estado vazio reutilizável: ilustração (SVG de `../assets/empty/`, arte
// quadrada bicolor — traço cinza + acentos laranja da marca) + um rótulo curto
// renderizado como texto Slint. O texto NÃO é embutido no SVG.
//
// Regras (AI_RULES.md §3, §8):
// - Componente sem lógica de negócio; só renderiza a imagem e o texto.
// - Por padrão NÃO há `colorize`: a arte aparece com as cores originais. O
//   `tint` existe só para casos que queiram forçar uma cor única (o que
//   achata a ilustração para monocromática).
//
// Uso:
//   EmptyState {
//       source: @image-url("../assets/empty/out-of-stock.svg");
//       title: "Nenhum produto";
//       subtitle: "Cadastre o primeiro para começar";
//   }
import { Theme } from "../theme.slint";

export component EmptyState inherits Rectangle {
    in property <image> source;
    // Rótulo principal (curto) e apoio (opcional). Vazios → não aparecem.
    in property <string> title;
    in property <string> subtitle;
    // Tingimento OPCIONAL da ilustração. Padrão `transparent` = SEM colorize,
    // preservando as cores originais da arte (cinza + laranja da marca). Só
    // defina se quiser forçar uma cor única (achata a arte para monocromática).
    in property <color> tint: transparent;
    // Lado da ilustração (arte quadrada). Ajustável por local
    // (áreas grandes x painéis pequenos).
    in property <length> art-size: 132px;

    min-width: root.art-size;
    min-height: root.art-size + 56px;

    VerticalLayout {
        alignment: center;
        spacing: 2px;

        HorizontalLayout {
            alignment: center;
            Image {
                width: root.art-size;
                height: root.art-size;
                source: root.source;
                colorize: root.tint;
                image-fit: contain;
            }
        }

        if root.title != "": Text {
            text: root.title;
            horizontal-alignment: center;
            font-size: 15px;
            font-weight: 600;
            color: Theme.text-primary;
        }

        if root.subtitle != "": Text {
            text: root.subtitle;
            horizontal-alignment: center;
            font-size: 13px;
            color: Theme.text-secondary;
            wrap: word-wrap;
        }
    }
}
