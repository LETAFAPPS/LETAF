// ── Ícones desenhados (Rectangle/Text) para métodos de pagamento ────────────
//
// Componentes parametrizados por `tint` para pintar tudo na cor do método.
// Mais elaborados que glifos unicode — desenhados com primitivos do Slint.
//
// Uso:
//   CashIcon { tint: #43A047; }       — dinheiro (verde)
//   CardIcon { tint: #E53935; }       — crédito (vermelho, com chip)
//   CardIcon { tint: Theme.accent; debit: true; }  — débito (amarelo, com tarja)

export component CashIcon inherits Rectangle {
    in property <color> tint;
    width: 32px; height: 32px;

    // Nota de trás (outline, deslocada para cima-esquerda)
    Rectangle {
        x: 4px; y: 9px;
        width: 18px; height: 12px;
        border-radius: 2px;
        background: transparent;
        border-width: 1.2px;
        border-color: tint;
    }
    // Nota da frente (preenchida, deslocada para baixo-direita)
    Rectangle {
        x: 10px; y: 12px;
        width: 18px; height: 12px;
        border-radius: 2px;
        background: tint;
        // $ branco no centro
        Text {
            width: parent.width; height: parent.height;
            text: "$"; color: white;
            font-size: 9px; font-weight: 900;
            horizontal-alignment: center; vertical-alignment: center;
        }
    }
}

export component CardIcon inherits Rectangle {
    in property <color> tint;
    // `debit = true` desenha tarja magnética + linha de assinatura;
    // `false` (default) desenha chip + linha de número (estilo crédito).
    in property <bool> debit: false;
    width: 32px; height: 32px;

    Rectangle {
        x: 5px; y: 9px;
        width: 22px; height: 14px;
        border-radius: 3px;
        background: tint;

        // ── Crédito: chip dourado + linha branca de "número" ───
        if !root.debit: Rectangle {
            x: 2px; y: 3px;
            width: 4px; height: 3px;
            border-radius: 1px;
            background: #FFD54F;
        }
        if !root.debit: Rectangle {
            x: 2px; y: 9px;
            width: 12px; height: 1.2px;
            background: white;
        }

        // ── Débito: tarja preta no topo + linha branca curta ───
        if root.debit: Rectangle {
            x: 0; y: 2px;
            width: parent.width; height: 3px;
            background: black;
        }
        if root.debit: Rectangle {
            x: 2px; y: 9px;
            width: 9px; height: 1.2px;
            background: white;
        }
    }
}
