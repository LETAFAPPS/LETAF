import { Theme } from "../theme.slint";
import { ProductData, CategoryData, SubcategoryData, CustomerData, OrderData, OrderItemData, BusinessHoursData } from "../types.slint";
import { DeleteBtn, EditBtn, ToggleActiveBtn, ToggleWebVisibleBtn, AdvanceOrderBtn } from "buttons.slint";
import { IconGlyph } from "../icon_glyph.slint";

// ── Componente: notificação toast ─────────────────────────────────────────

export component Toast inherits Rectangle {
    in property <string> message;
    in property <string> toast-type: "success";
    out property <length> hint-width: layout.preferred-width;

    property <color> toast-bg:
        toast-type == "error" ? Theme.danger :
        toast-type == "warning" ? #EF6C00 :
        toast-type == "info"  ? Theme.primary-dark : #2E7D32;

    background: toast-bg;
    border-radius: 10px;
    drop-shadow-blur: 12px;
    drop-shadow-offset-y: 4px;
    drop-shadow-color: #00000040;

    layout := HorizontalLayout {
        padding-left: 14px;
        padding-right: 14px;
        spacing: 8px;
        alignment: center;

        // Sem ícone — apenas o texto da notificação.
        Text {
            text: message;
            font-size: 13px;
            font-weight: 500;
            color: white;
            vertical-alignment: center;
            overflow: elide;
            max-width: 240px;
        }
    }
}

// ── Componente: container card (caixas com sombra e borda) ─────────────────

export component Card inherits Rectangle {
    border-radius: 10px;
    border-width: 1px;
    border-color: Theme.card-border;
    drop-shadow-blur: 12px;
    drop-shadow-offset-y: 0px;
    drop-shadow-color: Theme.card-shadow;
    background: Theme.surface;
}

// ── Componente: card de produto (grade de Produtos) ────────────────────────
// ProductCard reescrito: layout 100% estrutural via VerticalLayout aninhados,
// sem posicionamento absoluto, sem auto-referências de width↔height.
// Alturas internas fixas; a imagem usa min() apenas para limitar em cards estreitos.

export component ProductCard inherits Rectangle {
    in property <ProductData> product;
    callback toggle-active();
    callback toggle-web-visible();
    callback edit-product();
    callback delete-product();

    // Altura da área da imagem: limitada a 220px (cap), mas nunca maior que a largura - padding.
    // Usado apenas como height explícito — a largura efetiva vem do layout pai.
    property <length> img-box-size: min(root.width - 24px, 220px);

    background: product.active ? Theme.surface : Theme.bg;
    border-radius: 8px;
    border-width: 1px;
    border-color: Theme.card-border;
    drop-shadow-blur: 8px;
    drop-shadow-offset-y: 2px;
    drop-shadow-color: Theme.card-shadow;

    card-touch := TouchArea {
        mouse-cursor: default;
    }
    Rectangle {
        border-radius: parent.border-radius;
        background: card-touch.has-hover ? #00000008 : transparent;
    }

    VerticalLayout {
        padding: 12px;
        spacing: 8px;

        // ───── Área da imagem (quadrado 1:1, centralizado) ─────
        HorizontalLayout {
            alignment: center;
            height: root.img-box-size;
            Rectangle {
                width: root.img-box-size;
                height: root.img-box-size;
                border-radius: 8px;
                // Sem border: o fundo já delimita a área da imagem.
                //
                // Regras aplicadas (AI_RULES.md §8):
                // - Se a heurística detectou cor uniforme nos cantos da imagem
                //   (`has-cover-color`), o card pinta com a cor amostrada
                //   (Soda branca continua branca no dark mode).
                // - Senão, cai no fundo do tema (igual ao placeholder), que
                //   serve para PNGs transparentes aparecerem coerentes.
                background: product.has-cover-color
                    ? product.cover-color-value
                    : (Theme.dark-mode ? #3A3A3A : white);
                clip: true;
                if product.product-image.width > 0: Image {
                    width: parent.width;
                    height: parent.height;
                    source: product.product-image;
                    image-fit: cover;
                }
                if product.product-image.width == 0: Text {
                    text: "📷";
                    font-size: 36px;
                    color: #BDBDBD;
                    width: parent.width;
                    height: parent.height;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }
        }

        // ───── Informações textuais (cresce com vertical-stretch) ─────
        VerticalLayout {
            vertical-stretch: 1;
            spacing: 3px;

            Text {
                text: product.name;
                font-size: 14px;
                font-weight: 700;
                color: product.active ? Theme.text-primary : Theme.text-secondary;
                horizontal-alignment: center;
                overflow: elide;
            }
            if product.price != "": Text {
                text: "R$ " + product.price;
                font-size: 13px;
                font-weight: 600;
                color: product.active ? #2E7D32 : Theme.text-secondary;
                horizontal-alignment: center;
            }
            // Cor do estoque (texto): azul (ok), laranja (low), vermelho (out).
            // Quando o produto está inativo, mantém cor secundária para não
            // competir visualmente com o estado de inatividade.
            //
            // 3 estados mutuamente exclusivos:
            // - ilimitado → ícone ∞ grande (sem unidade);
            // - sem estoque → texto "Sem Estoque" em vermelho claro;
            // - com estoque → quantidade + unidade.
            if product.unlimited-stock: Text {
                // `font-size: 15px` para o ∞ destacar visualmente.
                // `height: 14px` força mesma altura de linha do texto
                // normal (11px) para não empurrar os botões abaixo.
                text: "∞";
                font-size: 15px;
                font-weight: 700;
                color: !product.active ? Theme.text-secondary : #1565C0;
                horizontal-alignment: center;
                height: 14px;
            }
            if !product.unlimited-stock && product.stock-status == "out": Text {
                text: "Sem Estoque";
                font-size: 11px;
                font-weight: 600;
                color: !product.active ? Theme.text-secondary : #EF5350;
                horizontal-alignment: center;
            }
            if !product.unlimited-stock && product.stock-status != "out": HorizontalLayout {
                alignment: center;
                spacing: 4px;
                Text {
                    text: product.stock-quantity;
                    font-size: 11px;
                    font-weight: 600;
                    color: !product.active
                        ? Theme.text-secondary
                        : (product.stock-status == "low" ? #EF6C00 : #1565C0);
                }
                if product.unit != "": Text {
                    text: product.unit;
                    font-size: 11px;
                    font-weight: 600;
                    color: !product.active
                        ? Theme.text-secondary
                        : (product.stock-status == "low" ? #EF6C00 : #1565C0);
                }
            }
            if product.barcode != "": Text {
                text: product.barcode;
                font-size: 10px;
                color: Theme.text-secondary;
                horizontal-alignment: center;
                overflow: elide;
            }
            Rectangle { vertical-stretch: 1; }
        }

        // ───── Divisor ─────
        Rectangle { height: 1px; background: Theme.border; }

        // ───── Barra de botões ─────
        HorizontalLayout {
            alignment: center;
            spacing: 10px;
            height: 32px;
            VerticalLayout {
                alignment: center;
                ToggleActiveBtn { active: product.active; clicked => { root.toggle-active(); } }
            }
            VerticalLayout {
                alignment: center;
                ToggleWebVisibleBtn { is-visible: product.web-visible; clicked => { root.toggle-web-visible(); } }
            }
            VerticalLayout {
                alignment: center;
                EditBtn { clicked => { root.edit-product(); } }
            }
            VerticalLayout {
                alignment: center;
                DeleteBtn { clicked => { root.delete-product(); } }
            }
        }
    }
}

// ── Componente: card de categoria (grade de Categorias) ──────────────────────

export component CategoryCard inherits Rectangle {
    in property <CategoryData> category;
    callback edit-category();
    callback delete-category();
    callback move-up();
    callback move-down();

    background: Theme.surface;
    border-radius: 8px;
    border-width: 1px;
    border-color: Theme.card-border;
    drop-shadow-blur: 8px;
    drop-shadow-offset-y: 2px;
    drop-shadow-color: Theme.card-shadow;
    height: 120px;

    card-touch := TouchArea {
        x: 0; y: 0;
        width: parent.width;
        height: parent.height;
        mouse-cursor: default;
    }
    Rectangle {
        border-radius: parent.border-radius;
        background: card-touch.has-hover ? #00000008 : transparent;
    }

    // Indicador no canto superior esquerdo: bolinha laranja simples.
    // Sinaliza apenas que existe um ícone cadastrado — qual ícone é,
    // o operador descobre ao editar a categoria.
    if category.icon-name != "": Rectangle {
        x: 8px;
        y: 8px;
        width: 10px;
        height: 10px;
        border-radius: 5px;
        background: Theme.primary;
    }

    VerticalLayout {
        padding: 10px;
        spacing: 4px;
        Text {
            text: category.name;
            font-size: 14px;
            font-weight: 700;
            color: Theme.text-primary;
            horizontal-alignment: center;
            overflow: elide;
        }
        if category.description != "": Text {
            text: category.description;
            font-size: 11px;
            color: Theme.text-secondary;
            horizontal-alignment: center;
            overflow: elide;
        }
        Rectangle { vertical-stretch: 1; }
        Rectangle { height: 1px; background: Theme.border; }
        HorizontalLayout {
            alignment: center;
            spacing: 6px;
            height: 26px;
            VerticalLayout {
                alignment: center;
                TouchArea {
                    width: 20px; height: 20px;
                    clicked => { root.move-up(); }
                    Rectangle {
                        border-radius: 4px;
                        background: parent.has-hover ? Theme.row-hover : transparent;
                        Text {
                            text: "\u{25C4}";
                            font-size: 9px;
                            color: Theme.text-secondary;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                }
            }
            VerticalLayout {
                alignment: center;
                TouchArea {
                    width: 20px; height: 20px;
                    clicked => { root.move-down(); }
                    Rectangle {
                        border-radius: 4px;
                        background: parent.has-hover ? Theme.row-hover : transparent;
                        Text {
                            text: "\u{25BA}";
                            font-size: 9px;
                            color: Theme.text-secondary;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                }
            }
            VerticalLayout {
                alignment: center;
                EditBtn { clicked => { root.edit-category(); } }
            }
            VerticalLayout {
                alignment: center;
                DeleteBtn { clicked => { root.delete-category(); } }
            }
        }
    }
}

