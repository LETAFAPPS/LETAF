import { Theme } from "../theme.slint";
import { AssetIcon } from "icons.slint";

// ── Componente: campo de formulario ─────────────────────────────────────────

export component FormField inherits VerticalLayout {
    in property <string> label;
    in-out property <string> value;
    in property <string> placeholder: "";
    in property <InputType> input-type: text;
    // Quando true, força o cursor ao final após cada edição (usar apenas em campos com máscara).
    in property <bool> force-end-cursor: false;
    /// Quando false, o input fica somente leitura (cinza). Útil para
    /// campos que dependem de outro estado (ex.: máximo fixo quando
    /// o modo é "Único"). Default `true`.
    in property <bool> enabled: true;
    /// Ícone opcional à esquerda do campo (vazio = sem ícone). Só ocupa
    /// espaço quando informado, então as telas existentes não mudam.
    in property <image> icon;
    /// Mensagem de erro opcional, exibida ABAIXO do campo e realçando a
    /// borda. É apenas FEEDBACK de UX (§11): a validação que vale é a do
    /// backend, que revalida tudo e é a autoridade.
    in property <string> error: "";
    callback edited(string);
    callback accepted();
    spacing: 4px;

    Text {
        text: root.label;
        font-size: 12px;
        font-weight: 500;
        color: Theme.text-secondary;
    }
    Rectangle {
        height: 32px;
        border-radius: 6px;
        border-width: 1px;
        border-color: root.error != "" ? Theme.danger
            : (input.has-focus ? Theme.primary : Theme.border);
        background: root.enabled ? Theme.surface : Theme.row-hover;
        opacity: root.enabled ? 1.0 : 0.6;

        HorizontalLayout {
            padding-left: 8px;
            padding-right: 8px;
            spacing: 6px;

            if root.icon.width > 0: VerticalLayout {
                alignment: center;
                AssetIcon {
                    width: 15px; height: 15px; icon-size: 15px;
                    icon-color: root.error != "" ? Theme.danger
                        : (input.has-focus ? Theme.primary : Theme.text-secondary);
                    source: root.icon;
                }
            }

            input := TextInput {
                text <=> root.value;
                input-type: root.input-type;
                font-size: 13px;
                color: Theme.text-primary;
                single-line: true;
                vertical-alignment: center;
                enabled: root.enabled;
                edited => {
                    root.edited(input.text);
                    if root.force-end-cursor { input.set-selection-offsets(9999, 9999); }
                }
                accepted => { root.accepted(); }
            }
        }

        // placeholder
        if root.value == "": Text {
            text: root.placeholder;
            font-size: 13px;
            color: #BDBDBD;
            vertical-alignment: center;
            x: root.icon.width > 0 ? 29px : 8px;
            width: parent.width - (root.icon.width > 0 ? 37px : 16px);
            height: parent.height;
        }

        // Ao clicar sem foco (e habilitado), posiciona cursor no final.
        if !input.has-focus && root.enabled: TouchArea {
            clicked => {
                input.focus();
                input.select-all();
            }
        }
    }

    // Mensagem de erro (só aparece quando há erro — não desloca o layout
    // dos formulários que não usam esta funcionalidade).
    if root.error != "": Text {
        text: root.error;
        font-size: 11px;
        color: Theme.danger;
        wrap: word-wrap;
    }
}

// ── Componente: campo de senha com toggle de visibilidade ───────────────────
// Regras aplicadas (AI_RULES.md §3, §8):
// - Responsabilidade única: exibir/ocultar senha sem lógica de negócio
// - Estado interno (show-password) não exposto ao Rust

export component PasswordField inherits VerticalLayout {
    in property <string> label;
    in-out property <string> value;
    in property <string> placeholder: "";
    callback accepted();

    property <bool> show-password: false;
    spacing: 4px;

    Text {
        text: root.label;
        font-size: 12px;
        font-weight: 500;
        color: Theme.text-secondary;
    }
    Rectangle {
        height: 32px;
        border-radius: 6px;
        border-width: 1px;
        border-color: pwd-input.has-focus ? Theme.primary : Theme.border;
        background: Theme.surface;

        HorizontalLayout {
            padding-left: 8px;
            padding-right: 2px;

            pwd-input := TextInput {
                text <=> root.value;
                input-type: root.show-password ? InputType.text : InputType.password;
                font-size: 13px;
                color: Theme.text-primary;
                single-line: true;
                vertical-alignment: center;
                accepted => { root.accepted(); }
            }

            toggle-ta := TouchArea {
                width: 28px;
                if !root.show-password: Path {
                    x: (parent.width - 16px) / 2;
                    y: (parent.height - 14px) / 2;
                    width: 16px;
                    height: 14px;
                    viewbox-width: 24;
                    viewbox-height: 24;
                    fill: toggle-ta.has-hover ? Theme.text-primary : Theme.text-secondary;
                    commands: "M12 4.5C7 4.5 2.73 7.61 1 12c1.73 4.39 6 7.5 11 7.5s9.27-3.11 11-7.5C21.27 7.61 17 4.5 12 4.5zm0 12c-2.76 0-5-2.24-5-5s2.24-5 5-5 5 2.24 5 5-2.24 5-5 5zm0-8c-1.66 0-3 1.34-3 3s1.34 3 3 3 3-1.34 3-3-1.34-3-3-3z";
                }
                if root.show-password: Path {
                    x: (parent.width - 16px) / 2;
                    y: (parent.height - 14px) / 2;
                    width: 16px;
                    height: 14px;
                    viewbox-width: 24;
                    viewbox-height: 24;
                    fill: toggle-ta.has-hover ? Theme.text-primary : Theme.text-secondary;
                    commands: "M12 7c2.76 0 5 2.24 5 5 0 .65-.13 1.26-.36 1.83l2.92 2.92c1.51-1.26 2.7-2.89 3.43-4.75C21.27 7.61 17 4.5 12 4.5c-1.23 0-2.41.2-3.51.57l2.17 2.17C11.26 7.13 11.61 7 12 7zM2 4.27l2.28 2.28.46.46C3.08 8.3 1.78 10.02 1 12c1.73 4.39 6 7.5 11 7.5 1.55 0 3.03-.3 4.38-.84l.42.42L19.73 22 21 20.73 3.27 3 2 4.27zM7.53 9.8l1.55 1.55c-.05.21-.08.43-.08.65 0 1.66 1.34 3 3 3 .22 0 .44-.03.65-.08l1.55 1.55c-.67.33-1.41.53-2.2.53-2.76 0-5-2.24-5-5 0-.79.2-1.53.53-2.2zm4.31-.78l3.15 3.15.02-.16c0-1.66-1.34-3-3-3l-.17.01z";
                }
                clicked => { root.show-password = !root.show-password; }
            }
        }

        if root.value == "": Text {
            text: root.placeholder;
            font-size: 13px;
            color: #BDBDBD;
            vertical-alignment: center;
            x: 8px;
            width: parent.width - 36px;
            height: parent.height;
        }

        if !pwd-input.has-focus: TouchArea {
            x: 0;
            width: parent.width - 28px;
            clicked => {
                pwd-input.focus();
                pwd-input.select-all();
            }
        }
        if pwd-input.has-focus: TouchArea {
            x: 0;
            width: parent.width - 28px;
            clicked => {
                pwd-input.focus();
                pwd-input.set-selection-offsets(root.value.character-count, root.value.character-count);
            }
        }
    }
}

// ── Componente: campo de horário com máscara HH:MM ────────────────────────
// Regras aplicadas (AI_RULES.md §1, §8):
// - Lógica de formatação delegada ao callback apply-mask (§1 — sem lógica na UI)
// - Cursor sempre posicionado ao final após edição (substituição sequencial)

export component TimeInput inherits VerticalLayout {
    in property <string> label;
    in-out property <string> value;
    callback apply-mask(string) -> string;
    spacing: 4px;

    Text {
        text: root.label;
        font-size: 12px;
        font-weight: 500;
        color: Theme.text-secondary;
    }
    Rectangle {
        height: 32px;
        border-radius: 6px;
        border-width: 1px;
        border-color: ti.has-focus ? Theme.primary : Theme.border;
        background: Theme.surface;

        HorizontalLayout {
            padding-left: 8px;
            padding-right: 8px;

            ti := TextInput {
                text <=> root.value;
                font-size: 13px;
                color: Theme.text-primary;
                single-line: true;
                vertical-alignment: center;
                edited => {
                    root.value = root.apply-mask(ti.text);
                    ti.set-selection-offsets(9999, 9999);
                }
            }
        }

        if root.value == "": Text {
            text: "00:00";
            font-size: 13px;
            color: #BDBDBD;
            vertical-alignment: center;
            x: 8px;
            width: parent.width - 16px;
            height: parent.height;
        }

        if !ti.has-focus: TouchArea {
            clicked => {
                ti.focus();
                ti.select-all();
            }
        }
    }
}
