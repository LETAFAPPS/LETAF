    callback card-modal-close();
    callback card-modal-submit();
    // Máscaras de input (implementadas no Rust).
    callback card-fmt-number(string) -> string;
    callback card-fmt-expiry(string) -> string;
    callback card-fmt-cvv(string) -> string;
    callback card-fmt-cpf-cnpj(string) -> string;
    callback card-fmt-birth(string) -> string;
    callback card-fmt-phone(string) -> string;

