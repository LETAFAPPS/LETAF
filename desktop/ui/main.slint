    /// Filtro de status. "all" | "open" | "overdue" | "settled".
    in-out property <string> finance-status-filter: "all";
    // Página atual de cada grupo (paginação de 10 por status). O Rust lê
    // estas props em apply_snapshot e grava de volta o valor clampeado.
    in-out property <int> finance-page-overdue: 1;
    in-out property <int> finance-page-pending: 1;
    in-out property <int> finance-page-settled: 1;
    in-out property <int> finance-page-cancelled: 1;
    in-out property <[FinanceKpi]> finance-kpis: [];
    in-out property <[FinanceTab]> finance-tabs: [];
    in-out property <[FinanceEntryRow]> finance-entries: [];
