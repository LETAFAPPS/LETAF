import { Button, VerticalBox, HorizontalBox, ScrollView } from "std-widgets.slint";
import { Theme } from "theme.slint";
export { Theme } from "theme.slint";
import { ProductData, CustomerData, CategoryData, CategoryIconOption, SubcategoryData, BusinessHoursData, OrderData, OrderItemData, EditOrderItem, ConfigVariation, ConfigOption, ConfigAddonGroup, ConfigAddon, CategoryFilterEntry, SubcategoryFilterEntry, DiscountTierData, AddonGroupData, AddonData, VariationData, VariationOptionData, BannerData, CouponData, CustomerOrderRow, CustomerAddressRow, CatTreeRow, CatProduct, CatSub, KanbanCol, CalDay, PrinterData, PrinterCategoryRow, PdvProductRow, PdvCartRow, PdvCategoryChip, PdvCustomerRow, PdvAddressRow } from "types.slint";
export { ProductData, CustomerData, CategoryData, CategoryIconOption, SubcategoryData, BusinessHoursData, OrderData, OrderItemData, CategoryFilterEntry, SubcategoryFilterEntry, DiscountTierData, AddonGroupData, AddonData, VariationData, VariationOptionData, BannerData, CouponData, CustomerOrderRow, CustomerAddressRow, CatTreeRow, CatProduct, CatSub, KanbanCol, CalDay, PrinterData, PrinterCategoryRow, PdvProductRow, PdvCartRow, PdvCategoryChip, PdvCustomerRow, PdvAddressRow } from "types.slint";
import { Toast } from "components/cards.slint";
import { LoginPage } from "pages/login_page.slint";
import { Sidebar } from "layouts/sidebar.slint";
import { ProductsPage } from "pages/products_page.slint";
import { CategoriesPage } from "pages/categories_page.slint";
import { CollaboratorsPage } from "pages/collaborators_page.slint";
import { CollabPermRow, CollabRoleRow, CollabEmployeeRow } from "types.slint";
import { AdminCompanyRow, AdminSubscriptionRow, AdminInvoiceRow, AdminAuditRow, AdminUserRow, AdminPlanRow } from "types.slint";
import { CustomersPage } from "pages/customers_page.slint";
import { OrdersPage, CalendarPopup } from "pages/orders_page.slint";
import { SettingsPage } from "pages/settings_page.slint";
// `ProductFormPage` deixou de ser instanciada aqui — a `ProductsPage`
// embute o form no painel direito da master-detail (Fase 9). O arquivo
// continua existindo porque o `ProductsPage` o importa com `embedded:
// true` para reaproveitar todos os cards.
import { AddonsPage } from "pages/addons_page.slint";
import { BannersPage } from "pages/banners_page.slint";
import { BannerModal } from "modals/banner_modal.slint";
import { CouponsPage } from "pages/coupons_page.slint";
import { CouponModal } from "modals/coupon_modal.slint";
import { CategoryModal, SubcategoryModal } from "modals/category_modal.slint";
import { AddonGroupModal, AddonItemModal } from "modals/addon_modal.slint";
import { CustomerModal } from "modals/customer_modal.slint";
import { SettingsModal } from "modals/settings_modal.slint";
import { CancelOrderModal } from "modals/cancel_order_modal.slint";
import { ReceiptModal } from "modals/receipt_modal.slint";
import { EditOrderModal } from "modals/edit_order_modal.slint";
import { ProductConfiguratorModal } from "modals/product_configurator_modal.slint";
import { UpdateModal } from "modals/update_modal.slint";
import { LogoutConfirmModal } from "modals/logout_confirm_modal.slint";
import { DeleteConfirmModal } from "modals/delete_confirm_modal.slint";
import { NewOrderAlarmModal } from "modals/new_order_alarm_modal.slint";
import { PrinterModal } from "modals/printer_modal.slint";
import { PdvPage } from "pages/pdv_page.slint";
import { AdminOverviewPage } from "pages/admin_overview_page.slint";
import { AdminCompaniesPage } from "pages/admin_companies_page.slint";
import { AdminSubscriptionsPage } from "pages/admin_subscriptions_page.slint";
import { AdminAuditPage } from "pages/admin_audit_page.slint";
import { AdminSubscriptionModal } from "modals/admin_subscription_modal.slint";
import { AdminAdminsPage } from "pages/admin_admins_page.slint";
import { AdminPlansPage } from "pages/admin_plans_page.slint";
import { PdvSoldModal } from "modals/pdv_sold_modal.slint";
import { PdvCustomerPickerModal } from "modals/pdv_customer_picker_modal.slint";
import { PdvCartModal } from "modals/pdv_cart_modal.slint";
import { CashPage } from "pages/cash_page.slint";
import { InventoryPage } from "pages/inventory_page.slint";
import { StockAdjustModal } from "modals/stock_adjust_modal.slint";
import { CashOpenModal } from "modals/cash_open_modal.slint";
import { CashSangriaModal } from "modals/cash_sangria_modal.slint";
import { CashSuprimentoModal } from "modals/cash_suprimento_modal.slint";
import { CashCloseModal } from "modals/cash_close_modal.slint";
import { PdvBlockedView } from "pages/pdv_blocked_view.slint";
import { CashSessionRow, CashMovementRow, CashMethodTotalRow, CashSummaryData } from "types.slint";
import { InventoryHealthData, InventoryProductRow } from "types.slint";
import { NavPerms } from "types.slint";
import { DashboardKpi, DashboardBarPoint, DashboardComparePoint, DashboardTopProduct, DashboardPaymentSlice, DashboardLinePoint } from "types.slint";
import { DashboardPage } from "pages/dashboard_page.slint";
import {
    ReportOption, ReportKpi,
    ReportDailyBar, ReportHBar, ReportDreLine,
    ReportProductRow, ReportCustomerRow,
    ReportNewVsReturning, ReportHourlyBar,
} from "types.slint";
import { ReportsPage } from "pages/reports_page.slint";
import { FinanceKpi, FinanceTab, FinanceEntryRow, FinanceCategoryOption, FinanceCashFlowPoint, FinanceCalendarCell, FinanceDayRow } from "types.slint";
import { WalletSummary, WalletMovementRow } from "types.slint";
import { WalletDepositModal, WalletWithdrawModal, WalletAdjustModal, WalletLimitModal } from "modals/wallet_modals.slint";
import { FinancePage } from "pages/finance_page.slint";
import { FinanceEntryModal } from "modals/finance_entry_modal.slint";
import { PlanCardData, SubscriptionData, SubscriptionInvoiceRow, PixChargeView, PaymentMethodOption } from "types.slint";
import { SubscriptionPage } from "pages/subscription_page.slint";
import { PixChargeModal } from "modals/pix_charge_modal.slint";
import { CardModal } from "modals/card_modal.slint";
import { PixAutoModal } from "modals/pix_auto_modal.slint";
import { PlanChangeConfirmModal } from "modals/plan_change_confirm_modal.slint";
import { ProfileModal } from "modals/profile_modal.slint";

// ══════════════════════════════════════════════════════════════════════════════
//  JANELA PRINCIPAL
// ══════════════════════════════════════════════════════════════════════════════
//
// Regras aplicadas (AI_RULES.md §1, §3, §8, §11):
// - Desktop usa Slint (§3)
// - UI nao contem logica de negocio (§1, §14)
// - Callbacks delegam ao Rust (§1)
// - Login obrigatorio para sincronizar (§11)
// - Componentes reutilizaveis, responsivo (§3, §8)
// - Telas separadas para lista e cadastro (responsabilidade unica, §8)

export component MainWindow inherits Window {
    title: "LETAF";
    preferred-width: 1100px;
    preferred-height: 700px;
    min-width: 640px;
    min-height: 480px;
    background: Theme.bg;

    /// Altura útil da janela em pixels lógicos. Atualizada pelo Rust
    /// no setup e em cada resize via `Window::on_resize_event` (ou
    /// equivalente). Necessária porque `root.height` em layouts
    /// aninhados não propaga corretamente via property — usar valor
    /// setado em Rust evita toda a cadeia de layout buggy do Slint.
    in-out property <length> live-window-height: 800px;
    // Tipografia base do sistema: Geist + corpo 14/400 (spec).
    // Todo `Text` herda a família; se a Geist não estiver
    // instalada/embarcada, o Slint usa o fallback padrão.
    default-font-family: Theme.font-sans;
    default-font-size: Theme.fs-body;
    default-font-weight: Theme.fw-regular;

    // ── Sidebar (Fase 14F: colapsada por padrão) ────
    /// `true` mostra rótulos + 248px; `false` esconde rótulos + 76px.
    /// Toggle ao clicar no logo do topo.
    in-out property <bool> sidebar-expanded: false;

    // ── Login state ─────────────────────────────────
    in-out property <bool> logged-in: false;
    in-out property <string> login-email: "";
    in-out property <string> login-password: "";
    in-out property <string> login-status: "";
    in-out property <bool> login-remember-me: false;
    /// Subdomínio do último login (vazio = nunca logou). Exibido no
    /// rodapé da tela de login para identificar o estabelecimento.
    in-out property <string> login-subdomain: "";
    /// Versão do app (ex.: "v0.1.0") — exibida na tela de login.
    in-out property <string> app-version: "";

    // ── Atualização do desktop (RBAC-independente) ──
    // Preenchidas pelo UpdateChecker (Rust) quando há versão nova.
    in-out property <bool> update-available: false;
    in-out property <string> update-version;
    in-out property <string> update-notes;
    in-out property <bool> update-mandatory: false;
    in-out property <string> update-url;
    in-out property <string> update-sha256;
    /// Status do auto-update ("Baixando…", "Instalando…") e erro, se houver.
    in-out property <string> update-status;
    in-out property <string> update-error;
    /// Auto-update: baixa, valida sha256, substitui o binário e reinicia.
    callback apply-update();
    /// Fallback manual: abre a URL de download no navegador/SO.
    callback open-update-url();
    callback do-login();
    callback login-with-pin();
    // Recuperação de senha ("esqueci a senha") — estado + ações no Rust.
    in-out property <int> recovery-step: 0;
    in-out property <string> recovery-email: "";
    in-out property <string> recovery-code: "";
    in-out property <string> recovery-new-password: "";
    in-out property <string> recovery-status: "";
    in-out property <bool> recovery-busy: false;
    callback recovery-forgot();
    callback recovery-verify();
    callback recovery-reset();
    // Perfil do usuário logado (clique na conta do menu lateral). O Rust
    // busca /auth/me ao abrir e salva via PUT /auth/profile.
    in-out property <bool> profile-open: false;
    in-out property <string> profile-name: "";
    in-out property <string> profile-email: "";
    in-out property <string> profile-new-password: "";
    in-out property <string> profile-status: "";
    in-out property <bool> profile-busy: false;
    // Foto de perfil decodificada (vazia = sem foto).
    in-out property <image> profile-avatar;
    // Base64 da foto atual (reenviado no save; "" = sem foto).
    in-out property <string> profile-avatar-data: "";
    // `true` enquanto a foto escolhida está sendo processada.
    in-out property <bool> profile-avatar-loading: false;
    callback open-profile();
    callback profile-save();
    // Abre o seletor de arquivo e envia a nova foto (Rust).
    callback profile-pick-avatar();
    callback do-logout();
    callback dark-mode-changed(bool);

    // ── Navegacao ───────────────────────────────────
    // Pedidos é a tela principal do operador (fluxo do dia). "dashboard",
    // Landing inicial: Dashboard (visão consolidada de KPIs + vendas
    // da semana). Atalhos da sidebar redirecionam para Pedidos/PDV.
    in-out property <string> active-tab: "dashboard";
    // Aba inicial a aplicar APÓS o primeiro frame. Setar `active-tab`
    // direto no restore (antes da janela montar) faz o Slint montar a
    // página durante o layout inicial → recursão de binding em telas que
    // dependem de `root.height` (ex.: PDV). Adiar via Timer monta a tela
    // com o layout já estabelecido, como numa navegação normal.
    in-out property <string> pending-initial-tab: "";
    Timer {
        interval: 1ms;
        // `running` segue só o binding: ao zerar pending-initial-tab no
        // triggered, vira false sozinho (sem atribuição imperativa).
        running: root.pending-initial-tab != "";
        triggered => {
            root.active-tab = root.pending-initial-tab;
            root.pending-initial-tab = "";
            // Sessão restaurada de super admin: carrega o painel ao abrir
            // (qualquer aba de plataforma).
            if root.active-tab == "admin-overview" || root.active-tab == "admin-companies"
               || root.active-tab == "admin-subscriptions" || root.active-tab == "admin-admins"
               || root.active-tab == "admin-plans" || root.active-tab == "admin-audit" {
                root.admin-refresh();
            }
        }
    }
    in-out property <bool> show-modal: false;
    in-out property <string> modal-type: "";
    in-out property <bool> show-delete-confirm: false;
    in-out property <string> delete-target-id: "";
    in-out property <string> delete-target-name: "";
    in-out property <string> delete-target-type: "";
    callback confirm-delete();

    // ── Produtos ────────────────────────────────────
    property <int> products-cols:
        root.width > 1800px ? 7
        : (root.width > 1500px ? 6
            : (root.width > 1250px ? 5 : 4));
    in-out property <[ProductData]> products: [];
    in-out property <int> products-active-count: 0;
    in-out property <int> products-inactive-count: 0;
    /// ID do produto selecionado na master-detail. Vazio = nenhum
    /// (detalhe mostra placeholder). Alterado via callback
    /// `select-product`; o Rust valida e popula `detail-product`.
    in-out property <string> selected-product-id: "";
    /// Snapshot do produto mostrado no painel direito da tela
    /// Produtos. O Rust monta o ProductData a partir do cache em
    /// `select-product`.
    in-out property <ProductData> detail-product;
    /// Total de pedidos ativos (status != Entregue/Cancelado).
    /// Alimentado em Rust e usado no badge da sidebar.
    in-out property <int> orders-active-count: 0;
    /// Badges da sidebar: contas vencidas (Financeiro) e produtos fora
    /// de estoque (Estoque). Alimentados em Rust.
    in-out property <int> finance-overdue-count: 0;
    in-out property <int> stock-out-count: 0;
    in-out property <string> product-name: "";
    in-out property <string> product-description: "";
    in-out property <string> product-price: "";
    /// Preço de custo (Fase 9 — tela Produtos). Vazio = sem custo
    /// cadastrado; a UI mostra "—" na margem e o relatório de
    /// rentabilidade ignora o item.
    in-out property <string> product-cost-price: "";
    in-out property <string> product-stock-quantity: "";
    /// Estoque mínimo desejado (Fase 9). Vazio/0 desliga o alerta
    /// "baixo" e a sugestão de compra. Segue a mesma regra de
    /// arredondamento do estoque atual conforme a unidade.
    in-out property <string> product-min-stock: "";
    /// Resumo de margem em pt-BR (Fase 9). "—" quando faltam dados
    /// (sem preço ou sem custo). Recalculado pelo Rust no
    /// request-edit/request-new.
    in-out property <string> product-margin-display: "—";
    in-out property <string> product-barcode: "";
    in-out property <string> product-unit: "un";
    /// "weight" | "price" — só relevante quando unit == "kg".
    /// Padrão "price": a maioria das balanças no varejo brasileiro emite
    /// etiqueta com o valor já calculado (não com o peso). [[product_modal_balance_mode]]
    in-out property <string> product-balance-mode: "price";
    in-out property <string> product-image-data: "";
    /// Cor de fundo detectada nas bordas da imagem do produto (#RRGGBB).
    /// Vazio = não detectado / imagem transparente → card cai no tema.
    in-out property <string> product-cover-color: "";
    in-out property <bool>   product-image-loading: false;
    /// Quando `true`, o produto é tratado como "estoque infinito": filtros
    /// do catálogo nunca o escondem por falta de estoque, carrinho não
    /// impõe teto e baixa de estoque é pulada no `OrderService::create`.
    in-out property <bool>   product-unlimited-stock: false;
    /// Disponibilidade do produto no cardápio web: quando `false`, o
    /// produto está sempre disponível; quando `true`, segue a agenda em
    /// `product-availability` (7 entradas, uma por dia).
    in-out property <bool>   product-availability-enabled: false;
    in-out property <[BusinessHoursData]> product-availability: [];
    /// Tipo de desconto: "none" (UI sentinel) ou um dos 4 kinds do core.
    in-out property <string> product-discount-kind: "none";
    in-out property <string> product-discount-value: "";
    in-out property <string> product-discount-min-qty: "";
    /// Faixas (tiers) para `bulk_*`. O Rust serializa/desserializa o JSON
    /// e popula esta lista — push/remove via `add-discount-tier` /
    /// `remove-discount-tier` (callbacks também no Rust).
    in-out property <[DiscountTierData]> product-discount-tiers: [];
    in-out property <string> product-category-id: "";
    in-out property <string> product-category-name: "";
    in-out property <bool>   product-category-open: false;
    in-out property <string> product-subcategory-id: "";
    in-out property <string> product-subcategory-name: "";
    in-out property <bool>   product-subcategory-open: false;
    in-out property <string> status-message: "Pronto";
    in-out property <string> product-error-name: "";
    in-out property <string> product-error-price: "";
    in-out property <string> product-error-stock: "";
    in-out property <string> product-save-error: "";
    in-out property <string> editing-id: "";
    callback add-product();
    callback update-product();
    callback toggle-product-active(string);
    callback toggle-product-web-visible(string);
    callback delete-product(string);
    /// Duplica um produto: o Rust lê o original, cria uma cópia com
    /// novo ID + nome "(cópia)" e devolve o ProductData no modelo.
    callback duplicate-product(string);
    /// Seleciona o produto pelo ID na master-detail. O Rust resolve
    /// `detail-product` a partir do cache e atualiza `selected-product-id`.
    callback select-product(string);
    /// Limpa o snapshot `detail-product` para o estado default (sem
    /// imagem, sem cor, etc.). Slint não permite atribuir campos
    /// individuais de struct, então o reset acontece no Rust.
    /// Disparado pelo `request-new` antes de zerar o form.
    callback clear-detail-product();
    callback refresh-products();
    /// Aplica o filtro de produtos com a busca textual atual; os demais
    /// filtros (categorias, subcategorias, status, estoque) ficam no
    /// Rust e são alterados via os toggle-/set-* callbacks abaixo.
    callback filter-products(string);
    callback pick-product-image();
    /// Pede ao Rust para deserializar o JSON da agenda e popular
    /// `product-availability` (7 entradas). String vazia → carrega
    /// o default (todos os dias ativos 08:00-22:00).
    callback load-product-availability(string);
    /// Recarrega `product-addon-groups` (chips) marcando `selected` para
    /// cada ID presente no CSV. String vazia = sem nenhum marcado.
    callback load-product-addon-groups(string);
    /// Adiciona uma faixa em branco em `product-discount-tiers`.
    /// O Rust faz push no VecModel — o Slint não tem helper de array.
    callback add-discount-tier();
    /// Remove a faixa no índice indicado.
    callback remove-discount-tier(int);
    /// Pede ao Rust para parsear o JSON `discount_tiers` e popular a
    /// lista exposta na UI. String vazia limpa a lista.
    callback load-discount-tiers(string);

    // ── Estado de filtros de produtos (multi-select, mantido no Rust) ──
    //
    // Regras aplicadas (AI_RULES.md §1, §11):
    // - O estado da seleção fica no Rust; o Slint apenas reflete o que
    //   o Rust devolve via `filter-cats` / `filter-subs` (com `selected:
    //   bool` em cada entrada). Isso evita lógica de set/manipulação de
    //   coleções dentro do Slint.
    // - `filter-status` / `filter-stock` são strings simples com 3
    //   valores: "active" | "inactive" | "both" (e o equivalente para
    //   estoque). Padrão: "active" + "with" (só vendáveis).
    in-out property <[CategoryFilterEntry]>    filter-cats: [];
    in-out property <[SubcategoryFilterEntry]> filter-subs: [];
    in-out property <string> filter-status: "both";
    in-out property <string> filter-stock:  "both";
    in-out property <int>    filter-active-count: 0;
    callback toggle-category-filter(string);
    callback toggle-subcategory-filter(string);
    callback set-status-filter(string);
    callback set-stock-filter(string);
    callback reset-product-filters();

    // ── Clientes ────────────────────────────────────
    in-out property <[CustomerData]> customers: [];
    in-out property <string> customer-name: "";
    in-out property <string> customer-email: "";
    in-out property <string> customer-phone: "";
    in-out property <string> customer-document: "";
    in-out property <image> customer-profile-picture;
    in-out property <string> customer-avatar-initial: "?";
    in-out property <string> customer-error-name: "";
    in-out property <string> customer-error-email: "";
    in-out property <string> customer-error-phone: "";
    in-out property <string> customer-error-document: "";
    /// Observação interna editável no modal de cliente.
    in-out property <string> customer-notes: "";
    /// Cliente selecionado no master-detail (vazio = nenhum).
    in-out property <string> selected-customer-id: "";
    /// Dados do cliente em foco no painel de detalhe.
    in-out property <CustomerData> detail-customer;
    /// Pedidos recentes do cliente em foco.
    in-out property <[CustomerOrderRow]> detail-recent-orders: [];
    in-out property <[CustomerAddressRow]> detail-addresses: [];
    /// Campos do form de novo endereço no modal de cliente.
    in-out property <string> customer-addr-label: "Casa";
    in-out property <string> customer-addr-custom-label: "";
    in-out property <string> customer-addr-street: "";
    in-out property <string> customer-addr-number: "";
    in-out property <string> customer-addr-neighborhood: "";
    in-out property <string> customer-addr-apartment: "";
    callback add-customer();
    callback update-customer();
    callback add-customer-address();
    callback delete-customer-address(string);
    callback delete-customer(string);
    callback refresh-customers();
    callback filter-customers(string);
    callback select-customer(string);
    callback new-customer-order(string);
    callback format-customer-phone(string) -> string;
    callback format-customer-document(string) -> string;

    // ── Categorias ──────────────────────────────────
    in-out property <[CategoryData]> categories: [];
    in-out property <string> category-name: "";
    in-out property <string> category-description: "";
    in-out property <string> category-error-name: "";
    /// Slug do ícone selecionado no formulário ("" = sem ícone).
    /// Persistido em `Category.icon_name` ao salvar.
    in-out property <string> category-icon-name: "";
    /// Allowlist de ícones disponíveis (populada pelo Rust a partir
    /// de `letaf_core::category::icons::ICONS`). Estática, sem rede.
    in-out property <[CategoryIconOption]> category-icon-options: [];
    callback add-category();
    callback update-category();
    callback delete-category(string);
    callback reorder-category(string, bool);

    // ── Subcategorias ───────────────────────────────
    in-out property <[SubcategoryData]> subcategories: [];
    in-out property <string> subcategory-name: "";
    in-out property <string> subcategory-category-id: "";
    in-out property <string> subcategory-category-name: "";
    in-out property <string> subcategory-error-name: "";
    in-out property <string> subcategory-error-category: "";
    in-out property <bool> subcategory-category-open: false;
    in-out property <string> subcategory-filter-category-id: "all";
    callback refresh-subcategories();
    callback add-subcategory();
    callback update-subcategory();
    callback delete-subcategory(string);
    callback reorder-subcategory(string, bool);
    callback refresh-categories();

    // ── Categorias: master-detail (árvore + detalhe) ────────────────
    // Tree e detalhe vêm prontos do Rust (cache + agregação). Sem
    // contagem na lista mestra (pedido do usuário); detalhe sim.
    in-out property <[CatTreeRow]> category-tree: [];
    in-out property <int> category-count: 0;
    in-out property <string> selected-category-id: "";
    in-out property <CategoryData> detail-category;
    in-out property <color> detail-color;
    in-out property <int> detail-prod-count: 0;
    in-out property <int> detail-sub-count: 0;
    in-out property <string> detail-stock-value: "";
    in-out property <string> detail-catalog-pct: "";
    in-out property <string> detail-catalog-hint: "";
    in-out property <[CatProduct]> detail-cat-products: [];
    in-out property <[CatSub]> detail-cat-subs: [];
    callback select-category(string);
    callback toggle-category(string);

    // ── Adicionais (Fase 4B) ────────────────────────
    in-out property <[AddonGroupData]> addon-groups: [];
    in-out property <[AddonData]> current-group-addons: [];
    in-out property <string> selected-addon-group-id: "";
    in-out property <string> selected-addon-group-name: "";
    // Form do modal de grupo.
    in-out property <string> addon-group-form-id: "";
    in-out property <string> addon-group-form-name: "";
    in-out property <string> addon-group-form-selection: "single";
    in-out property <string> addon-group-form-min: "0";
    in-out property <string> addon-group-form-max: "0";
    in-out property <string> addon-group-form-error: "";
    // Form do modal de addon individual.
    in-out property <string> addon-form-id: "";
    in-out property <string> addon-form-name: "";
    in-out property <string> addon-form-price: "";
    in-out property <string> addon-form-error: "";
    callback refresh-addon-groups();
    callback select-addon-group(string);
    callback save-addon-group();
    callback delete-addon-group(string);
    callback save-addon();
    callback delete-addon(string);
    callback toggle-addon-active(string);

    // ── Banners (Fase 7) ────────────────────────────
    in-out property <[BannerData]> banners: [];
    in-out property <int> banners-active-count: 0;
    in-out property <int> banners-inactive-count: 0;
    in-out property <string> banner-title: "";
    in-out property <string> banner-item-type: "product";
    in-out property <string> banner-product-id: "";
    in-out property <string> banner-product-name: "";
    /// Texto da barra de busca do produto. Sugestões só aparecem
    /// quando há algo digitado; clicar em uma sugestão preenche
    /// `banner-product-id`/`banner-product-name` e limpa a busca.
    in-out property <string> banner-product-search: "";
    /// Lista de produtos filtrada pela pesquisa. Rust mantém em sync
    /// com `banner-product-search` (Slint não tem `string.contains`).
    in-out property <[ProductData]> banner-product-filtered: [];
    /// Pedido para o Rust refiltrar a lista (depois que o operador
    /// digita na barra de busca).
    callback filter-banner-products();
    in-out property <string> banner-url: "";
    in-out property <string> banner-image-data: "";
    in-out property <image>  banner-image;
    in-out property <bool>   banner-image-loading: false;
    in-out property <string> banner-error-title: "";
    in-out property <string> banner-error-image: "";
    in-out property <string> banner-error-target: "";
    callback refresh-banners();
    callback pick-banner-image();
    callback add-banner();
    callback update-banner();
    callback delete-banner(string);
    callback toggle-banner-active(string);

    // ── Cupons (Fase 8) ────────────────────────────
    in-out property <[CouponData]> coupons: [];
    in-out property <int> coupons-active-count: 0;
    in-out property <int> coupons-inactive-count: 0;
    in-out property <string> coupon-title: "";
    in-out property <string> coupon-code: "";
    in-out property <string> coupon-type: "standard";
    in-out property <string> coupon-discount-kind: "fixed";
    in-out property <string> coupon-discount-value: "";
    in-out property <string> coupon-min-order: "";
    in-out property <string> coupon-max-discount: "";
    in-out property <string> coupon-per-user-limit: "";
    in-out property <string> coupon-usage-limit: "";
    in-out property <string> coupon-valid-from: "";
    in-out property <string> coupon-valid-until: "";
    in-out property <string> coupon-error-title: "";
    in-out property <string> coupon-error-code: "";
    in-out property <string> coupon-error-discount: "";
    in-out property <string> coupon-error-min: "";
    in-out property <string> coupon-error-per-user: "";
    in-out property <string> coupon-error-usage: "";
    in-out property <string> coupon-error-validity: "";
    callback refresh-coupons();
    callback add-coupon();
    callback update-coupon();
    callback delete-coupon(string);
    callback toggle-coupon-active(string);
    callback format-coupon-date(string) -> string;

    // Lista de grupos exibida como chips no form do produto. A diferença
    // é o flag `selected` por linha (= produto em edição usa esse grupo).
    in-out property <[AddonGroupData]> product-addon-groups: [];
    callback toggle-product-addon-group(string);

    // ── Variações (Fase 5B) ─────────────────────────────────
    // Lista mutável de variações do produto em edição. Rust gere
    // push/remove (VecModel) via callbacks; campos de texto são
    // editados diretamente via bindings inline na Slint.
    in-out property <[VariationData]> product-variations: [];
    callback add-variation();
    callback remove-variation(int);
    callback add-variation-option(int);
    callback remove-variation-option(int, int);
    /// Recarrega `product-variations` a partir do JSON persistido no
    /// produto. String vazia limpa a lista.
    callback load-product-variations(string);

    // ── Configurações / Horário de Funcionamento ────
    in-out property <[BusinessHoursData]> business-hours: [];
    in-out property <int> bh-editing-day: -1;
    in-out property <string> bh-editing-day-name: "";
    in-out property <string> bh-open-time: "";
    in-out property <string> bh-close-time: "";
    in-out property <bool> bh-is-open: false;
    in-out property <string> store-override: "none";
    in-out property <string> store-name: "";
    in-out property <string> store-address: "";
    in-out property <string> store-phone: "";
    // ── Contato adicional ─────────────────────────────────
    in-out property <string> store-whatsapp: "";
    in-out property <string> store-email: "";
    in-out property <string> store-instagram: "";
    // ── Endereço & documento ──────────────────────────────
    in-out property <string> store-document: "";
    in-out property <string> store-neighborhood: "";
    in-out property <string> store-zip-code: "";
    in-out property <string> store-city: "";
    in-out property <string> store-uf: "";
    // ── Imagens ───────────────────────────────────────────
    in-out property <string> store-logo-data;
    in     property <image>  store-logo-image;
    in-out property <bool>   store-logo-loading: false;
    in-out property <string> store-cover-data;
    in     property <image>  store-cover-image;
    in-out property <bool>   store-cover-loading: false;
    /// `Company.synced` exposto para o cabeçalho mostrar badge
    /// "editado" (pendente) / "sincronizado" nos 3 cards.
    in-out property <bool>   store-synced: true;
    /// Quantidade de produtos exibidos por página na grade.
    /// Configurada em SettingsPage e persistida em Company.
    in-out property <int>    products-per-page: 20;
    in-out property <int>    orders-per-page: 20;

    // ── Sidebar (status de sync + identidade do usuário) ───
    // Regras aplicadas (AI_RULES.md §7, §11):
    // Estado do SyncWorker exposto à UI; preenchido pelo Rust.
    // `user-role` é placeholder até roles serem implementados no User.
    in-out property <bool>   sync-online: true;
    in-out property <string> sync-status-label: "Sincronizado";
    in-out property <string> sync-last-label: "Agora";
    in-out property <int>    sync-pending-count: 0;
    in-out property <string> user-role: "Admin";
    in-out property <string> user-name: "Minha conta";
    // Permissões de navegação (RBAC §11). Default libera tudo até o login
    // calcular as permissões reais do operador. `collaborators-perms` é
    // o catálogo + estado para a tela de Colaboradores (Slice 4b/4c).
    in-out property <NavPerms> nav-perms: { is-admin: true };

    // ── Colaboradores (RBAC) ──
    in-out property <[CollabRoleRow]> collab-roles;
    in-out property <[CollabEmployeeRow]> collab-employees;
    in-out property <[CollabPermRow]> collab-perm-rows;
    in-out property <[string]> collab-role-combo;
    in-out property <string> collab-editing-role-id;
    in-out property <string> collab-role-name;
    in-out property <string> collab-emp-id;
    in-out property <string> collab-emp-name;
    in-out property <string> collab-emp-email;
    in-out property <string> collab-emp-password;
    in-out property <int> collab-emp-role-index;
    in-out property <int> collab-perm-active;
    in-out property <int> collab-perm-total;
    callback refresh-collaborators();
    callback collab-mark-all-perms();
    callback collab-new-role();
    callback collab-edit-role(string);
    callback collab-save-role(string, string);
    callback collab-toggle-perm(string, bool, bool);
    callback collab-new-employee();
    callback collab-edit-employee(string);
    callback collab-save-employee(string, string, string, string, int);

    callback refresh-business-hours();
    callback save-business-hours();
    callback set-store-override(string);
    callback save-store-info();
    callback pick-store-logo();
    callback pick-store-cover();
    callback format-store-phone(string) -> string;
    /// Máscara para CPF/CNPJ — reaproveita `format_document` do desktop.
    callback format-store-document(string) -> string;
    /// Máscara para CEP: `00000-000`.
    callback format-store-zip(string) -> string;
    callback apply-time-mask(string) -> string;

    // ── Pedidos ─────────────────────────────────────
    in-out property <[OrderData]> orders: [];
    in-out property <string> order-filter-status: "all";
    in-out property <string> order-detail-id: "";
    in-out property <OrderData> detail-order: { id: "", number: "", order-date: "", order-time: "", customer-name: "", customer-phone: "", delivery-label: "", delivery-street: "", delivery-number: "", delivery-neighborhood: "", delivery-apartment: "", total: "", coupon-summary: "", status: "", status-label: "", delivery-type: "", items-count: 0, items-summary: "", notes: "", subtotal-display: "", discount-display: "", delivery-fee-display: "", coupon-code-display: "", elapsed-display: "", created-at-iso: "" };
    in-out property <[OrderItemData]> detail-order-items: [];
    // Kanban (filtro "all"): estatísticas por coluna de status,
    // agregadas no Rust. Busca textual de pedidos.
    in-out property <[KanbanCol]> kanban-cols: [];
    in-out property <string> order-search-query: "";
    // Filtro por período (calendário). Datas em "AAAA-MM-DD".
    in-out property <string> order-date-start: "";
    in-out property <string> order-date-end: "";
    in-out property <string> order-date-label: "Período";
    in-out property <bool>   cal-open: false;
    in-out property <string> cal-title: "";
    in-out property <[CalDay]> cal-days: [];
    // Mês visível no calendário (controlado pelo Rust).
    in-out property <int> cal-year: 0;
    in-out property <int> cal-month: 0;
    callback cal-toggle();
    callback cal-prev();
    callback cal-next();
    callback cal-pick(string);
    callback cal-clear();
    callback refresh-orders();
    callback open-order(string);
    callback advance-order-status(string);
    callback cancel-order(string, string);
    /// Recalcula `detail-order.elapsed-display` a partir de
    /// `detail-order.created-at-iso`. Disparado a cada 60s pelo Timer
    /// do painel direito enquanto o pedido está ativo.
    callback refresh-order-elapsed();
    /// "Editar pedido" — popula `edit-order-*` (Rust) e abre o modal.
    callback edit-order(string);
    /// +/− qty no item `idx` da lista de edição (Rust mexe no model).
    callback edit-order-inc(int);
    callback edit-order-dec(int);
    /// Remove o item `idx` da lista de edição (linha desaparece).
    callback edit-order-delete(int);
    /// Reabre o configurador com as seleções já marcadas para o
    /// item `idx`. Ao confirmar, SUBSTITUI `items[idx]`; ao cancelar,
    /// o item original é preservado.
    callback edit-order-edit-item(int);
    /// Adiciona um produto novo à lista (push de EditOrderItem novo
    /// com `item_id == ""` — sentinel "novo"; o save gera UUID).
    callback edit-order-add-product(string);
    /// Refiltra `edit-order-picker-products` no Rust (Slint não tem
    /// `string.contains`). Disparado pelo `edited` da busca do picker.
    callback edit-order-filter-picker(string);
    /// Configurador de produto:
    /// - `start-product-config(pid)`: carrega adicionais + variações
    ///   do produto. Se nenhum dos dois existir, adiciona direto.
    /// - `config-toggle-variation(v, o)` / `config-toggle-addon(g, a)`:
    ///   alterna seleção respeitando single/multi/max_value.
    /// - `config-inc-qty` / `config-dec-qty`.
    /// - `config-confirm-add`: empurra o `EditOrderItem` configurado.
    /// - `config-cancel`: limpa o estado.
    callback start-product-config(string);
    callback config-toggle-variation(int, int);
    callback config-toggle-addon(int, int);
    callback config-inc-qty();
    callback config-dec-qty();
    callback config-confirm-add();
    callback config-cancel();
    /// "Salvar alterações" no modal — Rust lê itens/notes/delivery
    /// e chama `OrderService::update_basics`.
    callback save-edit-order();
    /// "Imprimir agora" — gera o HTML da comanda (completa ou cozinha,
    /// conforme `receipt-modal-mode`) e abre no navegador padrão com
    /// `window.print()` autoinjetado para o diálogo de impressão
    /// aparecer sem interação extra. Disparado pelo `ReceiptModal`.
    /// Argumentos: (order-id, mode).
    callback print-receipt-now(string, string);

    in-out property <bool> show-cancel-modal: false;
    /// Modal de preview/impressão de comanda. Vazio = oculto.
    /// "complete" = comanda do cliente (com valores).
    /// "kitchen"  = comanda da cozinha (compacta, sem valores).
    in-out property <string> receipt-modal-mode: "";
    /// Modal de edição do pedido. `false` oculto.
    in-out property <bool> show-edit-order-modal: false;
    /// Lista mutável de itens em edição (qty editável; remoção por
    /// −/+ até 0). Rust gerencia push/remove via callbacks.
    in-out property <[EditOrderItem]> edit-order-items: [];
    in-out property <string> edit-order-notes: "";
    in-out property <string> edit-order-delivery-type: "delivery";
    in-out property <string> edit-order-error: "";
    /// Lista de produtos exibida no picker do EditOrderModal —
    /// filtrada em Rust via callback `edit-order-filter-picker`.
    in-out property <[ProductData]> edit-order-picker-products: [];
    /// Lista mestra (sem filtro) usada pelo Rust para refiltrar quando
    /// o operador digita na busca. Carregada do `product_service` na
    /// abertura do modal — não depende do `products` lazy da UI.
    in-out property <[ProductData]> edit-order-picker-master: [];
    /// Estado do configurador de produto (adicionais/variações).
    /// `config-product-id` vazio = sem configuração em andamento;
    /// caso contrário, a seção de configuração aparece no EditOrderModal.
    in-out property <string> config-product-id: "";
    in-out property <string> config-product-name: "";
    in-out property <float>  config-base-price: 0;
    in-out property <int>    config-qty: 1;
    in-out property <[ConfigVariation]> config-variations: [];
    in-out property <[ConfigAddonGroup]> config-addon-groups: [];
    /// Total final formatado (`"R$ x,xx"`), recomputado em Rust a
    /// cada toggle / mudança de qty.
    in-out property <string> config-final-display: "R$ 0,00";
    in-out property <string> config-error: "";
    /// Índice do item em edição via "Editar item" (-1 = adicionando
    /// produto novo). O Rust seta no `edit-order-edit-item(idx)` e
    /// volta a -1 no confirm/cancel do configurador.
    in-out property <int>    config-edit-idx: -1;
    in-out property <string> cancel-target-id: "";
    in-out property <string> cancel-target-label: "";
    in-out property <string> cancel-reason: "";
    in-out property <string> cancel-error: "";

    in-out property <bool> show-logout-confirm: false;

    // ── Impressoras (Configurações) ─────────────────────────────
    // Lista refrescada por Rust após cada save/delete/set-default.
    // Estado do modal de cadastro: `show-printer-modal` aciona o
    // overlay; campos pré-preenchidos em modo edição via
    // `request-edit-printer`.
    // ── PDV (Ponto de Venda) ──────────────────────────────────
    // Estado é totalmente compartilhado com Rust (`ui::pdv`):
    // produtos visíveis (filtrados por categoria + busca), carrinho,
    // chips de categoria, totais. Slint só renderiza; Rust gerencia
    // o estado em memória (AI_RULES §1).
    in-out property <[PdvProductRow]>  pdv-products: [];
    in-out property <[PdvCartRow]>     pdv-cart: [];
    /// Linha 1 de chips. A decisão de quebra (tudo na row1 vs
    /// dividir entre row1 e row2) é feita em Rust ao receber a
    /// largura disponível do painel via `pdv-cats-width-changed`.
    /// Quando cabe tudo, row2 fica vazia.
    in-out property <[PdvCategoryChip]> pdv-categories: [];
    /// Linha 2. Vazia quando cabe tudo na row1.
    in-out property <[PdvCategoryChip]> pdv-categories-row2: [];
    in-out property <string>           pdv-search-text: "";
    in-out property <string>           pdv-subtotal-display: "R$ 0,00";
    in-out property <string>           pdv-discount-display: "R$ 0,00";
    in-out property <string>           pdv-additional-display: "R$ 0,00";
    in-out property <string>           pdv-total-display: "R$ 0,00";
    in-out property <string>           pdv-discount-input: "";
    in-out property <string>           pdv-additional-input: "";
    in-out property <int>              pdv-cart-count: 0;
    // Estado integrado ao carrinho (não há mais modal de finalização)
    in-out property <string>           pdv-sale-type: "counter";
    /// Forma de pagamento PRINCIPAL: `"cash" | "card" | "pix"`.
    /// Quando "card", o tipo (crédito/débito) é definido em
    /// `pdv-payment-card-type`. Quando "cash" com valor pago abaixo
    /// do total, `pdv-secondary-payment` registra a forma do restante.
    in-out property <string>           pdv-payment-method: "";
    in-out property <string>           pdv-payment-card-type: "credit";
    in-out property <string>           pdv-secondary-payment: "";
    in-out property <string>           pdv-amount-paid-input: "";
    in-out property <string>           pdv-change-display: "";
    in-out property <string>           pdv-remaining-display: "";
    in-out property <string>           pdv-customer-id: "";
    in-out property <string>           pdv-customer-name: "";
    in-out property <string>           pdv-delivery-street: "";
    in-out property <string>           pdv-delivery-number: "";
    in-out property <string>           pdv-delivery-neighborhood: "";
    in-out property <string>           pdv-finalize-error: "";
    // Modal pós-venda
    in-out property <bool>             pdv-show-sold: false;
    in-out property <string>           pdv-sold-order-id: "";
    in-out property <string>           pdv-sold-order-number: "";
    in-out property <string>           pdv-sold-total: "";
    // Modal de seleção de cliente
    in-out property <bool>             pdv-show-customer-picker: false;
    in-out property <[PdvCustomerRow]> pdv-customer-rows: [];
    in-out property <string>           pdv-customer-search: "";
    /// Endereços cadastrados do cliente atualmente selecionado.
    /// Populado pelo Rust após `pdv-pick-customer`. Vazio = sem
    /// endereços OU cliente não selecionado.
    in-out property <[PdvAddressRow]>  pdv-customer-addresses: [];

    // ── Carteira do cliente vinculado (Fase 3) ────────────────
    /// True quando o cliente tem carteira aberta — habilita o chip
    /// "Carteira" como forma de pagamento.
    in-out property <bool>   pdv-wallet-has-account: false;
    /// UUID da account, ou "" se vazio.
    in-out property <string> pdv-wallet-account-id: "";
    /// "R$ 87,50" (saldo atual, com sinal).
    in-out property <string> pdv-wallet-balance-display: "R$ 0,00";
    /// "pos" | "neg" | "neutral" — UI escolhe cor.
    in-out property <string> pdv-wallet-balance-tone: "neutral";
    /// "R$ 100,00" (limite de fiado configurado).
    in-out property <string> pdv-wallet-credit-limit-display: "R$ 0,00";
    /// "R$ 187,50" — saldo + limite (quanto o cliente ainda pode
    /// gastar nesta venda sem ser rejeitado).
    in-out property <string> pdv-wallet-available-display: "R$ 0,00";
    /// Disponível como número (cru) — UI usa pra comparar com total
    /// e mostrar aviso de fiado.
    in-out property <float>  pdv-wallet-available-amount: 0;
    /// Total cru do carrinho (para comparações em ponto flutuante).
    /// `pdv-total-display` continua sendo a string pt-BR formatada.
    in-out property <float>  pdv-total-amount: 0;

    // Callbacks
    callback pdv-refresh();
    callback pdv-search-changed(string);
    callback pdv-submit-search();
    callback pdv-toggle-category(string);
    callback pdv-clear-categories();
    /// Disparado pelo Slint quando a largura do painel de categorias
    /// muda. Rust decide se quebra os chips em duas linhas (e como
    /// distribuí-los) com base na largura recebida.
    callback pdv-cats-width-changed(length);
    callback pdv-add-product(string);
    callback pdv-inc-line(string);
    callback pdv-dec-line(string);
    callback pdv-remove-line(string);
    // Modal do carrinho (aberto pelo pill "N itens" ao lado da busca).
    in-out property <bool> pdv-show-cart-modal: false;
    callback pdv-clear-cart();
    callback pdv-finalize();
    callback pdv-config-confirm();
    callback pdv-discount-changed(string);
    callback pdv-additional-changed(string);
    callback pdv-amount-paid-changed(string);
    callback pdv-use-address(string);
    /// Recálculo solicitado pelo Slint quando uma propriedade
    /// reativa muda (ex.: payment-method). Faz o Rust reescrever
    /// `change-display` / `remaining-display`.
    callback pdv-recalc();

    changed pdv-payment-method => { root.pdv-recalc(); }
    // Customer picker
    callback pdv-open-customer-picker();
    callback pdv-customer-search-changed(string);
    callback pdv-pick-customer(string);
    callback pdv-clear-customer();

    /// Contexto do ProductConfiguratorModal — quem disparou o
    /// configurador. `"edit_order"` (default) = pelo EditOrderModal;
    /// `"pdv"` = pelo PDV. O wireup do botão "Adicionar" no PCM
    /// despacha o callback certo conforme essa propriedade.
    in-out property <string>           config-context: "edit_order";

    // ── Gestão de Caixa ─────────────────────────────────────────
    in-out property <CashSummaryData>  cash-summary;
    // Property bool dedicada para o `if` do PdvNoCashModal. Slint
    // pode disparar "Recursion detected" quando uma condição lê um
    // campo de struct (cash-summary.open) e o struct inteiro é
    // re-escrito a cada cash-refresh. Property bool isolada quebra
    // a dependência da struct.
    in-out property <bool>             cash-blocked: true;
    in-out property <[CashSessionRow]> cash-sessions: [];
    in-out property <[CashMovementRow]> cash-movements: [];
    in-out property <[CashMethodTotalRow]> cash-method-totals: [];
    // Modais
    in-out property <bool>             cash-show-open: false;
    in-out property <bool>             cash-show-sangria: false;
    in-out property <bool>             cash-show-suprimento: false;
    in-out property <bool>             cash-show-close: false;
    // Inputs do modal abrir
    in-out property <string>           cash-open-operator: "";
    in-out property <string>           cash-open-suggested: "";
    in-out property <string>           cash-open-amount: "";
    in-out property <string>           cash-open-notes: "";
    // Inputs do modal sangria
    in-out property <string>           cash-sangria-amount: "";
    in-out property <string>           cash-sangria-reason: "Depósito Bancário";
    in-out property <string>           cash-sangria-detail: "";
    // Inputs do modal suprimento
    in-out property <string>           cash-suprimento-amount: "";
    in-out property <string>           cash-suprimento-origin: "Cofre Troco";
    in-out property <string>           cash-suprimento-detail: "";
