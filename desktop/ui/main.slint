                wallet-open-limit => { root.wallet-open-limit(); }
                wallet-open-wallet => { root.wallet-confirm-open(); }
            }

            // PDV vive FORA deste ScrollView (irmão direto do
            // HorizontalLayout com Sidebar). Motivo arquitetural: o
            // ScrollView mede o conteúdo pela altura natural — não
            // estica filhos verticalmente. Resultado: o cart Rectangle
            // dentro do PdvPage ficava no tamanho dos próprios filhos
            // e o footer "Subtotal..Limpar" não colava na borda
            // inferior. Renderizado lá fora, PdvPage recebe a altura
            // total da janela direto do HorizontalLayout pai.

            // Caixa
            if root.active-tab == "cash": CashPage {
                summary: root.cash-summary;
                sessions: root.cash-sessions;
                movements: root.cash-movements;
                method-totals: root.cash-method-totals;
