    in-out property <string> company-form-cover-data: "";
    in-out property <image> company-form-logo-image;
    in-out property <image> company-form-cover-image;
    in-out property <bool> company-form-logo-loading: false;
    in-out property <bool> company-form-cover-loading: false;
    // Lê as propriedades acima no Rust (form grande → sem args).
