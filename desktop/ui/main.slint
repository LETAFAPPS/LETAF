    // ── Painel do administrador (plataforma / super admin) ────────
    // Dados cross-tenant vindos online das rotas /admin/*. Preenchidos
    // pelo Rust (ui/admin). O acesso é gateado no backend (§11).
    in-out property <int> admin-companies-count: 0;
    in-out property <int> admin-active-subs: 0;
    in-out property <int> admin-overdue-subs: 0;
    in-out property <int> admin-cancelled-subs: 0;
    in-out property <int> admin-admins-count: 0;
    in-out property <int> admin-new-companies-month: 0;
    in-out property <string> admin-mrr: "R$ 0,00";
    in-out property <[AdminCompanyRow]> admin-companies: [];
    in-out property <[AdminSubscriptionRow]> admin-subscriptions: [];
    in-out property <[AdminAuditRow]> admin-audit-entries: [];
