    in-out property <bool>   card-modal-open: false;
    in-out property <bool>   card-modal-loading: false;
    in-out property <string> card-form-number;
    in-out property <string> card-form-holder;
    in-out property <string> card-form-expiry;
    in-out property <string> card-form-cvv;
    in-out property <string> card-form-cpf;
    in-out property <string> card-form-email;
    in-out property <string> card-form-phone;
    in-out property <string> card-form-birth;
    in-out property <string> card-form-error;
    // Erros por campo (validação no Rust).
