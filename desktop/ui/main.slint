    in-out property <string> card-error-holder;
    in-out property <string> card-error-expiry;
    in-out property <string> card-error-cvv;
    in-out property <string> card-error-cpf;
    in-out property <string> card-error-birth;
    in-out property <string> card-error-email;
    in-out property <string> card-error-phone;

