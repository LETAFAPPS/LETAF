    callback finance-set-installments(int);
    callback finance-set-category(string);

    in-out property <[PrinterData]> printers: [];
    in-out property <bool>          show-printer-modal: false;
    in-out property <string>        printer-editing-id: "";
    in-out property <string>        printer-form-name: "";
    in-out property <string>        printer-form-kind: "order";
    in-out property <string>        printer-form-system-name: "";
    in-out property <bool>          printer-form-is-default: false;
    in-out property <int>           printer-form-paper-width: 80;
    in-out property <string>        printer-form-error: "";
    /// Categorias da empresa, populadas a cada abertura do modal.
    /// Cada linha tem `selected: bool` (alternada pelo checkbox da
    /// UI). Rust popula com `selected = true` para os IDs que estão
    /// em `Printer.category_ids` no modo edição.
    in-out property <[PrinterCategoryRow]> printer-form-categories: [];
    /// Lista de impressoras detectadas no SO (lpstat / Get-Printer).
    /// Atualizada pelo Rust quando o modal abre — operador escolhe num
    /// dropdown em vez de digitar o nome.
    in-out property <[string]>      printer-available-list: [];

    callback refresh-printers();
    callback refresh-available-printers();
    /// Popula `printer-form-categories` com as categorias da empresa,
    /// marcando como `selected = true` os IDs em `selected-ids`.
    /// Chamado no `request-new-printer` (lista vazia) e
    /// `request-edit-printer` (com os IDs da impressora).
    callback load-printer-categories([string]);
    callback printer-save();
    callback printer-test-print();
    callback printer-delete(string);
    callback printer-set-default(string);

    // ── Alarme de novos pedidos ──────────────────────────────────
    // `alarm-active`: estado lógico do alarme; enquanto true, o som
    //   continua e o modal volta sozinho se o operador apenas
    //   fechar. Setado pelo SyncWorker via observer task em Rust.
    // `alarm-visible`: controla a renderização do modal. Pode ser
    //   false enquanto `alarm-active` for true (intervalo de 5s
    //   entre reabertura — regra do projeto).
    // `alarm-pending-count`: quantidade total de Pendings no banco
    //   neste instante; usado pelo corpo do modal.
    in-out property <bool> alarm-active: false;
    in-out property <bool> alarm-visible: false;
    in-out property <int>  alarm-pending-count: 0;
    callback alarm-acknowledge();
    callback alarm-dismiss();
    // Reabre o modal 5 s após o operador fechar (regra: "enquanto não
    // clicar no botão, não vai parar de avisar"). `running` só é true
    // quando o alarme está ATIVO mas o modal está ESCONDIDO — quando
    // visível, o Timer pausa; quando o operador aciona, fica false.
    alarm-reopen-timer := Timer {
        interval: 5s;
        running: root.alarm-active && !root.alarm-visible;
        triggered => { root.alarm-visible = true; }
    }

    in-out property <bool> toast-visible: false;
    in-out property <string> toast-message: "";
    in-out property <string> toast-type: "success";

    toast-timer := Timer {
        interval: 3000ms;
        running: root.toast-visible;
        triggered => { root.toast-visible = false; }
    }

    // ════════════════════════════════════════════════
    //  TELA DE LOGIN
    // ════════════════════════════════════════════════
    if !root.logged-in: LoginPage {
        email <=> root.login-email;
        password <=> root.login-password;
        status <=> root.login-status;
        remember-me <=> root.login-remember-me;
        subdomain: root.login-subdomain;
        app-version: root.app-version;
        server-online: root.sync-online;
        server-last: root.sync-last-label;
        do-login => { root.do-login(); }
        login-with-pin => { root.login-with-pin(); }
        recovery-step <=> root.recovery-step;
        recovery-email <=> root.recovery-email;
        recovery-code <=> root.recovery-code;
        recovery-new-password <=> root.recovery-new-password;
        recovery-status <=> root.recovery-status;
        recovery-busy: root.recovery-busy;
        forgot-request => { root.recovery-forgot(); }
        verify-submit => { root.recovery-verify(); }
        reset-submit => { root.recovery-reset(); }
    }

    // ════════════════════════════════════════════════
    //  AREA PRINCIPAL (pos-login)
    // ════════════════════════════════════════════════
    if root.logged-in: HorizontalLayout {

        Sidebar {
            active-tab <=> root.active-tab;
            expanded <=> root.sidebar-expanded;
            nav: root.nav-perms;
            store-name: root.store-name;
            user-role: root.user-role;
            user-name: root.user-name;
            store-logo-image: root.store-logo-image;
            user-avatar: root.profile-avatar;
            orders-count: root.orders-active-count;
            subscription-pending-count: root.subscription-pending-count;
            finance-overdue-count: root.finance-overdue-count;
            stock-out-count: root.stock-out-count;
            sync-online: root.sync-online;
            sync-status-label: root.sync-status-label;
            sync-last-label: root.sync-last-label;
            sync-pending-count: root.sync-pending-count;
            dark-mode-changed(d) => { root.dark-mode-changed(d); }
            navigate(tab) => {
                root.active-tab = tab;
                root.show-modal = false;
                if tab == "products" {
                    root.refresh-products();
                    root.refresh-categories();
                    root.refresh-subcategories();
                } else if tab == "categories" {
                    root.subcategory-filter-category-id = "all";
                    root.refresh-categories();
                    root.refresh-subcategories();
                } else if tab == "addons" {
                    root.selected-addon-group-id = "";
                    root.selected-addon-group-name = "";
                    root.current-group-addons = [];
                    root.refresh-addon-groups();
                } else if tab == "customers" {
                    root.refresh-customers();
                } else if tab == "collaborators" {
                    root.refresh-collaborators();
                } else if tab == "orders" {
                    root.order-detail-id = "";
                    root.refresh-orders();
                } else if tab == "settings" {
                    root.refresh-business-hours();
                } else if tab == "banners" {
                    // Garante que a lista de produtos esteja carregada
                    // para resolver `item-name` no banner de produto.
                    root.refresh-products();
                    root.refresh-banners();
                } else if tab == "coupons" {
                    root.refresh-coupons();
                } else if tab == "cash" {
                    root.cash-refresh();
                } else if tab == "inventory" {
                    root.inventory-refresh();
                } else if tab == "dashboard" {
                    root.dashboard-refresh();
                } else if tab == "reports" {
                    root.report-refresh();
                } else if tab == "subscription" {
                    // Refresca ao ABRIR: o listener de sync só recomputa com a
                    // aba visível (evitava requisição HTTP a cada 30s com a
                    // tela fechada).
                    root.subscription-refresh();
                } else if tab == "admin-overview" || tab == "admin-companies"
                       || tab == "admin-subscriptions" || tab == "admin-admins" || tab == "admin-audit"
                       || tab == "admin-plans" {
                    root.admin-refresh();
                }
                // Importante: NÃO disparar cash-refresh ao entrar no
                // PDV. O estado já é pré-carregado no boot e após
                // login; disparar aqui causava re-entrância de
                // renderização (modal aparece no mesmo frame em que
                // a aba muda + callback async modifica cash-summary),
                // o que travava a UI ao entrar na aba PDV.
            }
            request-logout => { root.show-logout-confirm = true; }
            open-profile => { root.open-profile(); }
            toggle-expanded => { root.sidebar-expanded = !root.sidebar-expanded; }
        }

        // PDV mora FORA do ScrollView raiz pra receber a altura
        // total do HorizontalLayout pai (Sidebar + conteúdo). Sem
        // isso, o cart Rectangle não estica e o footer fica solto
        // no meio do card. PDV não precisa de scroll de página
        // (cabe no viewport; tem ScrollView interno só pro carrinho).
        //
        // Envolvido num Rectangle wrapper com `vertical-stretch: 1`
        // pra GARANTIR altura definida. PdvPage interno usa
        // `width/height: parent.*` pra preencher — referência sem
        // loop porque o Rectangle não depende do PdvPage pra seu
        // tamanho.
        if root.active-tab == "pdv" && root.cash-blocked: Rectangle {
            horizontal-stretch: 1;
            height: root.height;
            PdvBlockedView {
                x: 0; y: 0;
                width: parent.width;
                height: parent.height;
                go-to-cash => { root.active-tab = "cash"; }
            }
        }

        if root.active-tab == "pdv" && !root.cash-blocked: Rectangle {
            horizontal-stretch: 1;
            // Em vez de vertical-stretch (que o Slint às vezes
            // ignora aqui), seto height literal = altura da Window
            // (root). Sem ambiguidade.
            height: root.height;
            pdv-page := PdvPage {
                x: 0; y: 0;
                width: parent.width;
                height: parent.height;
                window-height: root.live-window-height;
                customer-picker-open: root.pdv-show-customer-picker;
                sold-modal-open: root.pdv-show-sold;
                products: root.pdv-products;
            cart: root.pdv-cart;
            categories: root.pdv-categories;
            categories-row2: root.pdv-categories-row2;
            cats-width-changed(w) => { root.pdv-cats-width-changed(w); }
            search-text <=> root.pdv-search-text;
            subtotal-display: root.pdv-subtotal-display;
            discount-display: root.pdv-discount-display;
            additional-display: root.pdv-additional-display;
            total-display: root.pdv-total-display;
            discount-input <=> root.pdv-discount-input;
            additional-input <=> root.pdv-additional-input;
            cart-count: root.pdv-cart-count;
            sale-type <=> root.pdv-sale-type;
            payment-method <=> root.pdv-payment-method;
            payment-card-type <=> root.pdv-payment-card-type;
            secondary-payment <=> root.pdv-secondary-payment;
            amount-paid-input <=> root.pdv-amount-paid-input;
            change-display: root.pdv-change-display;
            remaining-display: root.pdv-remaining-display;
            customer-name: root.pdv-customer-name;
            wallet-has-account: root.pdv-wallet-has-account;
            wallet-balance-display: root.pdv-wallet-balance-display;
            wallet-balance-tone: root.pdv-wallet-balance-tone;
            wallet-credit-limit-display: root.pdv-wallet-credit-limit-display;
            wallet-available-display: root.pdv-wallet-available-display;
            wallet-available-amount: root.pdv-wallet-available-amount;
            total-amount: root.pdv-total-amount;
            delivery-street <=> root.pdv-delivery-street;
            delivery-number <=> root.pdv-delivery-number;
            delivery-neighborhood <=> root.pdv-delivery-neighborhood;
            finalize-error: root.pdv-finalize-error;
            search-changed(q) => { root.pdv-search-changed(q); }
            submit-search => { root.pdv-submit-search(); }
            toggle-category(id) => { root.pdv-toggle-category(id); }
            clear-categories => { root.pdv-clear-categories(); }
            add-product(id) => { root.pdv-add-product(id); }
            inc-line(id) => { root.pdv-inc-line(id); }
            dec-line(id) => { root.pdv-dec-line(id); }
            remove-line(id) => { root.pdv-remove-line(id); }
            open-cart => { root.pdv-show-cart-modal = true; }
            clear-cart => { root.pdv-clear-cart(); }
            finalize => { root.pdv-finalize(); }
            open-customer-picker => { root.pdv-open-customer-picker(); }
            clear-customer => { root.pdv-clear-customer(); }
            discount-changed(v) => { root.pdv-discount-changed(v); }
            additional-changed(v) => { root.pdv-additional-changed(v); }
            amount-paid-changed(v) => { root.pdv-amount-paid-changed(v); }
            customer-addresses: root.pdv-customer-addresses;
            use-address(id) => { root.pdv-use-address(id); }
            }
        }

        // ScrollView raiz da área de conteúdo: garante que, em janelas
        // estreitas (largura abaixo do preferred-width das páginas), o
        // conteúdo seja rolável vertical/horizontalmente em vez de ser
        // cortado. min-width: 0 no layout interno permite encolhimento.
        // Não renderiza no PDV — ele vive fora.
        if root.active-tab != "pdv": ScrollView { vertical-scrollbar-policy: ScrollBarPolicy.always-off; horizontal-scrollbar-policy: ScrollBarPolicy.always-off;
            horizontal-stretch: 1;
            VerticalLayout {
                min-width: 0;
                // Reports = 0px aqui: a página gerencia o próprio padding
                // internamente (header/abas com 24px; o ScrollView ocupa a
                // largura toda e insere os 24px por dentro, dando folga p/ a
                // sombra dos cards roláveis). Master-detail = 16px (mostra a
                // borda lateral do painel secundário). Demais = 24px.
                padding: root.active-tab == "reports" ? 0px
                    : ((root.active-tab == "categories"
                        || root.active-tab == "collaborators") ? 16px
                    // Produtos e Clientes usam 24px — mesma distância das
                    // paredes que a tela Caixa (e as demais telas padrão).
                    : 24px);
                spacing: 16px;

                // ── Painel do administrador (super admin) ──
                if root.active-tab == "admin-overview": AdminOverviewPage {
                    companies: root.admin-companies-count;
                    active-subs: root.admin-active-subs;
                    overdue-subs: root.admin-overdue-subs;
                    cancelled-subs: root.admin-cancelled-subs;
                    admins: root.admin-admins-count;
                    new-companies-month: root.admin-new-companies-month;
                    mrr: root.admin-mrr;
                }
                if root.active-tab == "admin-companies": AdminCompaniesPage {
                    companies: root.admin-companies;
                    form-name <=> root.company-form-name;
                    form-subdomain <=> root.company-form-subdomain;
                    form-admin-name <=> root.company-form-admin-name;
                    form-admin-email <=> root.company-form-admin-email;
                    form-admin-password <=> root.company-form-admin-password;
                    form-phone <=> root.company-form-phone;
                    form-whatsapp <=> root.company-form-whatsapp;
                    form-email <=> root.company-form-email;
                    form-document <=> root.company-form-document;
                    form-discount <=> root.company-form-discount;
                    form-address <=> root.company-form-address;
                    form-neighborhood <=> root.company-form-neighborhood;
                    form-zip <=> root.company-form-zip;
                    form-city <=> root.company-form-city;
                    form-uf <=> root.company-form-uf;
                    logo-image: root.company-form-logo-image;
                    cover-image: root.company-form-cover-image;
                    logo-loading: root.company-form-logo-loading;
                    cover-loading: root.company-form-cover-loading;
                    has-logo: root.company-form-logo-data != "";
                    has-cover: root.company-form-cover-data != "";
                    save-company => { root.admin-save-company(); }
                    pick-logo => { root.admin-pick-company-logo(); }
                    pick-cover => { root.admin-pick-company-cover(); }
                    delete-company(id, name) => {
                        root.admin-del-company-id = id;
                        root.admin-del-company-name = name;
                        root.admin-del-company-open = true;
                    }
                    set-company-active(id, active) => { root.admin-set-company-active(id, active); }
                    search <=> root.admin-company-search;
                    filter <=> root.admin-company-filter;
                    filters-changed => { root.admin-filter-companies(); }
                }
                if root.active-tab == "admin-audit": AdminAuditPage {
                    entries: root.admin-audit-entries;
                }
                if root.active-tab == "admin-subscriptions": AdminSubscriptionsPage {
                    subscriptions: root.admin-subscriptions;
                    search <=> root.admin-sub-search;
                    filter <=> root.admin-sub-filter;
                    filters-changed => { root.admin-filter-subscriptions(); }
                    manage(s) => {
                        root.admin-sub-edit-company-id = s.company-id;
                        root.admin-sub-edit-company-name = s.company-name;
                        root.admin-sub-edit-plan = s.plan;
                        root.admin-sub-edit-status = s.status;
                        root.admin-sub-edit-discount = s.discount;
                        root.admin-invoices = [];
                        root.admin-sub-edit-open = true;
                        root.admin-load-invoices(s.company-id);
                    }
                }
                if root.active-tab == "admin-admins": AdminAdminsPage {
                    users: root.admin-users;
                    form-id <=> root.admin-form-id;
                    form-name <=> root.admin-form-name;
                    form-email <=> root.admin-form-email;
                    form-password <=> root.admin-form-password;
                    new-user => { root.admin-new-user(); }
                    edit-user(id) => { root.admin-edit-user(id); }
                    save-user(id, n, e, p) => { root.admin-save-user(id, n, e, p); }
                    delete-user(id) => { root.admin-delete-user(id); }
                }
                if root.active-tab == "admin-plans": AdminPlansPage {
                    plans: root.admin-plans;
                    form-id <=> root.admin-plan-id;
                    form-name <=> root.admin-plan-name;
                    form-amount <=> root.admin-plan-amount;
                    form-period <=> root.admin-plan-period;
                    form-trial <=> root.admin-plan-trial;
                    form-description <=> root.admin-plan-description;
                    form-highlight <=> root.admin-plan-highlight;
                    form-active <=> root.admin-plan-active;
                    new-plan => { root.admin-plan-new(); }
                    edit-plan(id) => { root.admin-plan-edit(id); }
                    save-plan => { root.admin-plan-save(); }
                    delete-plan(id) => { root.admin-plan-delete(id); }
                }

                // Produtos — master-detail com editor inline (não há mais
                // aba `product-form` separada; o form vive no painel direito).
                if root.active-tab == "products": ProductsPage {
                    products: root.products;
                    products-active-count: root.products-active-count;
                    products-inactive-count: root.products-inactive-count;
                    products-per-page: root.products-per-page;
                    filter-cats: root.filter-cats;
                    filter-subs: root.filter-subs;
                    filter-status: root.filter-status;
                    filter-stock: root.filter-stock;
                    filter-active-count: root.filter-active-count;
                    selected-product-id: root.selected-product-id;
                    detail-product: root.detail-product;
                    // Pass-through do estado do form (in-out → o Rust escreve
                    // direto via setters; aqui só pontuamos a ligação).
                    editing-id <=> root.editing-id;
                    product-name <=> root.product-name;
                    product-description <=> root.product-description;
                    product-price <=> root.product-price;
                    product-cost-price <=> root.product-cost-price;
                    product-stock-quantity <=> root.product-stock-quantity;
                    product-min-stock <=> root.product-min-stock;
                    product-margin-display: root.product-margin-display;
                    product-unlimited-stock <=> root.product-unlimited-stock;
                    product-availability-enabled <=> root.product-availability-enabled;
                    product-availability <=> root.product-availability;
                    product-discount-kind <=> root.product-discount-kind;
                    product-discount-value <=> root.product-discount-value;
                    product-discount-min-qty <=> root.product-discount-min-qty;
                    product-discount-tiers <=> root.product-discount-tiers;
                    product-barcode <=> root.product-barcode;
                    product-unit <=> root.product-unit;
                    product-balance-mode <=> root.product-balance-mode;
                    product-image-data <=> root.product-image-data;
                    product-image-loading <=> root.product-image-loading;
                    product-category-id <=> root.product-category-id;
                    product-category-name <=> root.product-category-name;
                    product-category-open <=> root.product-category-open;
                    product-subcategory-id <=> root.product-subcategory-id;
                    product-subcategory-name <=> root.product-subcategory-name;
                    product-subcategory-open <=> root.product-subcategory-open;
                    product-error-name <=> root.product-error-name;
                    product-error-price <=> root.product-error-price;
                    product-error-stock <=> root.product-error-stock;
                    product-save-error <=> root.product-save-error;
                    categories: root.categories;
                    subcategories: root.subcategories;
                    addon-groups: root.product-addon-groups;
                    variations <=> root.product-variations;
                    // Filtros / sidebar
                    search-changed(q) => { root.filter-products(q); }
                    toggle-category-filter(id) => { root.toggle-category-filter(id); }
                    toggle-subcategory-filter(id) => { root.toggle-subcategory-filter(id); }
                    set-status-filter(v) => { root.set-status-filter(v); }
                    set-stock-filter(v)  => { root.set-stock-filter(v); }
                    reset-product-filters => { root.reset-product-filters(); }
                    // Toggles (Ativo / Web visível) usam os mesmos
                    // callbacks já existentes — o Rust faz o flip.
                    toggle-product-active(id) => { root.toggle-product-active(id); }
                    toggle-product-web-visible(id) => { root.toggle-product-web-visible(id); }
                    select-product(id) => { root.select-product(id); }
                    request-duplicate(p) => { root.duplicate-product(p.id); }
                    // "+ Novo produto" — limpa o form e marca a seleção
                    // com o sentinel "new" para o painel direito virar
                    // o cadastro (sem trocar de aba).
                    request-new => {
                        // Zera o snapshot do detalhe primeiro — sem isso,
                        // o card de imagem mostraria a foto do último
                        // produto selecionado até o operador escolher
                        // outra imagem.
                        root.clear-detail-product();
                        root.editing-id = "";
                        root.product-name = ""; root.product-description = "";
                        root.product-price = ""; root.product-stock-quantity = "";
                        root.product-cost-price = ""; root.product-min-stock = "";
                        root.product-margin-display = "—";
                        root.product-unlimited-stock = false;
                        root.product-availability-enabled = false;
                        root.product-discount-kind = "none";
                        root.product-discount-value = "";
                        root.product-discount-min-qty = "";
                        root.load-discount-tiers("");
                        root.load-product-addon-groups("");
                        root.load-product-variations("");
                        root.product-barcode = ""; root.product-unit = "un";
                        root.product-balance-mode = "price";
                        root.product-image-data = "";
                        root.product-cover-color = "";
                        root.product-category-id = ""; root.product-category-name = "";
                        root.product-subcategory-id = ""; root.product-subcategory-name = "";
                        root.product-category-open = false; root.product-subcategory-open = false;
                        root.product-error-name = ""; root.product-error-price = ""; root.product-error-stock = "";
                        root.selected-product-id = "new";
                    }
                    request-delete(id, name, type) => {
                        root.delete-target-id = id; root.delete-target-name = name;
                        root.delete-target-type = type; root.show-delete-confirm = true;
                    }
                    // Callbacks do form (encaminham aos do MainWindow).
                    add-product => { root.add-product(); }
                    update-product => { root.update-product(); }
                    pick-product-image => { root.pick-product-image(); }
                    add-discount-tier => { root.add-discount-tier(); }
                    remove-discount-tier(idx) => { root.remove-discount-tier(idx); }
                    toggle-addon-group(id) => { root.toggle-product-addon-group(id); }
                    add-variation => { root.add-variation(); }
                    remove-variation(idx) => { root.remove-variation(idx); }
                    add-variation-option(idx) => { root.add-variation-option(idx); }
                    remove-variation-option(vidx, oidx) => { root.remove-variation-option(vidx, oidx); }
                    apply-time-mask(t) => { root.apply-time-mask(t) }
                }

            // Categorias
            if root.active-tab == "categories": CategoriesPage {
                category-tree: root.category-tree;
                category-count: root.category-count;
                selected-category-id: root.selected-category-id;
                detail-category: root.detail-category;
                detail-color: root.detail-color;
                detail-prod-count: root.detail-prod-count;
                detail-sub-count: root.detail-sub-count;
                detail-stock-value: root.detail-stock-value;
                detail-catalog-pct: root.detail-catalog-pct;
                detail-catalog-hint: root.detail-catalog-hint;
                detail-cat-products: root.detail-cat-products;
                detail-cat-subs: root.detail-cat-subs;
                select-category(id) => { root.select-category(id); }
                toggle-category(id) => { root.toggle-category(id); }
                request-new-category => {
                    root.editing-id = ""; root.category-name = "";
                    root.category-description = ""; root.category-error-name = "";
                    root.category-icon-name = "";
                    root.modal-type = "category"; root.show-modal = true;
                }
                request-edit-category(c) => {
                    root.editing-id = c.id; root.category-name = c.name;
                    root.category-description = c.description; root.category-error-name = "";
                    root.category-icon-name = c.icon-name;
                    root.modal-type = "category"; root.show-modal = true;
                }
                request-new-sub-in(cat-id, cat-name) => {
                    root.editing-id = ""; root.subcategory-name = "";
                    root.subcategory-category-id = cat-id;
                    root.subcategory-category-name = cat-name;
                    root.subcategory-error-name = ""; root.subcategory-error-category = "";
                    root.subcategory-category-open = false;
                    root.modal-type = "subcategory"; root.show-modal = true;
                }
                request-edit-subcategory(s) => {
                    root.editing-id = s.id; root.subcategory-name = s.name;
                    root.subcategory-category-id = s.category-id; root.subcategory-category-name = s.category-name;
                    root.subcategory-error-name = ""; root.subcategory-error-category = "";
                    root.subcategory-category-open = false;
                    root.modal-type = "subcategory"; root.show-modal = true;
                }
                request-new-product-in(cat-id, cat-name) => {
                    // Mesmo motivo do `request-new` em ProductsPage: zera
                    // o snapshot do detalhe antes do form.
                    root.clear-detail-product();
                    root.editing-id = "";
                    root.product-name = ""; root.product-description = "";
                    root.product-price = ""; root.product-stock-quantity = "";
                    root.product-cost-price = ""; root.product-min-stock = "";
                    root.product-margin-display = "—";
                    root.product-unlimited-stock = false;
                    root.product-availability-enabled = false;
                    root.product-discount-kind = "none";
                    root.product-discount-value = "";
                    root.product-discount-min-qty = "";
                    root.load-discount-tiers("");
                    root.load-product-addon-groups("");
                    root.load-product-variations("");
                    root.product-barcode = ""; root.product-unit = "un";
                    root.product-balance-mode = "price";
                    root.product-image-data = "";
                    root.product-cover-color = "";
                    root.product-category-id = cat-id; root.product-category-name = cat-name;
                    root.product-subcategory-id = ""; root.product-subcategory-name = "";
                    root.product-category-open = false; root.product-subcategory-open = false;
                    root.product-error-name = ""; root.product-error-price = ""; root.product-error-stock = "";
                    // Navega para Produtos (master-detail) com a aba do
                    // formulário já preparada como "Novo Produto" e a
                    // categoria pré-selecionada.
                    root.selected-product-id = "new";
                    root.active-tab = "products";
                }
                request-delete(id, name, type) => {
                    root.delete-target-id = id; root.delete-target-name = name;
                    root.delete-target-type = type; root.show-delete-confirm = true;
                }
            }

