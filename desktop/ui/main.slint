    in-out property <[AdminInvoiceRow]> admin-invoices: [];
    callback admin-load-invoices(string);
    callback admin-mark-invoice-paid(string);
    // Busca/filtro das listas do painel (aplicados sobre o cache no Rust).
    in-out property <string> admin-company-search: "";
    in-out property <string> admin-company-filter: "all";   // all|active|suspended
    in-out property <string> admin-sub-search: "";
    in-out property <string> admin-sub-filter: "all";       // all|active|overdue|cancelled
    callback admin-filter-companies();
    callback admin-filter-subscriptions();
    // Exclusão de empresa (confirmação do super admin).
    in-out property <bool> admin-del-company-open: false;
    in-out property <string> admin-del-company-id: "";
    in-out property <string> admin-del-company-name: "";
    callback admin-confirm-delete-company();
    // Suspender/reativar acesso do tenant. (id, novo-active)
    callback admin-set-company-active(string, bool);
    in-out property <[AdminUserRow]> admin-users: [];
    // Formulário de administrador (criar/editar credenciais).
    in-out property <string> admin-form-id: "";
    in-out property <string> admin-form-name: "";
    in-out property <string> admin-form-email: "";
    in-out property <string> admin-form-password: "";
    callback admin-refresh();
    callback admin-new-user();
    callback admin-edit-user(string);
    callback admin-save-user(string, string, string, string);
    callback admin-delete-user(string);
    // Cadastro de estabelecimento (empresa + admin inicial + infos).
    in-out property <string> company-form-name: "";
    in-out property <string> company-form-subdomain: "";
    in-out property <string> company-form-admin-name: "";
    in-out property <string> company-form-admin-email: "";
    in-out property <string> company-form-admin-password: "";
    // Contatos / documento
