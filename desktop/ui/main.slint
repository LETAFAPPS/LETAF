                    root.printer-editing-id = "";
                    root.printer-form-name = "";
                    root.printer-form-kind = "order";
                    root.printer-form-system-name = "";
                    root.printer-form-is-default = false;
                    root.printer-form-paper-width = 80;
                    root.printer-form-error = "";
                    // Lista vazia → todas as categorias começam desmarcadas
                    // (UI fica em modo "catch-all" até o operador selecionar).
                    root.load-printer-categories([]);
                    root.refresh-available-printers();
                    root.show-printer-modal = true;
                }
                request-edit-printer(p) => {
                    root.printer-editing-id = p.id;
                    root.printer-form-name = p.name;
                    root.printer-form-kind = p.kind;
                    root.printer-form-system-name = p.system-name;
                    root.printer-form-is-default = p.is-default;
                    root.printer-form-paper-width = p.paper-width;
                    root.printer-form-error = "";
                    root.load-printer-categories(p.category-ids);
                    root.refresh-available-printers();
                    root.show-printer-modal = true;
                }
                delete-printer(id) => { root.printer-delete(id); }
                set-default-printer(id) => { root.printer-set-default(id); }
                }
            }
        }
    }

    // ════════════════════════════════════════════════
    //  MODAIS (overlays sobre tudo)
    // ════════════════════════════════════════════════

    if root.show-modal && root.active-tab == "categories" && root.modal-type == "category": CategoryModal {
        editing-id <=> root.editing-id;
        category-name <=> root.category-name;
        category-description <=> root.category-description;
        category-error-name <=> root.category-error-name;
        category-icon-name <=> root.category-icon-name;
        icon-options: root.category-icon-options;
        close => { root.show-modal = false; }
        add-category => { root.add-category(); }
        update-category => { root.update-category(); }
    }

    if root.show-modal && root.active-tab == "categories" && root.modal-type == "subcategory": SubcategoryModal {
        editing-id <=> root.editing-id;
        subcategory-name <=> root.subcategory-name;
        subcategory-category-id <=> root.subcategory-category-id;
        subcategory-category-name <=> root.subcategory-category-name;
        subcategory-category-open <=> root.subcategory-category-open;
        subcategory-error-name <=> root.subcategory-error-name;
        subcategory-error-category <=> root.subcategory-error-category;
        categories: root.categories;
        close => { root.show-modal = false; root.subcategory-category-open = false; }
        add-subcategory => { root.add-subcategory(); }
        update-subcategory => { root.update-subcategory(); }
    }

    // Modal de Banner (Fase 7). Form com upload de imagem + busca de
    // produto filtrante. `forward-focus` no Slint dá foco automático
    // na barra de busca assim que o dropdown abre.
    if root.show-modal && root.active-tab == "banners" && root.modal-type == "banner": BannerModal {
        products: root.products;
        products-filtered: root.banner-product-filtered;
        filter-products => { root.filter-banner-products(); }
        editing-id <=> root.editing-id;
        banner-title <=> root.banner-title;
        banner-item-type <=> root.banner-item-type;
        banner-product-id <=> root.banner-product-id;
        banner-product-name <=> root.banner-product-name;
        banner-product-search <=> root.banner-product-search;
        banner-url <=> root.banner-url;
        banner-image-data <=> root.banner-image-data;
        banner-image <=> root.banner-image;
        banner-image-loading <=> root.banner-image-loading;
        banner-error-title <=> root.banner-error-title;
        banner-error-image <=> root.banner-error-image;
        banner-error-target <=> root.banner-error-target;
        close => { root.show-modal = false; }
        request-pick-image => { root.pick-banner-image(); }
        request-clear-image => { root.banner-image-data = ""; }
        // Não fecha o modal aqui: o Rust valida primeiro e só fecha
        // (set_show_modal(false)) em caso de sucesso. Assim mensagens
        // de erro abaixo dos campos ficam visíveis para o operador.
        add-banner => { root.add-banner(); }
        update-banner => { root.update-banner(); }
    }

    // Modal de Cupom (Fase 8). Não fecha aqui: o Rust valida e só
    // fecha (set_show_modal(false)) em caso de sucesso, mantendo as
    // mensagens de erro visíveis abaixo dos campos.
    if root.show-modal && root.active-tab == "coupons" && root.modal-type == "coupon": CouponModal {
        editing-id <=> root.editing-id;
        coupon-title <=> root.coupon-title;
        coupon-code <=> root.coupon-code;
        coupon-type <=> root.coupon-type;
        coupon-discount-kind <=> root.coupon-discount-kind;
        coupon-discount-value <=> root.coupon-discount-value;
        coupon-min-order <=> root.coupon-min-order;
        coupon-max-discount <=> root.coupon-max-discount;
        coupon-per-user-limit <=> root.coupon-per-user-limit;
        coupon-usage-limit <=> root.coupon-usage-limit;
        coupon-valid-from <=> root.coupon-valid-from;
        coupon-valid-until <=> root.coupon-valid-until;
        coupon-error-title <=> root.coupon-error-title;
        coupon-error-code <=> root.coupon-error-code;
        coupon-error-discount <=> root.coupon-error-discount;
        coupon-error-min <=> root.coupon-error-min;
        coupon-error-per-user <=> root.coupon-error-per-user;
        coupon-error-usage <=> root.coupon-error-usage;
        coupon-error-validity <=> root.coupon-error-validity;
        format-date(t) => { root.format-coupon-date(t) }
        close => { root.show-modal = false; }
        add-coupon => { root.add-coupon(); }
        update-coupon => { root.update-coupon(); }
        open-from-cal => { root.coupon-cal-open("from"); }
        open-until-cal => { root.coupon-cal-open("until"); }
    }

    // Pop-up do calendário de validade do Cupom (sobreposto ao modal).
    // `coupon-cal-target` controla qual campo será preenchido pelo pick.
    if root.show-modal && root.active-tab == "coupons" && root.modal-type == "coupon" && root.coupon-cal-target != "": CalendarPopup {
        x: 0; y: 0;
        width: parent.width;
        height: parent.height;
        title: root.coupon-cal-title;
        days: root.coupon-cal-days;
        prev => { root.coupon-cal-prev(); }
        next => { root.coupon-cal-next(); }
        pick(d) => { root.coupon-cal-pick(d); }
        clear => { root.coupon-cal-pick(""); }
        close => { root.coupon-cal-close(); }
    }

    if root.show-modal && root.active-tab == "customers": CustomerModal {
        editing-id <=> root.editing-id;
        customer-name <=> root.customer-name;
        customer-email <=> root.customer-email;
        customer-phone <=> root.customer-phone;
        customer-document <=> root.customer-document;
        customer-notes <=> root.customer-notes;
        customer-profile-picture <=> root.customer-profile-picture;
        customer-avatar-initial <=> root.customer-avatar-initial;
        customer-error-name <=> root.customer-error-name;
        customer-error-email <=> root.customer-error-email;
        customer-error-phone <=> root.customer-error-phone;
        customer-error-document <=> root.customer-error-document;
        customer-addresses: root.detail-addresses;
        addr-label <=> root.customer-addr-label;
        addr-custom-label <=> root.customer-addr-custom-label;
        addr-street <=> root.customer-addr-street;
        addr-number <=> root.customer-addr-number;
        addr-neighborhood <=> root.customer-addr-neighborhood;
        addr-apartment <=> root.customer-addr-apartment;
        close => { root.show-modal = false; }
        add-customer => { root.add-customer(); }
        update-customer => { root.update-customer(); }
        add-customer-address => { root.add-customer-address(); }
        delete-customer-address(id) => { root.delete-customer-address(id); }
        format-customer-phone(t) => { root.format-customer-phone(t) }
        format-customer-document(t) => { root.format-customer-document(t) }
    }

    if root.show-modal && root.active-tab == "addons" && root.modal-type == "addon-group": AddonGroupModal {
        editing-id <=> root.addon-group-form-id;
        group-name <=> root.addon-group-form-name;
        group-selection <=> root.addon-group-form-selection;
        group-min <=> root.addon-group-form-min;
        group-max <=> root.addon-group-form-max;
        error-name <=> root.addon-group-form-error;
        close => { root.show-modal = false; }
        add-group => { root.save-addon-group(); }
        update-group => { root.save-addon-group(); }
    }

    if root.show-modal && root.active-tab == "addons" && root.modal-type == "addon": AddonItemModal {
        editing-id <=> root.addon-form-id;
        group-name: root.selected-addon-group-name;
        addon-name <=> root.addon-form-name;
        addon-price <=> root.addon-form-price;
        error-name <=> root.addon-form-error;
        close => { root.show-modal = false; }
        add-addon => { root.save-addon(); }
        update-addon => { root.save-addon(); }
    }

    if root.show-modal && root.active-tab == "settings" && root.modal-type == "business-hours": SettingsModal {
        bh-editing-day-name <=> root.bh-editing-day-name;
        bh-open-time <=> root.bh-open-time;
        bh-close-time <=> root.bh-close-time;
        bh-is-open <=> root.bh-is-open;
        close => { root.show-modal = false; }
        save-business-hours => { root.save-business-hours(); }
        apply-time-mask(s) => { root.apply-time-mask(s) }
    }

    if root.show-cancel-modal: CancelOrderModal {
        cancel-target-id <=> root.cancel-target-id;
        cancel-target-label <=> root.cancel-target-label;
        cancel-reason <=> root.cancel-reason;
        cancel-error <=> root.cancel-error;
        close => { root.show-cancel-modal = false; }
        cancel-order(id, reason) => { root.cancel-order(id, reason); }
    }

    if root.show-edit-order-modal: EditOrderModal {
        order: root.detail-order;
        items <=> root.edit-order-items;
        edit-notes <=> root.edit-order-notes;
        edit-error: root.edit-order-error;
        products: root.edit-order-picker-products;
        close => { root.show-edit-order-modal = false; }
        inc-qty(idx) => { root.edit-order-inc(idx); }
        dec-qty(idx) => { root.edit-order-dec(idx); }
        delete-item(idx) => { root.edit-order-delete(idx); }
        edit-item(idx) => { root.edit-order-edit-item(idx); }
        // O clique no produto agora dispara `start-product-config`: o
        // Rust decide se adiciona direto (sem addons/variações) ou
        // abre o ProductConfiguratorModal (renderizado abaixo, em
        // cima do EditOrderModal via z-order natural).
        add-product(pid) => { root.start-product-config(pid); }
        filter-picker(q) => { root.edit-order-filter-picker(q); }
        save => { root.save-edit-order(); }
    }

    // Configurador de produto — modal próprio, empilhado sobre o
    // EditOrderModal quando o operador escolhe um produto com
    // variações/adicionais OU clica em "Editar item". Removido do
    // body do EditOrderModal para garantir botões Cancelar/Adicionar
    // sempre visíveis em telas pequenas.
    if root.config-product-id != "": ProductConfiguratorModal {
        config-product-id: root.config-product-id;
        config-product-name: root.config-product-name;
        config-qty: root.config-qty;
        config-variations: root.config-variations;
        config-addon-groups: root.config-addon-groups;
        config-final-display: root.config-final-display;
        config-error: root.config-error;
        config-edit-idx: root.config-edit-idx;
        config-toggle-variation(v, o) => { root.config-toggle-variation(v, o); }
        config-toggle-addon(g, a) => { root.config-toggle-addon(g, a); }
        config-inc-qty => { root.config-inc-qty(); }
        config-dec-qty => { root.config-dec-qty(); }
        // Dispatch baseado no contexto: PDV (push no carrinho) vs
        // EditOrderModal (push em edit_order_items). Cada contexto
        // tem seu próprio callback wirado para a lógica certa em Rust.
        config-confirm => {
            if (root.config-context == "pdv") {
                root.pdv-config-confirm();
            } else {
                root.config-confirm-add();
            }
        }
        config-cancel => { root.config-cancel(); }
    }

    if root.receipt-modal-mode != "": ReceiptModal {
        mode: root.receipt-modal-mode;
        order: root.detail-order;
        items: root.detail-order-items;
        close => { root.receipt-modal-mode = ""; }
        print => {
            root.print-receipt-now(root.detail-order.id, root.receipt-modal-mode);
            // O modal fecha após disparar a impressão — o navegador
            // assume daqui e mostra o diálogo de impressão.
            root.receipt-modal-mode = "";
        }
    }

    // Calendário de período (filtro de Pedidos) — overlay full-window.
    if root.active-tab == "orders" && root.cal-open: CalendarPopup {
        x: 0; y: 0;
        width: root.width;
        height: root.height;
        title: root.cal-title;
        days: root.cal-days;
        prev => { root.cal-prev(); }
        next => { root.cal-next(); }
        pick(ymd) => { root.cal-pick(ymd); }
        clear => { root.cal-clear(); }
        close => { root.cal-open = false; }
    }

    if root.show-logout-confirm: LogoutConfirmModal {
        close => { root.show-logout-confirm = false; }
        do-logout => { root.do-logout(); }
    }

    if root.admin-del-company-open: DeleteConfirmModal {
        delete-target-name <=> root.admin-del-company-name;
        close => { root.admin-del-company-open = false; }
        confirm-delete => { root.admin-confirm-delete-company(); }
    }

    if root.admin-sub-edit-open: AdminSubscriptionModal {
        company-name: root.admin-sub-edit-company-name;
        plan <=> root.admin-sub-edit-plan;
        status <=> root.admin-sub-edit-status;
        discount <=> root.admin-sub-edit-discount;
        busy: root.admin-sub-edit-busy;
        invoices: root.admin-invoices;
        save => { root.admin-save-subscription(); }
        mark-paid(id) => { root.admin-mark-invoice-paid(id); }
        close => { root.admin-sub-edit-open = false; }
    }

    if root.profile-open: ProfileModal {
        role-label: root.user-role;
        name <=> root.profile-name;
        email <=> root.profile-email;
        new-password <=> root.profile-new-password;
        status: root.profile-status;
        busy: root.profile-busy;
        avatar: root.profile-avatar;
        avatar-loading: root.profile-avatar-loading;
        save => { root.profile-save(); }
        pick-avatar => { root.profile-pick-avatar(); }
        close => { root.profile-open = false; }
    }

    if root.show-delete-confirm: DeleteConfirmModal {
        delete-target-name <=> root.delete-target-name;
        close => { root.show-delete-confirm = false; }
        confirm-delete => { root.confirm-delete(); }
    }

    if root.pdv-show-customer-picker: PdvCustomerPickerModal {
        rows: root.pdv-customer-rows;
        search <=> root.pdv-customer-search;
        close => { root.pdv-show-customer-picker = false; }
        search-changed(q) => { root.pdv-customer-search-changed(q); }
        pick(id) => { root.pdv-pick-customer(id); }
    }

    if root.pdv-show-cart-modal: PdvCartModal {
        cart: root.pdv-cart;
        total-display: root.pdv-total-display;
        inc(id) => { root.pdv-inc-line(id); }
        dec(id) => { root.pdv-dec-line(id); }
        remove(id) => { root.pdv-remove-line(id); }
        close => { root.pdv-show-cart-modal = false; }
    }

    if root.pdv-show-sold: PdvSoldModal {
        order-number: root.pdv-sold-order-number;
        total-display: root.pdv-sold-total;
        close => { root.pdv-show-sold = false; }
        print-receipt => {
            root.print-receipt-now(root.pdv-sold-order-id, "complete");
        }
        print-kitchen => {
            root.print-receipt-now(root.pdv-sold-order-id, "kitchen");
        }
    }

    // ── Assinatura: modal de cobrança PIX (Fase 14 — Efi).
    if root.pix-modal-open: PixChargeModal {
        data: root.pix-charge-view;
        qr-code-image: root.pix-qr-image;
        close => { root.subscription-close-pix-modal(); }
        copy-code => { root.subscription-copy-pix-code(); }
    }

    // ── Assinatura: modal de cadastro de cartão recorrente (Efi).
    if root.card-modal-open: CardModal {
        number <=> root.card-form-number;
        holder <=> root.card-form-holder;
        expiry <=> root.card-form-expiry;
        cvv <=> root.card-form-cvv;
        cpf <=> root.card-form-cpf;
        email <=> root.card-form-email;
        phone <=> root.card-form-phone;
        birth <=> root.card-form-birth;
        error <=> root.card-form-error;
        error-number <=> root.card-error-number;
        error-holder <=> root.card-error-holder;
        error-expiry <=> root.card-error-expiry;
        error-cvv <=> root.card-error-cvv;
        error-cpf <=> root.card-error-cpf;
        error-birth <=> root.card-error-birth;
        error-email <=> root.card-error-email;
        error-phone <=> root.card-error-phone;
        loading: root.card-modal-loading;
        fmt-card-number(t) => { root.card-fmt-number(t) }
        fmt-card-expiry(t) => { root.card-fmt-expiry(t) }
        fmt-cvv(t) => { root.card-fmt-cvv(t) }
        fmt-cpf-cnpj(t) => { root.card-fmt-cpf-cnpj(t) }
        fmt-birth(t) => { root.card-fmt-birth(t) }
        fmt-phone(t) => { root.card-fmt-phone(t) }
        close => { root.card-modal-close(); }
        submit => { root.card-modal-submit(); }
    }

    // ── Assinatura: modal de ativação do Pix Automático.
    if root.pix-auto-modal-open: PixAutoModal {
        name <=> root.pix-auto-name;
        cpf <=> root.pix-auto-cpf;
        error <=> root.pix-auto-error;
        loading: root.pix-auto-loading;
        fmt-cpf-cnpj(t) => { root.pix-auto-fmt-cpf-cnpj(t) }
        close => { root.pix-auto-close(); }
        submit => { root.pix-auto-submit(); }
    }

    // ── Assinatura: confirmação de troca de plano com recorrência ativa.
    if root.plan-change-confirm-open: PlanChangeConfirmModal {
        message: root.plan-change-confirm-message;
        loading: root.plan-change-confirm-loading;
        close => { root.plan-change-confirm-close(); }
        confirm => { root.plan-change-confirm-yes(); }
    }

    // ── Caixa: 4 modais ───────────────────────────────────────
    // Modal: nova/editar conta a pagar ou receber (Financeiro).
    if root.finance-show-modal: FinanceEntryModal {
        kind: root.finance-form-kind;
        editing: root.finance-form-editing-id != "";
        description <=> root.finance-form-description;
        party: root.finance-form-party;
        amount <=> root.finance-form-amount;
        due-date: root.finance-form-due-date;
        installments: root.finance-form-installments;
        recurrence: root.finance-form-recurrence;
        notes <=> root.finance-form-notes;
        error-description: root.finance-form-error-description;
        error-amount: root.finance-form-error-amount;
        error-due-date: root.finance-form-error-due-date;
        error-general: root.finance-form-error-general;
        close => { root.finance-close-modal(); }
        save => { root.finance-save-modal(); }
        set-recurrence(k) => { root.finance-set-recurrence(k); }
        set-installments(n) => { root.finance-set-installments(n); }
        open-party-picker => { root.finance-open-party-picker(); }
        clear-party => { root.finance-pick-party(""); }
        toggle-due-cal => { root.finance-due-cal-toggle(); }
    }

    // Pop-up do calendário de vencimento (sobreposto ao modal).
    if root.finance-show-modal && root.finance-due-cal-open: CalendarPopup {
        x: 0; y: 0;
        width: parent.width;
        height: parent.height;
        title: root.finance-due-cal-title;
        days: root.finance-due-cal-days;
        prev => { root.finance-due-cal-prev(); }
        next => { root.finance-due-cal-next(); }
        pick(d) => { root.finance-due-cal-pick(d); }
        clear => { root.finance-due-cal-pick(""); }
        close => { root.finance-due-cal-toggle(); }
    }

    // Pop-up do picker de cliente/fornecedor (sobreposto ao modal).
    if root.finance-show-modal && root.finance-show-party-picker: PdvCustomerPickerModal {
        rows: root.finance-party-options;
        search <=> root.finance-party-search;
        search-changed(q) => { root.finance-party-search-changed(q); }
        pick(id) => { root.finance-pick-party(id); }
        close => { root.finance-close-party-picker(); }
    }

    // ── Modal de confirmação: dar baixa (Receber/Pagar) ──────
    if root.finance-show-settle-confirm: Rectangle {
        background: #00000080;
        TouchArea { clicked => { root.finance-close-settle-confirm(); } }
        VerticalLayout {
            alignment: center;
            HorizontalLayout {
                alignment: center;
                Rectangle {
                    width: 420px;
                    height: 240px;
                    border-radius: 12px;
                    background: Theme.surface;
                    border-width: 1px;
                    border-color: Theme.card-border;
                    drop-shadow-blur: 12px;
                    drop-shadow-offset-y: 0px;
                    drop-shadow-color: Theme.card-shadow;
                    // Absorve cliques dentro do card.
                    TouchArea { }
                    VerticalLayout {
                        padding: 22px;
                        spacing: 14px;
                        // Conteúdo centralizado verticalmente dentro do
                        // card de altura fixa (240px).
                        alignment: center;
                        VerticalLayout {
                            spacing: 4px;
                            Text {
                                text: root.finance-settle-target-kind == "receivable"
                                    ? "Confirmar Recebimento"
                                    : "Confirmar Pagamento";
                                font-size: 16px; font-weight: 700;
                                color: Theme.text-primary;
                                horizontal-alignment: center;
                            }
                            Text {
                                text: root.finance-settle-target-kind == "receivable"
                                    ? "O lançamento será marcado como Recebido."
                                    : "O lançamento será marcado como Pago.";
                                font-size: 12px;
                                color: Theme.text-secondary;
                                horizontal-alignment: center;
                            }
                        }
                        Rectangle {
                            background: Theme.bg;
                            border-radius: 8px;
                            border-width: 1px;
                            border-color: Theme.card-border;
                            VerticalLayout {
                                padding: 14px;
                                spacing: 4px;
                                HorizontalLayout {
                                    Text {
                                        horizontal-stretch: 1;
                                        text: root.finance-settle-target-desc;
                                        font-size: 13px; font-weight: 700;
                                        color: Theme.text-primary;
                                        overflow: elide;
                                    }
                                    Text {
                                        text: root.finance-settle-target-amount;
                                        font-size: 14px; font-weight: 800;
                                        color: root.finance-settle-target-kind == "receivable"
                                            ? #2E7D32 : #E53935;
                                    }
                                }
                                if root.finance-settle-target-party != "": Text {
                                    text: root.finance-settle-target-party;
                                    font-size: 11px;
                                    color: Theme.text-secondary;
                                    overflow: elide;
                                }
                            }
                        }
                        HorizontalLayout {
                            spacing: 10px;
                            alignment: end;
                            cancel-ta := TouchArea {
                                width: 100px; height: 32px;
                                clicked => { root.finance-close-settle-confirm(); }
                                Rectangle {
                                    border-radius: 8px;
                                    // Cancelar = neutro (borda/texto cinza, sem fundo).
                                    border-width: 1px;
                                    border-color: Theme.text-secondary;
                                    background: cancel-ta.has-hover ? Theme.row-hover : transparent;
                                    Text {
                                        width: parent.width; height: parent.height;
                                        text: "Cancelar";
                                        font-size: 13px; font-weight: 700;
                                        color: Theme.text-secondary;
                                        horizontal-alignment: center; vertical-alignment: center;
                                    }
                                }
                            }
                            confirm-ta := TouchArea {
                                width: 140px; height: 32px;
                                clicked => { root.finance-confirm-settle(); }
                                Rectangle {
                                    border-radius: 8px;
                                    background: confirm-ta.has-hover ? Theme.primary-dark : Theme.primary;
                                    Text {
                                        width: parent.width; height: parent.height;
                                        text: root.finance-settle-target-kind == "receivable"
                                            ? "Confirmar"
                                            : "Confirmar";
                                        font-size: 12px; font-weight: 700;
                                        color: white;
                                        horizontal-alignment: center; vertical-alignment: center;
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }

    // ── Modal de confirmação: excluir lançamento ─────────────
    if root.finance-show-delete-confirm: Rectangle {
        background: #00000080;
        TouchArea { clicked => { root.finance-close-delete-confirm(); } }
        VerticalLayout {
            alignment: center;
            HorizontalLayout {
                alignment: center;
                Rectangle {
                    width: 420px;
                    height: 240px;
                    border-radius: 12px;
                    background: Theme.surface;
                    border-width: 1px;
                    border-color: Theme.card-border;
                    drop-shadow-blur: 12px;
                    drop-shadow-offset-y: 0px;
                    drop-shadow-color: Theme.card-shadow;
                    TouchArea { }
                    VerticalLayout {
                        padding: 22px;
                        spacing: 14px;
                        alignment: center;
                        VerticalLayout {
                            spacing: 4px;
                            Text {
                                text: "Excluir Lançamento";
                                font-size: 16px; font-weight: 700;
                                color: Theme.text-primary;
                                horizontal-alignment: center;
                            }
                            Text {
                                text: "Este lançamento será removido. Esta ação não pode ser desfeita.";
                                font-size: 12px;
                                color: Theme.text-secondary;
                                horizontal-alignment: center;
                                wrap: word-wrap;
                            }
                        }
                        Rectangle {
                            background: Theme.bg;
                            border-radius: 8px;
                            border-width: 1px;
                            border-color: Theme.card-border;
                            VerticalLayout {
                                padding: 14px;
                                spacing: 4px;
                                HorizontalLayout {
                                    Text {
                                        horizontal-stretch: 1;
                                        text: root.finance-delete-target-desc;
                                        font-size: 13px; font-weight: 700;
                                        color: Theme.text-primary;
                                        overflow: elide;
                                    }
                                    Text {
                                        text: root.finance-delete-target-amount;
                                        font-size: 14px; font-weight: 800;
                                        color: root.finance-delete-target-kind == "receivable"
                                            ? #2E7D32 : #E53935;
                                    }
                                }
                            }
                        }
                        HorizontalLayout {
                            spacing: 10px;
                            alignment: end;
                            del-cancel-ta := TouchArea {
                                width: 100px; height: 32px;
                                clicked => { root.finance-close-delete-confirm(); }
                                Rectangle {
                                    border-radius: 8px;
                                    // Cancelar = neutro (borda/texto cinza, sem fundo).
                                    border-width: 1px;
                                    border-color: Theme.text-secondary;
                                    background: del-cancel-ta.has-hover ? Theme.row-hover : transparent;
                                    Text {
                                        width: parent.width; height: parent.height;
                                        text: "Cancelar";
                                        font-size: 13px; font-weight: 700;
                                        color: Theme.text-secondary;
                                        horizontal-alignment: center; vertical-alignment: center;
                                    }
                                }
                            }
                            del-confirm-ta := TouchArea {
                                width: 140px; height: 32px;
                                clicked => { root.finance-confirm-delete(); }
                                Rectangle {
                                    border-radius: 8px;
                                    background: del-confirm-ta.has-hover ? #B71C1C : #E53935;
                                    Text {
                                        width: parent.width; height: parent.height;
                                        text: "Excluir";
                                        font-size: 13px; font-weight: 700;
                                        color: white;
                                        horizontal-alignment: center; vertical-alignment: center;
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }

    // ── Modais da carteira do cliente ────────────────────────
    if root.wallet-show-deposit: WalletDepositModal {
        amount <=> root.wallet-form-amount;
        notes <=> root.wallet-form-notes;
        error: root.wallet-form-error;
        close => { root.wallet-close-modals(); }
        confirm => { root.wallet-confirm-deposit(); }
    }
    if root.wallet-show-withdraw: WalletWithdrawModal {
        amount <=> root.wallet-form-amount;
        notes <=> root.wallet-form-notes;
        error: root.wallet-form-error;
        close => { root.wallet-close-modals(); }
        confirm => { root.wallet-confirm-withdraw(); }
    }
    if root.wallet-show-adjust: WalletAdjustModal {
        amount <=> root.wallet-form-amount;
        notes <=> root.wallet-form-notes;
        error: root.wallet-form-error;
        close => { root.wallet-close-modals(); }
        confirm => { root.wallet-confirm-adjust(); }
    }
    if root.wallet-show-limit: WalletLimitModal {
        amount <=> root.wallet-form-limit;
        notes <=> root.wallet-form-notes;
        error: root.wallet-form-error;
        close => { root.wallet-close-modals(); }
        confirm => { root.wallet-confirm-limit(); }
    }

    if root.cash-show-open: CashOpenModal {
        operator-label: root.cash-open-operator;
        suggested-display: root.cash-open-suggested;
        amount-input <=> root.cash-open-amount;
        notes-input <=> root.cash-open-notes;
        close => { root.cash-show-open = false; }
        confirm => { root.cash-open-confirm(); }
    }
    if root.cash-show-sangria: CashSangriaModal {
        cash-now-display: root.cash-summary.cash-now-display;
        amount-input <=> root.cash-sangria-amount;
        reason-selected <=> root.cash-sangria-reason;
        detail-input <=> root.cash-sangria-detail;
        close => { root.cash-show-sangria = false; }
        confirm => { root.cash-sangria-confirm(); }
    }
    if root.cash-show-suprimento: CashSuprimentoModal {
        cash-now-display: root.cash-summary.cash-now-display;
        amount-input <=> root.cash-suprimento-amount;
        origin-selected <=> root.cash-suprimento-origin;
        detail-input <=> root.cash-suprimento-detail;
        close => { root.cash-show-suprimento = false; }
        confirm => { root.cash-suprimento-confirm(); }
    }
    if root.cash-show-close: CashCloseModal {
        opened-at-display: root.cash-close-opened-at;
        duration-display: root.cash-close-duration;
        operator-label: root.cash-close-operator;
        sys-cash-display: root.cash-close-sys-cash;
        sys-pix-display: root.cash-close-sys-pix;
        sys-credit-display: root.cash-close-sys-credit;
        sys-debit-display: root.cash-close-sys-debit;
        sys-total-display: root.cash-close-sys-total;
        sales-cash-count: root.cash-close-cash-count;
        sales-pix-count: root.cash-close-pix-count;
        sales-credit-count: root.cash-close-credit-count;
        sales-debit-count: root.cash-close-debit-count;
        in-cash <=> root.cash-close-in-cash;
        in-pix <=> root.cash-close-in-pix;
        in-credit <=> root.cash-close-in-credit;
        in-debit <=> root.cash-close-in-debit;
        notes <=> root.cash-close-notes;
        diff-cash-display: root.cash-close-diff-cash;
        diff-pix-display: root.cash-close-diff-pix;
        diff-credit-display: root.cash-close-diff-credit;
        diff-debit-display: root.cash-close-diff-debit;
        diff-total-display: root.cash-close-diff-total;
        has-diff: root.cash-close-has-diff;
        in-total-display: root.cash-close-in-total;
        close => { root.cash-show-close = false; }
        recalc => { root.cash-close-recalc(); }
        confirm => { root.cash-close-confirm(); }
    }

    // Modal de ajuste de estoque (Controle de Estoque)
    if root.stock-adjust-show: StockAdjustModal {
        mode: root.stock-adjust-mode;
        product-name: root.stock-adjust-product-name;
        current-display: root.stock-adjust-current;
        qty-input <=> root.stock-adjust-qty;
        reason-input <=> root.stock-adjust-reason;
        error-message: root.stock-adjust-error;
        close => { root.stock-adjust-show = false; root.stock-adjust-error = ""; }
        confirm => { root.inventory-confirm-adjust(); }
    }

    // PDV bloqueado por caixa fechado: implementado como PÁGINA
    // (PdvBlockedView) que substitui o PdvPage acima, não como modal
    // overlay. Overlay top-level mountado em conjunto com mudança de
    // aba causava panic "Recursion detected" no layout do Slint.

    if root.show-printer-modal: PrinterModal {
        editing-id <=> root.printer-editing-id;
        printer-name <=> root.printer-form-name;
        printer-kind <=> root.printer-form-kind;
        printer-system-name <=> root.printer-form-system-name;
        printer-is-default <=> root.printer-form-is-default;
        printer-paper-width <=> root.printer-form-paper-width;
        printer-error: root.printer-form-error;
        available-list: root.printer-available-list;
        categories <=> root.printer-form-categories;
        close => { root.show-printer-modal = false; }
        save => { root.printer-save(); }
        test-print => { root.printer-test-print(); }
        refresh-available => { root.refresh-available-printers(); }
    }

    // Alarme de novos pedidos — instanciado por ÚLTIMO entre os
    // modais globais para garantir z-order acima de qualquer outro
    // overlay (sobrepõe edit-order/configurador/comanda etc.).
    if root.alarm-visible: NewOrderAlarmModal {
        pending-count: root.alarm-pending-count;
        acknowledge => { root.alarm-acknowledge(); }
        dismiss => { root.alarm-dismiss(); }
    }

    // ════════════════════════════════════════════════
    //  MODAL DE ATUALIZAÇÃO (overlay global)
    // ════════════════════════════════════════════════
    if root.update-available: UpdateModal {
        version: root.update-version;
        notes: root.update-notes;
        mandatory: root.update-mandatory;
        status: root.update-status;
        error: root.update-error;
        update-now => { root.apply-update(); }
        download-manual => { root.open-update-url(); }
        later => { root.update-available = false; }
    }

    // ════════════════════════════════════════════════
    //  TOAST NOTIFICATION
    // ════════════════════════════════════════════════
    toast-el := Toast {
        x: root.width - toast-el.hint-width - 16px;
        y: root.height - self.height - 16px;
        width: toast-el.hint-width;
        height: 44px;
        opacity: root.toast-visible ? 1.0 : 0.0;
        animate opacity { duration: 250ms; easing: ease; }
        message: root.toast-message;
        toast-type: root.toast-type;
    }
}
