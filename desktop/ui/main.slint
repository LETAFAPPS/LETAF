    in-out property <[FinanceCashFlowPoint]> finance-cash-flow: [];
    /// Sub-rótulo do gráfico: "saldo previsto: R$ -5.541,50".
    in-out property <string> finance-cash-flow-summary: "";

    /// Modo de visualização: "list" (default) | "calendar".
    in-out property <string> finance-view-mode: "list";
