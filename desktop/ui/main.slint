    in-out property <bool> admin-sub-edit-open: false;
    in-out property <bool> admin-sub-edit-busy: false;
    in-out property <string> admin-sub-edit-company-id: "";
    in-out property <string> admin-sub-edit-company-name: "";
    in-out property <string> admin-sub-edit-plan: "monthly";
    in-out property <string> admin-sub-edit-status: "active";
    in-out property <string> admin-sub-edit-discount: "0";
    callback admin-save-subscription();
