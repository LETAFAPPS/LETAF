// Painel do administrador — Assinaturas & planos (cross-tenant).
// UI sem lógica (§1/§3): lista pronta do Rust (GET /admin/subscriptions).
import { Theme } from "../theme.slint";
import { AdminSubscriptionRow } from "../types.slint";
import { EmptyState } from "../components/empty_state.slint";

export component AdminSubscriptionsPage inherits VerticalLayout {
    in property <[AdminSubscriptionRow]> subscriptions;
    spacing: 12px;

    Text {
        text: "Assinaturas & planos";
        font-size: 20px; font-weight: 800; color: Theme.text-primary;
    }
    Text {
        text: root.subscriptions.length + " assinatura(s).";
        font-size: 13px; color: Theme.text-secondary;
    }

    if root.subscriptions.length == 0: EmptyState {
        source: @image-url("../assets/empty/invoice.svg");
        title: "Nenhuma assinatura";
    }

    if root.subscriptions.length > 0: Rectangle {
        vertical-stretch: 1;
        background: Theme.surface;
        border-radius: 12px;
        border-width: 1px;
        border-color: Theme.card-border;
        drop-shadow-blur: 12px;
        drop-shadow-offset-y: 0px;
        drop-shadow-color: Theme.card-shadow;
        VerticalLayout {
            padding: 8px;
            HorizontalLayout {
                padding: 10px;
                spacing: 12px;
                Text { text: "EMPRESA"; horizontal-stretch: 2; font-size: 11px; font-weight: 700; color: Theme.text-secondary; }
                Text { text: "PLANO"; horizontal-stretch: 1; font-size: 11px; font-weight: 700; color: Theme.text-secondary; }
                Text { text: "STATUS"; horizontal-stretch: 1; font-size: 11px; font-weight: 700; color: Theme.text-secondary; }
                Text { text: "PAGAMENTO"; horizontal-stretch: 1; font-size: 11px; font-weight: 700; color: Theme.text-secondary; }
                Text { text: "PRÓX. COBRANÇA"; horizontal-stretch: 1; font-size: 11px; font-weight: 700; color: Theme.text-secondary; horizontal-alignment: right; }
            }
            Rectangle { height: 1px; background: Theme.border; }
            for s in root.subscriptions: HorizontalLayout {
                padding: 10px;
                spacing: 12px;
                Text { text: s.company-name; horizontal-stretch: 2; font-size: 13px; font-weight: 600; color: Theme.text-primary; overflow: elide; vertical-alignment: center; }
                Text { text: s.plan == "monthly" ? "Mensal" : (s.plan == "yearly" ? "Anual" : s.plan); horizontal-stretch: 1; font-size: 13px; color: Theme.text-primary; vertical-alignment: center; }
                Text { text: s.status == "active" ? "Ativa" : "Cancelada"; horizontal-stretch: 1; font-size: 13px; font-weight: 700; color: s.status == "active" ? #2E7D32 : Theme.text-secondary; vertical-alignment: center; }
                Text { text: s.payment-kind == "" ? "—" : s.payment-kind; horizontal-stretch: 1; font-size: 13px; color: Theme.text-secondary; vertical-alignment: center; }
                Text { text: s.next-charge == "" ? "—" : s.next-charge; horizontal-stretch: 1; font-size: 13px; color: Theme.text-secondary; horizontal-alignment: right; vertical-alignment: center; }
            }
        }
    }
}
