// Painel do administrador — Assinaturas & planos (cross-tenant).
// UI sem lógica (§1/§3): lista pronta do Rust (GET /admin/subscriptions).
import { Theme } from "../theme.slint";
import { AdminSubscriptionRow } from "../types.slint";
import { EmptyState } from "../components/empty_state.slint";
import { AdminSearchBox, FilterChipSm } from "../components/admin_filter_bar.slint";

export component AdminSubscriptionsPage inherits VerticalLayout {
    in property <[AdminSubscriptionRow]> subscriptions;
    callback manage(AdminSubscriptionRow);
    // Busca/filtro (aplicados no Rust sobre a lista completa).
    in-out property <string> search;
    in-out property <string> filter: "all";
    callback filters-changed();
    spacing: 12px;
    alignment: start;

    Text {
        text: "Assinaturas & planos";
        font-size: 20px; font-weight: 800; color: Theme.text-primary;
    }
    Text {
        text: root.subscriptions.length + " assinatura(s).";
        font-size: 13px; color: Theme.text-secondary;
    }

    // Busca + filtro de status.
    HorizontalLayout {
        spacing: 8px;
        AdminSearchBox {
            horizontal-stretch: 1;
            value <=> root.search;
            placeholder: "Buscar por empresa...";
            changed => { root.filters-changed(); }
        }
        FilterChipSm {
            label: "Todas"; active: root.filter == "all";
            clicked => { root.filter = "all"; root.filters-changed(); }
        }
        FilterChipSm {
            label: "Ativas"; active: root.filter == "active";
            clicked => { root.filter = "active"; root.filters-changed(); }
        }
        FilterChipSm {
            label: "Vencidas"; active: root.filter == "overdue";
            clicked => { root.filter = "overdue"; root.filters-changed(); }
        }
        FilterChipSm {
            label: "Canceladas"; active: root.filter == "cancelled";
            clicked => { root.filter = "cancelled"; root.filters-changed(); }
        }
    }

    if root.subscriptions.length == 0: EmptyState {
        source: @image-url("../assets/empty/invoice.svg");
        title: "Nenhuma assinatura";
    }

    if root.subscriptions.length > 0: Rectangle {
        vertical-stretch: 1;
        background: Theme.surface;
        border-radius: 12px;
        border-width: 1px;
        border-color: Theme.card-border;
        drop-shadow-blur: 12px;
        drop-shadow-offset-y: 0px;
        drop-shadow-color: Theme.card-shadow;
        VerticalLayout {
            padding: 8px;
            alignment: start;   // linhas logo abaixo do cabeçalho
            HorizontalLayout {
                padding: 10px;
                spacing: 12px;
                Text { text: "EMPRESA"; horizontal-stretch: 2; font-size: 11px; font-weight: 700; color: Theme.text-secondary; }
                Text { text: "PLANO"; horizontal-stretch: 1; font-size: 11px; font-weight: 700; color: Theme.text-secondary; }
                Text { text: "STATUS"; horizontal-stretch: 1; font-size: 11px; font-weight: 700; color: Theme.text-secondary; }
                Text { text: "PAGAMENTO"; horizontal-stretch: 1; font-size: 11px; font-weight: 700; color: Theme.text-secondary; }
                Text { text: "PRÓX. COBRANÇA"; horizontal-stretch: 1; font-size: 11px; font-weight: 700; color: Theme.text-secondary; horizontal-alignment: right; }
                Text { text: ""; width: 104px; }
            }
            Rectangle { height: 1px; background: Theme.border; }
            for s in root.subscriptions: HorizontalLayout {
                padding: 10px;
                spacing: 12px;
                Text { text: s.company-name; horizontal-stretch: 2; font-size: 13px; font-weight: 600; color: Theme.text-primary; overflow: elide; vertical-alignment: center; }
                Text { text: s.plan == "monthly" ? "Mensal" : (s.plan == "semestral" ? "Semestral" : (s.plan == "annual" ? "Anual" : s.plan)); horizontal-stretch: 1; font-size: 13px; color: Theme.text-primary; vertical-alignment: center; }
                Text { text: s.status == "active" ? "Ativa" : (s.status == "overdue" ? "Vencida" : "Cancelada"); horizontal-stretch: 1; font-size: 13px; font-weight: 700; color: s.status == "active" ? #2E7D32 : (s.status == "overdue" ? #E65100 : Theme.text-secondary); vertical-alignment: center; }
                Text { text: s.payment-kind == "" ? "—" : s.payment-kind; horizontal-stretch: 1; font-size: 13px; color: Theme.text-secondary; vertical-alignment: center; }
                Text { text: s.next-charge == "" ? "—" : s.next-charge; horizontal-stretch: 1; font-size: 13px; color: Theme.text-secondary; horizontal-alignment: right; vertical-alignment: center; }
                // Ação: gerenciar (estilo tênue de ação).
                manage-ta := TouchArea {
                    width: 104px; height: 32px;
                    clicked => { root.manage(s); }
                    Rectangle {
                        border-radius: 8px;
                        border-width: 1.5px;
                        border-color: Theme.btn-accent;
                        background: manage-ta.has-hover
                            ? Theme.btn-accent.transparentize(0.80)
                            : Theme.btn-accent.transparentize(0.90);
                        Text {
                            text: "Gerenciar";
                            font-size: 13px; font-weight: 700; color: Theme.btn-accent;
                            horizontal-alignment: center; vertical-alignment: center;
                            width: parent.width; height: parent.height;
                        }
                    }
                }
            }
        }
    }
}
