import { ScrollView } from "std-widgets.slint";
import { AssetIcon } from "../components/icons.slint";
import { EmptyState } from "../components/empty_state.slint";
import { Theme } from "../theme.slint";
import { PlanCardData, SubscriptionData, SubscriptionInvoiceRow, PaymentMethodOption } from "../types.slint";

// ── Tela "Plano & cobrança" ──────────────────────────────────────
// Layout responsivo: duas colunas quando largo; abaixo de ~1180px as
// colunas EMPILHAM (esquerda em cima, direita embaixo) e a página rola
// verticalmente — nada é cortado. UI sem lógica (§1/§14).

// Chip "VISA" / "PIX".
component PaymentChip inherits Rectangle {
    in property <string> kind;
    width: 56px;
    height: 26px;
    border-radius: 5px;
    background: root.kind == "pix" ? #1AA86F
              : root.kind == "card" || root.kind == "visa" ? #1A237E
              : #757575;
    Text {
        width: parent.width; height: parent.height;
        text: root.kind == "pix" ? "PIX"
            : root.kind == "card" || root.kind == "visa" ? "VISA"
            : "—";
        font-size: 11px; font-weight: 800;
        letter-spacing: 1px;
        color: white;
        horizontal-alignment: center; vertical-alignment: center;
    }
}

// Card de plano (Mensal/Semestral/Anual).
component PlanCard inherits Rectangle {
    in property <PlanCardData> data;
    callback choose();

    property <color> brand-color: data.tone == "primary" ? Theme.primary
                                  : data.tone == "success" ? #2E7D32
                                  : #1976D2;
    property <color> brand-dark: data.tone == "primary" ? Theme.primary-dark
                                 : data.tone == "success" ? #1B5E20
                                 : #0D47A1;

    border-radius: 12px;
    border-width: data.is-current ? 2px : 1px;
    border-color: data.is-current ? Theme.sidebar-sel-bg : Theme.border;
    drop-shadow-blur: 12px;
    drop-shadow-offset-y: 0px;
    drop-shadow-color: Theme.card-shadow;
    background: Theme.surface;
    // Permite encolher abaixo da largura natural do conteúdo (adaptativo).
    min-width: 150px;

    VerticalLayout {
        padding: 22px;
        spacing: 6px;

        HorizontalLayout {
            spacing: 8px;
            Rectangle {
                width: 12px; height: 12px;
                y: 4px;
                border-radius: 3px;
                background: root.brand-color;
            }
            Text {
                horizontal-stretch: 1;
                text: data.label;
                font-size: 16px; font-weight: 800;
                color: Theme.text-primary;
                vertical-alignment: center;
                overflow: elide;
            }
            if data.is-current: Rectangle {
                width: atual-text.preferred-width + 12px;
                height: 20px;
                border-radius: 4px;
                background: #E8F5E9;
                atual-text := Text {
                    width: parent.width; height: parent.height;
                    text: "ATUAL";
                    font-size: 10px; font-weight: 800;
                    color: #2E7D32;
                    letter-spacing: 1px;
                    horizontal-alignment: center; vertical-alignment: center;
                }
            }
            if !data.is-current && data.highlight-label != "": Rectangle {
                width: off-text.preferred-width + 12px;
                height: 20px;
                border-radius: 4px;
                background: #E8F5E9;
                off-text := Text {
                    width: parent.width; height: parent.height;
                    text: data.highlight-label;
                    font-size: 10px; font-weight: 800;
                    color: #2E7D32;
                    letter-spacing: 1px;
                    horizontal-alignment: center; vertical-alignment: center;
                }
            }
        }

        Text {
            text: data.description;
            font-size: 11px;
            color: Theme.text-secondary;
            overflow: elide;
        }

        Rectangle { height: 6px; }

        HorizontalLayout {
            spacing: 2px;
            alignment: start;
            Text {
                text: data.monthly-display;
                font-size: 26px; font-weight: 800;
                color: Theme.text-primary;
                vertical-alignment: bottom;
            }
            Text {
                text: "/mês";
                font-size: 12px; font-weight: 600;
                color: Theme.text-secondary;
                vertical-alignment: bottom;
            }
        }

        if data.cycle-display != "": Text {
            text: data.cycle-display;
            font-size: 11px; font-weight: 700;
            color: #2E7D32;
            overflow: elide;
        }

        // Período gratuito (trial) definido no plano do catálogo.
        if data.trial-label != "": Text {
            text: data.trial-label;
            font-size: 11px; font-weight: 700;
            color: Theme.sidebar-sel-bg;
            overflow: elide;
        }

        Rectangle { vertical-stretch: 1; background: transparent; min-height: 6px; }

        ta := TouchArea {
            height: 40px;
            clicked => { if !data.is-current { root.choose(); } }
            Rectangle {
                border-radius: 8px;
                background: data.is-current
                    ? Theme.row-hover
                    : (ta.has-hover ? root.brand-dark : root.brand-color);
                border-width: data.is-current ? 1px : 0;
                border-color: Theme.card-border;
                drop-shadow-blur: 12px;
                drop-shadow-offset-y: 0px;
                drop-shadow-color: Theme.card-shadow;
                Text {
                    width: parent.width; height: parent.height;
                    text: data.is-current ? "Plano Atual" : "Mudar e Economizar";
                    font-size: 13px; font-weight: 700;
                    color: data.is-current ? Theme.text-primary : white;
                    horizontal-alignment: center; vertical-alignment: center;
                    overflow: elide;
                }
            }
        }
    }
}

// Linha da tabela de faturas.
component InvoiceRow inherits Rectangle {
    in property <SubscriptionInvoiceRow> data;
    callback download();
    callback pay();

    property <bool> pending: root.data.status-key == "pending";
    height: 56px;
    background: root.pending ? Theme.row-hover : (ta.has-hover ? Theme.row-hover : transparent);
    ta := TouchArea { }
    Rectangle {
        x: 0; y: parent.height - 1px;
        width: parent.width; height: 1px;
        background: Theme.border;
    }
    HorizontalLayout {
        padding-left: 18px; padding-right: 18px;
        spacing: 14px;

        Text {
            width: 120px;
            text: root.data.issued-display;
            font-size: 12px;
            color: Theme.text-primary;
            vertical-alignment: center;
        }
        Text {
            width: 120px;
            text: root.data.number;
            font-size: 12px;
            color: Theme.text-secondary;
            vertical-alignment: center;
        }
        Text {
            horizontal-stretch: 1;
            min-width: 90px;
            text: root.data.description;
            font-size: 13px; font-weight: 600;
            color: Theme.text-primary;
            vertical-alignment: center;
            overflow: elide;
        }
        HorizontalLayout {
            width: 120px;
            spacing: 8px;
            PaymentChip {
                kind: root.data.method-kind;
                y: (parent.height - self.height) / 2;
            }
            Text {
                text: root.data.method-label;
                font-size: 12px;
                color: Theme.text-secondary;
                vertical-alignment: center;
                horizontal-stretch: 1;
                overflow: elide;
            }
        }
        HorizontalLayout {
            width: 100px;
            spacing: 6px;
            alignment: start;
            Rectangle {
                width: 8px; height: 8px;
                y: (parent.height - 8px) / 2;
                border-radius: 4px;
                background: root.data.status-key == "paid" ? #2E7D32
                          : root.data.status-key == "failed" ? #E53935
                          : #C62828;
            }
            Text {
                text: root.data.status-label;
                font-size: 12px; font-weight: 600;
                color: root.data.status-key == "paid" ? #2E7D32
                     : root.data.status-key == "failed" ? #E53935
                     : #C62828;
                vertical-alignment: center;
            }
        }
        Rectangle {
            width: 110px; background: transparent;
            Text {
                width: parent.width - 14px; height: parent.height;
                x: 0;
                text: root.data.amount-display;
                font-size: 13px; font-weight: 800;
                color: Theme.text-primary;
                horizontal-alignment: right; vertical-alignment: center;
            }
        }
        if root.pending: pay-ta := TouchArea {
            width: 72px; height: 30px;
            y: (parent.height - 30px) / 2;
            clicked => { root.pay(); }
            Rectangle {
                border-radius: 6px;
                background: pay-ta.has-hover ? #A21B1B : #C62828;
                Text {
                    width: parent.width; height: parent.height;
                    text: "Pagar";
                    font-size: 11px; font-weight: 800;
                    color: white;
                    horizontal-alignment: center; vertical-alignment: center;
                }
            }
        }
        if !root.pending: Rectangle {
            width: 72px; background: transparent;
        }
        pdf-ta := TouchArea {
            width: 56px; height: 30px;
            y: (parent.height - 30px) / 2;
            clicked => { root.download(); }
            Rectangle {
                border-radius: 6px;
                border-width: 1px;
                border-color: Theme.card-border;
                drop-shadow-blur: 12px;
                drop-shadow-offset-y: 0px;
                drop-shadow-color: Theme.card-shadow;
                background: pdf-ta.has-hover ? Theme.row-hover : Theme.surface;
                Text {
                    width: parent.width; height: parent.height;
                    text: "PDF";
                    font-size: 11px; font-weight: 800;
                    color: Theme.text-primary;
                    horizontal-alignment: center; vertical-alignment: center;
                }
            }
        }
    }
}

// Célula de métrica do card "PLANO ATUAL".
component MiniStat inherits Rectangle {
    in property <string> label;
    in property <string> value;
    horizontal-stretch: 1;
    height: 56px;
    border-radius: 10px;
    border-width: 1px;
    border-color: Theme.card-border;
    drop-shadow-blur: 12px;
    drop-shadow-offset-y: 0px;
    drop-shadow-color: Theme.card-shadow;
    background: Theme.surface;
    VerticalLayout {
        padding-left: 12px; padding-right: 12px;
        alignment: center;
        spacing: 2px;
        Text { text: root.label; font-size: 9px; font-weight: 800; letter-spacing: 1px; color: Theme.text-secondary; overflow: elide; }
        Text { text: root.value; font-size: 16px; font-weight: 800; color: Theme.text-primary; overflow: elide; }
    }
}

// ── Coluna esquerda: resumo do plano + pagamento + botões ──────────
component LeftPanel inherits VerticalLayout {
    in property <SubscriptionData> data;
    in property <[SubscriptionInvoiceRow]> invoices;
    in property <[PaymentMethodOption]> payment-methods;
    in property <bool> payment-picker-open;
    callback pay-invoice(string);
    callback open-payment-change();
    callback pick-payment-method(string);
    callback open-card-modal();
    callback cancel-card();
    callback open-pix-auto();
    callback cancel-pix-auto();

    spacing: 14px;
    alignment: start;

    // Cabeçalho
    VerticalLayout {
        spacing: 2px;
        Text { text: "ASSINATURA"; font-size: 10px; font-weight: 800; letter-spacing: 1px; color: Theme.text-secondary; }
        Text { text: "Plano & Cobrança"; font-size: 22px; font-weight: 800; color: Theme.text-primary; }
    }

    // Alerta: fatura(s) pendente(s) — não-pendentes ficam com altura 0.
    VerticalLayout {
        spacing: 0px;
        for inv in root.invoices: Rectangle {
            height: inv.status-key == "pending" ? 64px : 0px;
            visible: inv.status-key == "pending";
            border-radius: 12px;
            border-width: 1px;
            border-color: #F3C5C0;
            drop-shadow-blur: 12px;
            drop-shadow-offset-y: 0px;
            drop-shadow-color: Theme.card-shadow;
            background: #FDECEA;
            HorizontalLayout {
                padding-left: 14px; padding-right: 14px;
                spacing: 12px;
                VerticalLayout {
                    alignment: center;
                    Rectangle {
                        width: 24px; height: 24px; border-radius: 12px;
                        background: #C62828;
                        Text { width: parent.width; height: parent.height; text: "!"; font-size: 14px; font-weight: 800; color: white; horizontal-alignment: center; vertical-alignment: center; }
                    }
                }
                VerticalLayout {
                    horizontal-stretch: 1;
                    alignment: center;
                    spacing: 2px;
                    Text { text: "Fatura vencida"; font-size: 13px; font-weight: 800; color: #C62828; }
                    Text { text: inv.number + " · " + inv.amount-display + " pendente"; font-size: 11px; color: #C62828; overflow: elide; }
                }
                VerticalLayout {
                    alignment: center;
                    pay-alert-ta := TouchArea {
                        width: 72px; height: 32px;
                        clicked => { root.pay-invoice(inv.id); }
                        Rectangle {
                            border-radius: 8px;
                            background: pay-alert-ta.has-hover ? #A21B1B : #C62828;
                            Text { width: parent.width; height: parent.height; text: "Pagar"; font-size: 12px; font-weight: 800; color: white; horizontal-alignment: center; vertical-alignment: center; }
                        }
                    }
                }
            }
        }
    }

    // PLANO ATUAL
    Rectangle {
        border-radius: 16px;
        border-width: 1px;
        border-color: Theme.sidebar-sel-bg;
        drop-shadow-blur: 12px;
        drop-shadow-offset-y: 0px;
        drop-shadow-color: Theme.card-shadow;
        background: Theme.row-hover;
        VerticalLayout {
            padding: 18px;
            spacing: 10px;
            HorizontalLayout {
                alignment: start;
                Rectangle {
                    width: badge-t.preferred-width + 20px; height: 22px;
                    border-radius: 6px;
                    background: Theme.sidebar-sel-bg;
                    badge-t := Text { width: parent.width; height: parent.height; text: "PLANO ATUAL"; font-size: 10px; font-weight: 800; letter-spacing: 1px; color: white; horizontal-alignment: center; vertical-alignment: center; }
                }
            }
            HorizontalLayout {
                spacing: 0px;
                alignment: start;
                Text { text: root.data.plan-headline + " · "; font-size: 24px; font-weight: 800; color: Theme.text-primary; }
                Text { text: root.data.plan-suffix; font-size: 24px; font-weight: 800; color: Theme.sidebar-sel-bg; }
            }
            Text { text: root.data.plan-description; font-size: 12px; color: Theme.text-secondary; wrap: word-wrap; }
            HorizontalLayout {
                spacing: 10px;
                MiniStat { label: "VALOR/MÊS"; value: root.data.monthly-display; }
                if root.data.has-next-charge: MiniStat { label: "PRÓX. COBRANÇA"; value: root.data.next-charge-display; }
            }
        }
    }

    // PAGAMENTO
    Rectangle {
        border-radius: 12px;
        border-width: 1px;
        border-color: Theme.card-border;
        drop-shadow-blur: 12px;
        drop-shadow-offset-y: 0px;
        drop-shadow-color: Theme.card-shadow;
        background: Theme.surface;
        VerticalLayout {
            padding: 16px;
            spacing: 12px;
            Text { text: "Pagamento"; font-size: 14px; font-weight: 800; color: Theme.text-primary; }

            if !root.payment-picker-open: HorizontalLayout {
                spacing: 12px;
                PaymentChip { kind: root.data.payment-method-kind; width: 48px; height: 30px; y: (parent.height - 30px) / 2; }
                VerticalLayout {
                    horizontal-stretch: 1;
                    alignment: center;
                    spacing: 1px;
                    Text { text: root.data.payment-method-label; font-size: 13px; font-weight: 700; color: Theme.text-primary; overflow: elide; }
                    Text { text: root.data.payment-method-detail; font-size: 11px; color: Theme.text-secondary; overflow: elide; }
                }
                trocar-ta := TouchArea {
                    width: 64px; height: 30px;
                    y: (parent.height - 30px) / 2;
                    clicked => { root.open-payment-change(); }
                    Rectangle {
                        border-radius: 8px;
                        border-width: 1px;
                        border-color: Theme.card-border;
                        background: trocar-ta.has-hover ? Theme.row-hover : Theme.surface;
                        Text { width: parent.width; height: parent.height; text: "Trocar"; font-size: 12px; font-weight: 700; color: Theme.text-primary; horizontal-alignment: center; vertical-alignment: center; }
                    }
                }
            }

            if root.payment-picker-open: VerticalLayout {
                spacing: 8px;
                HorizontalLayout {
                    spacing: 6px;
                    Text { horizontal-stretch: 1; text: "FORMA DE PAGAMENTO"; font-size: 9px; font-weight: 800; letter-spacing: 1px; color: Theme.text-secondary; vertical-alignment: center; }
                    fechar-ta := TouchArea {
                        width: 50px; height: 18px;
                        clicked => { root.open-payment-change(); }
                        Text { width: parent.width; height: parent.height; text: "Fechar"; font-size: 11px; font-weight: 700; color: fechar-ta.has-hover ? Theme.primary-dark : Theme.primary; horizontal-alignment: right; vertical-alignment: center; }
                    }
                }
                for opt in root.payment-methods: opt-ta := TouchArea {
                    height: 36px;
                    clicked => { root.pick-payment-method(opt.id); }
                    Rectangle {
                        border-radius: 8px;
                        border-width: opt.is-active ? 2px : 1px;
                        border-color: opt.is-active ? Theme.primary : Theme.border;
                        background: opt-ta.has-hover ? Theme.row-hover : Theme.surface;
                        HorizontalLayout {
                            padding-left: 10px; padding-right: 10px;
                            spacing: 10px;
                            PaymentChip { kind: opt.kind; width: 44px; height: 22px; y: (parent.height - 22px) / 2; }
                            Text { horizontal-stretch: 1; text: opt.title; font-size: 12px; font-weight: 700; color: Theme.text-primary; vertical-alignment: center; overflow: elide; }
                            if opt.is-active: AssetIcon { width: 14px; height: 14px; icon-size: 14px; icon-color: Theme.primary; source: @image-url("../assets/icons/1.2/confirmar.svg"); }
                        }
                    }
                }
            }

            HorizontalLayout {
                spacing: 8px;
                Text { horizontal-stretch: 1; text: root.data.charge-line-label; font-size: 12px; color: Theme.text-secondary; vertical-alignment: center; overflow: elide; }
                Text { text: root.data.charge-line-amount; font-size: 12px; font-weight: 700; color: Theme.text-primary; vertical-alignment: center; }
            }
            Rectangle {
                height: 44px;
                border-radius: 10px;
                background: Theme.row-hover;
                HorizontalLayout {
                    padding-left: 14px; padding-right: 14px;
                    spacing: 8px;
                    Text { horizontal-stretch: 1; text: "Total / Mês"; font-size: 13px; font-weight: 700; color: Theme.text-primary; vertical-alignment: center; }
                    Text { text: root.data.monthly-display; font-size: 17px; font-weight: 800; color: Theme.sidebar-sel-bg; vertical-alignment: center; }
                }
            }
            // Planos semestral/anual: também mostra o TOTAL cobrado por
            // ciclo (não só o valor mensal).
            if root.data.current-plan-kind != "monthly": Rectangle {
                height: 44px;
                border-radius: 10px;
                background: Theme.row-hover;
                HorizontalLayout {
                    padding-left: 14px; padding-right: 14px;
                    spacing: 8px;
                    Text {
                        horizontal-stretch: 1;
                        text: root.data.current-plan-kind == "annual" ? "Total / Ano" : "Total / Semestre";
                        font-size: 13px; font-weight: 700; color: Theme.text-primary;
                        vertical-alignment: center;
                    }
                    Text {
                        text: root.data.charge-total-display;
                        font-size: 17px; font-weight: 800; color: Theme.sidebar-sel-bg;
                        vertical-alignment: center;
                    }
                }
            }
        }
    }

    // Botões: + Cartão (contorno) · + PIX Auto (marrom)
    HorizontalLayout {
        spacing: 10px;
        card-ta := TouchArea {
            horizontal-stretch: 1; height: 32px;
            clicked => { if root.data.card-active { root.cancel-card(); } else { root.open-card-modal(); } }
            Rectangle {
                border-radius: 8px;
                border-width: 1px;
                border-color: root.data.card-active ? #E53935 : Theme.border;
                background: card-ta.has-hover ? (root.data.card-active ? #FDECEA : #00000008) : Theme.surface;
                Text { width: parent.width; height: parent.height; text: root.data.card-active ? "Cancelar cartão" : "+ Cartão"; font-size: 12px; font-weight: 700; color: root.data.card-active ? #E53935 : Theme.text-primary; horizontal-alignment: center; vertical-alignment: center; }
            }
        }
        pixauto-ta := TouchArea {
            horizontal-stretch: 1; height: 32px;
            clicked => { if root.data.pix-auto-active { root.cancel-pix-auto(); } else { root.open-pix-auto(); } }
            Rectangle {
                border-radius: 8px;
                // "+ PIX Auto" = outline de destaque (estilo Relatórios);
                // "Cancelar PIX Auto" = outline vermelho (ação de cancelar).
                border-width: root.data.pix-auto-active ? 1px : 1.5px;
                border-color: root.data.pix-auto-active ? #E53935 : Theme.sidebar-sel-bg;
                background: pixauto-ta.has-hover ? Theme.row-hover
                    : (root.data.pix-auto-active ? Theme.surface : transparent);
                Text { width: parent.width; height: parent.height; text: root.data.pix-auto-active ? "Cancelar PIX Auto" : "+ PIX Auto"; font-size: 12px; font-weight: 700; color: root.data.pix-auto-active ? #E53935 : Theme.sidebar-sel-bg; horizontal-alignment: center; vertical-alignment: center; }
            }
        }
    }
}

// ── Coluna direita: escolher plano + faturas ───────────────────────
component RightPanel inherits VerticalLayout {
    in property <[PlanCardData]> plans;
    in property <[SubscriptionInvoiceRow]> invoices;
    callback choose-plan(string);
    callback download-invoice(string);
    callback download-all();
    callback pay-invoice(string);

    spacing: 18px;
    alignment: start;

    VerticalLayout {
        spacing: 6px;
        Text { text: "Escolher Plano"; font-size: 18px; font-weight: 800; color: Theme.text-primary; }
        Text { text: "Prazos maiores têm desconto. Recorrência automática."; font-size: 11px; color: Theme.text-secondary; }
    }
    HorizontalLayout {
        spacing: 14px;
        for p in root.plans: PlanCard {
            horizontal-stretch: 1;
            data: p;
            choose => { root.choose-plan(p.kind); }
        }
    }

    // Faturas & recibos (altura de conteúdo — a página rola).
    Rectangle {
        border-radius: 12px;
        border-width: 1px;
        border-color: Theme.card-border;
        drop-shadow-blur: 12px;
        drop-shadow-offset-y: 0px;
        drop-shadow-color: Theme.card-shadow;
        background: Theme.surface;
        VerticalLayout {
            spacing: 0;
            Rectangle {
                height: 60px;
                HorizontalLayout {
                    padding-left: 18px; padding-right: 18px;
                    spacing: 8px;
                    VerticalLayout {
                        horizontal-stretch: 1;
                        alignment: center;
                        spacing: 2px;
                        Text { text: "Faturas & Recibos"; font-size: 14px; font-weight: 800; color: Theme.text-primary; }
                        Text { text: "Cobranças recorrentes"; font-size: 11px; color: Theme.text-secondary; }
                    }
                    baixar-ta := TouchArea {
                        width: 140px; height: 32px;
                        y: (parent.height - 32px) / 2;
                        clicked => { root.download-all(); }
                        Rectangle {
                            border-radius: 8px;
                            border-width: 1px;
                            border-color: Theme.card-border;
                            background: baixar-ta.has-hover ? Theme.row-hover : Theme.surface;
                            HorizontalLayout {
                                alignment: center; spacing: 6px;
                                VerticalLayout { alignment: center; AssetIcon { width: 14px; height: 14px; icon-size: 14px; icon-color: Theme.text-primary; source: @image-url("../assets/icons/1.2/download.svg"); } }
                                Text { text: "Baixar Todos"; font-size: 12px; font-weight: 700; color: Theme.text-primary; vertical-alignment: center; }
                            }
                        }
                    }
                }
            }
            Rectangle {
                height: 34px;
                background: #00000005;
                HorizontalLayout {
                    padding-left: 18px; padding-right: 18px;
                    spacing: 14px;
                    Text { width: 120px; text: "DATA"; font-size: 10px; font-weight: 700; color: Theme.text-secondary; letter-spacing: 1px; vertical-alignment: center; }
                    Text { width: 120px; text: "FATURA"; font-size: 10px; font-weight: 700; color: Theme.text-secondary; letter-spacing: 1px; vertical-alignment: center; }
                    Text { horizontal-stretch: 1; min-width: 90px; text: "DESCRIÇÃO"; font-size: 10px; font-weight: 700; color: Theme.text-secondary; letter-spacing: 1px; vertical-alignment: center; }
                    Text { width: 120px; text: "MÉTODO"; font-size: 10px; font-weight: 700; color: Theme.text-secondary; letter-spacing: 1px; vertical-alignment: center; }
                    Text { width: 100px; text: "STATUS"; font-size: 10px; font-weight: 700; color: Theme.text-secondary; letter-spacing: 1px; vertical-alignment: center; }
                    Rectangle {
                        width: 110px; background: transparent;
                        Text { width: parent.width - 14px; height: parent.height; x: 0; text: "VALOR"; font-size: 10px; font-weight: 700; color: Theme.text-secondary; letter-spacing: 1px; horizontal-alignment: right; vertical-alignment: center; }
                    }
                    Rectangle { width: 72px; background: transparent; }
                    Rectangle { width: 56px; background: transparent; }
                }
            }
            for inv in root.invoices: InvoiceRow {
                data: inv;
                download => { root.download-invoice(inv.id); }
                pay => { root.pay-invoice(inv.id); }
            }
            if root.invoices.length == 0: Rectangle {
                height: 140px;
                EmptyState {
                    source: @image-url("../assets/empty/empty-charges.svg");
                    title: "Nenhuma fatura";
                    art-size: 120px;
                }
            }
        }
    }
}

export component SubscriptionPage inherits Rectangle {
    in property <SubscriptionData> data;
    in property <[PlanCardData]> plans;
    in property <[SubscriptionInvoiceRow]> invoices;

    in property <[PaymentMethodOption]> payment-methods;
    in property <bool> payment-picker-open;

    callback choose-plan(string);
    callback open-payment-change();
    callback pick-payment-method(string);
    callback open-card-modal();
    callback cancel-card();
    callback open-pix-auto();
    callback cancel-pix-auto();
    callback download-invoice(string);
    callback download-all();
    callback pay-invoice(string);

    background: transparent;
    // Abaixo deste limite as colunas empilham (nada é cortado).
    property <bool> narrow: self.width < 1180px;

    Flickable {
        x: 0; y: 0;
        width: parent.width;
        height: parent.height;
        viewport-width: self.width;
        viewport-height: box.preferred-height;
        box := VerticalLayout {
            width: parent.width;
            // Folga p/ o Flickable não recortar a sombra dos cards
            // (laterais e topo).
            padding: 12px;

            // ─ Largo: duas colunas ─
            if !root.narrow: HorizontalLayout {
                spacing: 18px;
                LeftPanel {
                    width: 360px;
                    data: root.data;
                    invoices: root.invoices;
                    payment-methods: root.payment-methods;
                    payment-picker-open: root.payment-picker-open;
                    pay-invoice(id) => { root.pay-invoice(id); }
                    open-payment-change => { root.open-payment-change(); }
                    pick-payment-method(id) => { root.pick-payment-method(id); }
                    open-card-modal => { root.open-card-modal(); }
                    cancel-card => { root.cancel-card(); }
                    open-pix-auto => { root.open-pix-auto(); }
                    cancel-pix-auto => { root.cancel-pix-auto(); }
                }
                RightPanel {
                    horizontal-stretch: 1;
                    plans: root.plans;
                    invoices: root.invoices;
                    choose-plan(k) => { root.choose-plan(k); }
                    download-invoice(id) => { root.download-invoice(id); }
                    download-all => { root.download-all(); }
                    pay-invoice(id) => { root.pay-invoice(id); }
                }
            }

            // ─ Estreito: empilhado (rola na vertical) ─
            if root.narrow: VerticalLayout {
                spacing: 18px;
                LeftPanel {
                    data: root.data;
                    invoices: root.invoices;
                    payment-methods: root.payment-methods;
                    payment-picker-open: root.payment-picker-open;
                    pay-invoice(id) => { root.pay-invoice(id); }
                    open-payment-change => { root.open-payment-change(); }
                    pick-payment-method(id) => { root.pick-payment-method(id); }
                    open-card-modal => { root.open-card-modal(); }
                    cancel-card => { root.cancel-card(); }
                    open-pix-auto => { root.open-pix-auto(); }
                    cancel-pix-auto => { root.cancel-pix-auto(); }
                }
                RightPanel {
                    plans: root.plans;
                    invoices: root.invoices;
                    choose-plan(k) => { root.choose-plan(k); }
                    download-invoice(id) => { root.download-invoice(id); }
                    download-all => { root.download-all(); }
                    pay-invoice(id) => { root.pay-invoice(id); }
                }
            }
        }
    }
}
