import { Theme } from "../theme.slint";
import { FormField, PasswordField } from "../components/form_fields.slint";
import { ActionBtn } from "../components/buttons.slint";

// ── Tela de login (split 50/50: marketing escuro | formulário claro) ─────────
// Regras aplicadas (AI_RULES.md §3, §8, §11):
// - UI sem lógica de negócio; autenticação delegada a `do-login`.
// - Divisão exata em metades via `width: parent.width / 2` (não usar
//   HorizontalLayout: o conteúdo grande da esquerda empurrava a
//   divisão e desalinhava as colunas).
// - `login-with-pin` é placeholder da entrada por PIN (futuro).
// - `subdomain` (rodapé) identifica o estabelecimento se já houve
//   login; `app-version` mostra só o número da versão.

export component LoginPage inherits Rectangle {
    in-out property <string> email;
    in-out property <string> password;
    in-out property <string> status;
    in-out property <bool> remember-me;
    in property <string> subdomain;
    in property <string> app-version;
    in property <bool> server-online;
    in property <string> server-last;
    callback do-login();
    callback login-with-pin();

    // ── Recuperação de senha ("esqueci a senha") ──────────────────
    // Passo: 0 = login · 1 = informar e-mail · 2 = informar código ·
    // 3 = definir nova senha (só aparece após o código ser validado).
    // O Rust preenche `recovery-status`/`recovery-step`.
    in-out property <int> recovery-step: 0;
    in-out property <string> recovery-email;
    in-out property <string> recovery-code;
    in-out property <string> recovery-new-password;
    in-out property <string> recovery-status;
    in property <bool> recovery-busy: false;
    callback forgot-request();   // passo 1 → envia o código pro e-mail
    callback verify-submit();    // passo 2 → valida o código (sem consumir)
    callback reset-submit();     // passo 3 → define a nova senha

    width: 100%;
    height: 100%;
    background: Theme.surface;

    // ── Painel esquerdo (metade esquerda exata) ─────────────────
    Rectangle {
        x: 0;
        y: 0;
        width: parent.width / 2;
        height: parent.height;
        // Mesma cor do menu lateral: marrom no tema claro,
        // #1A1A1A no tema escuro (Theme.sidebar-bg).
        background: Theme.sidebar-bg;

        VerticalLayout {
            padding: 48px;
            alignment: space-between;

            // Topo: logo do estabelecimento (apenas a imagem).
            HorizontalLayout {
                alignment: start;
                Image {
                    source: @image-url("../letaf-logo.png");
                    height: 46px;
                    width: self.height * self.source.width / max(1, self.source.height);
                    image-fit: contain;
                }
            }

            // Meio: chamada principal.
            VerticalLayout {
                spacing: 0;
                Text {
                    text: "OFFLINE-FIRST · MULTI-ESTAÇÃO";
                    font-size: 11.5px;
                    font-weight: Theme.fw-strong;
                    letter-spacing: 1.5px;
                    color: #8A8178;
                }
                Rectangle { height: 14px; }
                // Chamada em 3 linhas (branco / laranja / branco),
                // como no mockup, com entrelinha justa.
                Text {
                    text: "Sua operação,";
                    font-size: 52px;
                    font-weight: 800;
                    color: #FFFFFF;
                }
                Text {
                    text: "com ou sem";
                    font-size: 52px;
                    font-weight: 800;
                    color: Theme.primary;
                }
                Text {
                    text: "internet.";
                    font-size: 52px;
                    font-weight: 800;
                    color: #FFFFFF;
                }
                Rectangle { height: 22px; }
                Text {
                    text: "Vendas salvas localmente, sincronizadas em segundo plano. O sistema nunca trava, você nunca para.";
                    font-size: 15px;
                    color: #A89E94;
                    wrap: word-wrap;
                }
            }

            // Rodapé numa única linha: versão à esquerda, subdomínio
            // à direita (mesma posição do mockup).
            HorizontalLayout {
                Text {
                    text: root.app-version;
                    font-family: Theme.font-mono;
                    font-size: 12px;
                    color: #6E665F;
                    vertical-alignment: center;
                    horizontal-stretch: 1;
                }
                if root.subdomain != "": HorizontalLayout {
                    alignment: end;
                    spacing: 8px;
                    VerticalLayout {
                        alignment: center;
                        Rectangle {
                            width: 8px; height: 8px;
                            border-radius: 4px;
                            background: #4CAF50;
                        }
                    }
                    Text {
                        text: root.subdomain + ".letaf.app";
                        font-family: Theme.font-mono;
                        font-size: 12px;
                        color: #9A9189;
                        vertical-alignment: center;
                    }
                }
            }
        }
    }

    // ── Painel direito (metade direita exata) ───────────────────
    // Mesmo card centralizado tanto para LOGIN quanto para RECUPERAÇÃO —
    // só o conteúdo do formulário troca (mantém o padrão visual).
    Rectangle {
        x: parent.width / 2;
        y: 0;
        width: parent.width / 2;
        height: parent.height;
        background: Theme.surface;

        // ── LOGIN (recovery-step == 0) ──────────────────────────
        if root.recovery-step == 0: Rectangle {
            width: 360px;
            height: login-col.preferred-height;
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;

            login-col := VerticalLayout {
                spacing: 0;

                Text {
                    text: "ÁREA RESTRITA";
                    font-size: 11.5px;
                    font-weight: Theme.fw-strong;
                    letter-spacing: 1.5px;
                    color: Theme.text-secondary;
                }
                Rectangle { height: 8px; }
                Text {
                    text: "Entrar";
                    font-size: Theme.fs-page;
                    font-weight: Theme.fw-strong;
                    color: Theme.text-primary;
                }
                Rectangle { height: 6px; }
                Text {
                    text: "Use suas credenciais de administrador.";
                    font-size: 14px;
                    color: Theme.text-secondary;
                }

                Rectangle { height: 26px; }

                FormField {
                    label: "Email";
                    value <=> root.email;
                    placeholder: "usuario@email.com";
                    accepted => { root.do-login(); }
                }
                Rectangle { height: 12px; }
                PasswordField {
                    label: "Senha";
                    value <=> root.password;
                    placeholder: "Sua senha";
                    accepted => { root.do-login(); }
                }

                Rectangle { height: 12px; }

                HorizontalLayout {
                    spacing: 8px;
                    remember-ta := TouchArea {
                        horizontal-stretch: 1;
                        height: 20px;
                        clicked => { root.remember-me = !root.remember-me; }
                        HorizontalLayout {
                            spacing: 6px;
                            alignment: start;
                            Rectangle {
                                width: 18px; height: 18px;
                                border-radius: 4px;
                                border-width: 2px;
                                border-color: root.remember-me ? Theme.primary : Theme.border;
                                background: root.remember-me ? Theme.primary : transparent;
                                if root.remember-me: Path {
                                    x: (parent.width - 12px) / 2;
                                    y: (parent.height - 9px) / 2;
                                    width: 12px; height: 9px;
                                    viewbox-width: 12; viewbox-height: 9;
                                    stroke: white;
                                    stroke-width: 2px;
                                    fill: transparent;
                                    commands: "M1 4.5 L4.5 8 L11 1";
                                }
                            }
                            Text {
                                text: "Lembrar";
                                font-size: 13px;
                                color: Theme.text-secondary;
                                vertical-alignment: center;
                            }
                        }
                    }
                    forgot-ta := TouchArea {
                        width: forgot-lbl.preferred-width;
                        height: 20px;
                        clicked => {
                            root.recovery-email = root.email;
                            root.recovery-code = "";
                            root.recovery-new-password = "";
                            root.recovery-status = "";
                            root.recovery-step = 1;
                        }
                        forgot-lbl := Text {
                            text: "Esqueci a senha";
                            font-size: 13px;
                            color: forgot-ta.has-hover ? Theme.primary-dark : Theme.primary;
                            vertical-alignment: center;
                        }
                    }
                }

                Rectangle { height: 18px; }

                ActionBtn {
                    label: "Entrar";
                    bg-color: Theme.sidebar-sel-bg;
                    width: 100%;
                    height: 46px;
                    clicked => { root.do-login(); }
                }

                if root.status != "": Rectangle { height: 10px; }
                if root.status != "": Text {
                    text: root.status;
                    font-size: 12px;
                    font-weight: Theme.fw-strong;
                    color: #E65100;
                    wrap: word-wrap;
                    width: 100%;
                    horizontal-alignment: center;
                }

                Rectangle { height: 22px; }

                // Status do servidor abaixo do botão.
                HorizontalLayout {
                    alignment: center;
                    spacing: 7px;
                    VerticalLayout {
                        alignment: center;
                        Rectangle {
                            width: 7px; height: 7px;
                            border-radius: 4px;
                            background: root.server-online ? #4CAF50 : #C62828;
                        }
                    }
                    Text {
                        text: root.server-online
                            ? "Servidor Online"
                            : "Servidor Offline";
                        font-size: 12px;
                        color: Theme.text-secondary;
                        vertical-alignment: center;
                    }
                }
            }
        }

        // ── RECUPERAÇÃO DE SENHA (recovery-step > 0) ────────────
        // Mesmo card do login; passo 1 = e-mail, passo 2 = código + nova senha.
        if root.recovery-step > 0: Rectangle {
            width: 360px;
            height: rec-col.preferred-height;
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;

            rec-col := VerticalLayout {
                spacing: 0;

                Text {
                    text: "RECUPERAR ACESSO";
                    font-size: 11.5px;
                    font-weight: Theme.fw-strong;
                    letter-spacing: 1.5px;
                    color: Theme.text-secondary;
                }
                Rectangle { height: 8px; }
                Text {
                    text: root.recovery-step == 1 ? "Recuperar senha"
                        : (root.recovery-step == 2 ? "Confirmar código" : "Definir nova senha");
                    font-size: Theme.fs-page;
                    font-weight: Theme.fw-strong;
                    color: Theme.text-primary;
                }
                Rectangle { height: 6px; }
                Text {
                    text: root.recovery-step == 1
                        ? "Informe seu e-mail. Enviaremos um código de 6 dígitos."
                        : (root.recovery-step == 2
                            ? "Digite o código de 6 dígitos enviado ao seu e-mail."
                            : "Escolha a nova senha para a sua conta.");
                    font-size: 14px;
                    color: Theme.text-secondary;
                    wrap: word-wrap;
                }

                Rectangle { height: 26px; }

                if root.recovery-step == 1: FormField {
                    label: "Email";
                    value <=> root.recovery-email;
                    placeholder: "seu@email.com";
                    accepted => { root.forgot-request(); }
                }
                if root.recovery-step == 2: FormField {
                    label: "Código (6 dígitos)";
                    value <=> root.recovery-code;
                    placeholder: "000000";
                    accepted => { root.verify-submit(); }
                }
                if root.recovery-step == 3: PasswordField {
                    label: "Nova senha";
                    value <=> root.recovery-new-password;
                    placeholder: "Mínimo 6 caracteres";
                    accepted => { root.reset-submit(); }
                }

                Rectangle { height: 18px; }

                ActionBtn {
                    label: root.recovery-busy
                        ? "Aguarde..."
                        : (root.recovery-step == 1 ? "Enviar código"
                            : (root.recovery-step == 2 ? "Confirmar código" : "Redefinir senha"));
                    bg-color: Theme.sidebar-sel-bg;
                    width: 100%;
                    height: 46px;
                    clicked => {
                        if (root.recovery-step == 1) { root.forgot-request(); }
                        else if (root.recovery-step == 2) { root.verify-submit(); }
                        else { root.reset-submit(); }
                    }
                }

                if root.recovery-status != "": Rectangle { height: 10px; }
                if root.recovery-status != "": Text {
                    text: root.recovery-status;
                    font-size: 12px;
                    font-weight: Theme.fw-strong;
                    color: Theme.primary;
                    wrap: word-wrap;
                    width: 100%;
                    horizontal-alignment: center;
                }

                Rectangle { height: 22px; }

                // Voltar um passo (passo 1 → login). Mesma posição do
                // status do servidor no card de login.
                HorizontalLayout {
                    alignment: center;
                    back-ta := TouchArea {
                        width: back-lbl.preferred-width;
                        height: 22px;
                        clicked => {
                            root.recovery-step = root.recovery-step - 1;
                            root.recovery-status = "";
                        }
                        back-lbl := Text {
                            text: root.recovery-step == 1 ? "‹ Voltar ao login" : "‹ Voltar";
                            font-size: 13px;
                            color: back-ta.has-hover ? Theme.primary-dark : Theme.primary;
                            vertical-alignment: center;
                        }
                    }
                }
            }
        }
    }
}
