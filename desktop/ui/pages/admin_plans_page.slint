// Painel do super admin — Planos (catálogo). CRUD dos planos que as lojas
// veem/assinam. UI sem lógica (§1/§3): lista/salvar delegam ao Rust
// (rotas /admin/plans/*). A autoridade/validação é o backend (§11).
import { Theme } from "../theme.slint";
import { AdminPlanRow } from "../types.slint";
import { FormField, PasswordField } from "../components/form_fields.slint";
import { ActionBtn, OutlineBtn } from "../components/buttons.slint";
import { EmptyState } from "../components/empty_state.slint";

component Toggle inherits TouchArea {
    in property <bool> on;
    callback toggled();
    width: 46px; height: 26px;
    clicked => { root.toggled(); }
    Rectangle {
        border-radius: 13px;
        background: root.on ? Theme.sidebar-sel-bg : Theme.border;
        Rectangle {
            width: 20px; height: 20px; border-radius: 10px;
            background: white;
            x: root.on ? parent.width - self.width - 3px : 3px;
            y: (parent.height - self.height) / 2;
            animate x { duration: 120ms; easing: ease-in-out; }
        }
    }
}

export component AdminPlansPage inherits VerticalLayout {
    in property <[AdminPlanRow]> plans;
    in-out property <string> form-id;
    in-out property <string> form-name;
    in-out property <string> form-amount;
    in-out property <string> form-period;
    in-out property <string> form-trial;
    in-out property <string> form-description;
    in-out property <string> form-highlight;
    in-out property <bool> form-active;
    callback new-plan();
    callback edit-plan(string);
    callback save-plan();
    callback delete-plan(string);
    spacing: 12px;

    Text { text: "Planos"; font-size: 20px; font-weight: 800; color: Theme.text-primary; }
    Text {
        text: "Catálogo de planos que as lojas veem e assinam.";
        font-size: 13px; color: Theme.text-secondary;
    }

    HorizontalLayout {
        vertical-stretch: 1;
        spacing: 16px;

        // ── Lista ──
        Rectangle {
            horizontal-stretch: 1;
            background: Theme.surface;
            border-radius: 12px;
            border-width: 1px;
            border-color: Theme.card-border;
            drop-shadow-blur: 12px;
            drop-shadow-offset-y: 0px;
            drop-shadow-color: Theme.card-shadow;
            VerticalLayout {
                padding: 8px;
                if root.plans.length == 0: EmptyState {
                    source: @image-url("../assets/empty/invoice.svg");
                    title: "Nenhum plano";
                    subtitle: "Cadastre os planos da plataforma";
                    art-size: 130px;
                }
                for p in root.plans: Rectangle {
                    height: 72px;
                    Rectangle { x: 0; y: parent.height - 1px; width: parent.width; height: 1px; background: Theme.border; }
                    HorizontalLayout {
                        padding: 10px;
                        spacing: 10px;
                        VerticalLayout {
                            horizontal-stretch: 1;
                            alignment: center;
                            spacing: 2px;
                            HorizontalLayout {
                                spacing: 8px;
                                Text { text: p.name; font-size: 14px; font-weight: 700; color: Theme.text-primary; overflow: elide; }
                                if p.highlight-label != "": Rectangle {
                                    width: hl.preferred-width + 12px; height: 18px; border-radius: 9px;
                                    background: Theme.sidebar-sel-bg;
                                    hl := Text { x: 6px; text: p.highlight-label; font-size: 9px; font-weight: 700; color: white; vertical-alignment: center; }
                                }
                                if !p.active: Text { text: "inativo"; font-size: 10px; color: #C62828; vertical-alignment: center; }
                            }
                            Text {
                                text: p.amount-display + " a cada " + p.period-months + (p.period-months == 1 ? " mês" : " meses")
                                    + " · " + p.monthly-display + (p.trial-days > 0 ? " · " + p.trial-days + " dias grátis" : "");
                                font-size: 11px; color: Theme.text-secondary; overflow: elide;
                            }
                        }
                        VerticalLayout { alignment: center; OutlineBtn { label: "Editar"; clicked => { root.edit-plan(p.id); } } }
                        VerticalLayout { alignment: center; OutlineBtn { label: "Excluir"; btn-color: #C62828; clicked => { root.delete-plan(p.id); } } }
                    }
                }
            }
        }

        // ── Formulário ──
        Rectangle {
            width: 360px;
            background: Theme.surface;
            border-radius: 12px;
            border-width: 1px;
            border-color: Theme.card-border;
            drop-shadow-blur: 12px;
            drop-shadow-offset-y: 0px;
            drop-shadow-color: Theme.card-shadow;
            VerticalLayout {
                padding: 18px;
                spacing: 10px;
                alignment: start;
                Text {
                    text: root.form-id == "" ? "Novo plano" : "Editar plano";
                    font-size: 15px; font-weight: 700; color: Theme.text-primary;
                }
                FormField { label: "Nome"; value <=> root.form-name; placeholder: "Ex.: Mensal"; }
                HorizontalLayout {
                    spacing: 10px;
                    FormField { label: "Valor por ciclo (R$)"; value <=> root.form-amount; placeholder: "200,00"; }
                    FormField { label: "Período (meses)"; value <=> root.form-period; placeholder: "1"; }
                }
                FormField { label: "Dias grátis (trial)"; value <=> root.form-trial; placeholder: "0"; }
                FormField { label: "Descrição"; value <=> root.form-description; placeholder: "Cobrado todo mês"; }
                FormField { label: "Selo de destaque"; value <=> root.form-highlight; placeholder: "MELHOR VALOR (opcional)"; }
                HorizontalLayout {
                    spacing: 10px;
                    Text { text: "Ativo"; font-size: 13px; color: Theme.text-primary; vertical-alignment: center; horizontal-stretch: 1; }
                    Toggle { on: root.form-active; toggled => { root.form-active = !root.form-active; } }
                }
                HorizontalLayout {
                    spacing: 10px;
                    padding-top: 4px;
                    OutlineBtn { label: "Novo"; clicked => { root.new-plan(); } }
                    ActionBtn { label: "Salvar"; clicked => { root.save-plan(); } }
                }
            }
        }
    }
}
