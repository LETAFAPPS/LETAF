import { Theme } from "../theme.slint";
import { Card } from "../components/cards.slint";
import { OutlineBtn } from "../components/buttons.slint";
import { EmptyState } from "../components/empty_state.slint";

// ── Tela: PDV bloqueado (caixa fechado) ─────────────────────────────────────
//
// Renderizada no LUGAR do PdvPage quando `cash-blocked == true`.
// Implementada como página (e não modal overlay) porque overlays
// top-level que aparecem ao mesmo tempo em que a aba muda causavam
// panic "Recursion detected" no layout do Slint.
//
// AI_RULES.md §1, §3, §8, §14:
// - UI sem lógica de negócio; só renderiza e dispara `go-to-cash()`.
// - Reusa o `EmptyState` do sistema (ilustração + título + apoio) em vez de
//   reimplementar o layout — mesma linguagem visual das demais telas vazias.
// - Só arte do sistema: `assets/empty/empty-cash.svg`. NADA de emoji (a fonte
//   não os renderiza de forma consistente e o glifo saía quebrado).
// - O CTA replica o estilo das abas de Relatórios (contorno na cor de
//   destaque, sem preenchimento), sem ícone.

export component PdvBlockedView inherits Rectangle {
    callback go-to-cash();

    background: Theme.bg;

    VerticalLayout {
        alignment: center;
        HorizontalLayout {
            alignment: center;

            Card {
                width: 460px;
                border-radius: Theme.radius-3xl;

                VerticalLayout {
                    padding: 36px;
                    spacing: 24px;

                    // Ilustração + textos no padrão de estado vazio do sistema.
                    EmptyState {
                        source: @image-url("../assets/empty/empty-cash.svg");
                        art-size: 128px;
                        title: "Caixa fechado";
                        subtitle: "Para registrar vendas no PDV é necessário abrir o caixa.";
                    }

                    // Divisor sutil separando o conteúdo da ação.
                    Rectangle { height: 1px; background: Theme.border; }

                    // CTA no padrão das abas de Relatórios (contorno na cor de
                    // destaque, sem preencher) — modo `accent` do OutlineBtn.
                    HorizontalLayout {
                        alignment: center;
                        OutlineBtn {
                            label: "Ir para o Caixa";
                            accent: true;
                            btn-color: Theme.sidebar-sel-bg;
                            width: 200px;
                            height: 40px;
                            clicked => { root.go-to-cash(); }
                        }
                    }
                }
            }
        }
    }
}
