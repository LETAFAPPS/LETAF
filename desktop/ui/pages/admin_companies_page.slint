// Painel do administrador — Empresas (tenants) cross-tenant.
// UI sem lógica (§1/§3): a lista vem pronta do Rust (GET /admin/companies).
//
// Estrutura (a pedido): barra de busca + filtro (dropdown) + "+" num card
// próprio; a lista abaixo com UM CARD POR EMPRESA; e o cadastro numa TELA
// separada (alternada por `show-form`, sem sair da aba).
import { Theme } from "../theme.slint";
import { AdminCompanyRow } from "../types.slint";
import { AdminSearchBox, FilterDropdown, FilterOption, AddSquareBtn } from "../components/admin_filter_bar.slint";
import { FormField, PasswordField } from "../components/form_fields.slint";
import { ActionBtn, OutlineBtn } from "../components/buttons.slint";
import { EmptyState } from "../components/empty_state.slint";

// Traduz o status da assinatura para rótulo + cor.
component StatusBadge inherits Rectangle {
    in property <string> status;
    property <bool> active: root.status == "active";
    width: label.preferred-width + 20px;
    height: 22px;
    border-radius: 11px;
    background: root.active ? #2E7D3222 : #9E9E9E22;
    label := Text {
        x: 10px;
        text: root.active ? "Ativa" : (root.status == "none" ? "Sem plano" : "Cancelada");
        font-size: 11px; font-weight: 700;
        color: root.active ? #2E7D32 : Theme.text-secondary;
        vertical-alignment: center;
    }
}

// Card de UMA empresa na lista.
component CompanyCard inherits Rectangle {
    in property <AdminCompanyRow> c;
    callback open-detail();
    callback toggle-active();
    callback remove();

    height: 74px;
    background: Theme.surface;
    border-radius: 10px;
    border-width: 1px;
    border-color: Theme.card-border;
    drop-shadow-blur: 8px;
    drop-shadow-offset-y: 0px;
    drop-shadow-color: Theme.card-shadow;

    HorizontalLayout {
        padding-left: 16px; padding-right: 16px;
        spacing: 12px;

        // Identificação (nome clicável → detalhe) + subdomínio.
        VerticalLayout {
            horizontal-stretch: 3;
            alignment: center;
            spacing: 3px;
            HorizontalLayout {
                spacing: 6px;
                alignment: start;
                name-ta := TouchArea {
                    width: name-txt.preferred-width;
                    height: 20px;
                    clicked => { root.open-detail(); }
                    name-txt := Text {
                        text: root.c.name;
                        font-size: 14px; font-weight: 700;
                        color: name-ta.has-hover ? Theme.btn-accent
                            : (root.c.active ? Theme.text-primary : Theme.text-secondary);
                        overflow: elide; vertical-alignment: center;
                        width: parent.width; height: parent.height;
                    }
                }
                if !root.c.active: Rectangle {
                    width: susp.preferred-width + 12px; height: 18px;
                    border-radius: 5px;
                    background: Theme.danger.transparentize(0.85);
                    y: (parent.height - self.height) / 2;
                    susp := Text {
                        text: "Suspensa"; font-size: 10px; font-weight: 700;
                        color: Theme.danger;
                        horizontal-alignment: center; vertical-alignment: center;
                        width: parent.width; height: parent.height;
                    }
                }
            }
            Text {
                text: root.c.subdomain;
                font-size: 12px; color: Theme.text-secondary; overflow: elide;
            }
        }

        // Plano + status da assinatura.
        VerticalLayout {
            horizontal-stretch: 2;
            alignment: center;
            spacing: 4px;
            Text {
                text: root.c.plan == "monthly" ? "Mensal"
                    : (root.c.plan == "semestral" ? "Semestral"
                        : (root.c.plan == "annual" ? "Anual" : "Sem plano"));
                font-size: 12.5px; color: Theme.text-primary;
            }
            HorizontalLayout { alignment: start; StatusBadge { status: root.c.status; } }
        }

        // Data de criação.
        VerticalLayout {
            horizontal-stretch: 1;
            alignment: center;
            Text {
                text: "criada em " + root.c.created-at;
                font-size: 11.5px; color: Theme.text-secondary;
                horizontal-alignment: right;
            }
        }

        // Ações.
        VerticalLayout {
            alignment: center;
            toggle-ta := TouchArea {
                width: 104px; height: 30px;
                clicked => { root.toggle-active(); }
                Rectangle {
                    x: 0; y: 0; width: parent.width; height: parent.height;
                    border-radius: 8px;
                    border-width: 1.5px;
                    border-color: root.c.active ? #E65100 : #2E7D32;
                    background: toggle-ta.has-hover
                        ? (root.c.active ? #E6510022 : #2E7D3222)
                        : transparent;
                    Text {
                        text: root.c.active ? "Suspender" : "Reativar";
                        font-size: 12px; font-weight: 700;
                        color: root.c.active ? #E65100 : #2E7D32;
                        horizontal-alignment: center; vertical-alignment: center;
                        width: parent.width; height: parent.height;
                    }
                }
            }
        }
        VerticalLayout {
            alignment: center;
            del-ta := TouchArea {
                width: 30px; height: 30px;
                clicked => { root.remove(); }
                Rectangle {
                    x: 0; y: 0; width: parent.width; height: parent.height;
                    border-radius: 6px;
                    border-width: 1px;
                    border-color: del-ta.has-hover ? Theme.danger : transparent;
                    background: del-ta.has-hover ? #FFEBEE : transparent;
                    Text {
                        text: "\u{2715}";
                        font-size: 13px;
                        color: del-ta.has-hover ? Theme.danger : Theme.text-secondary;
                        horizontal-alignment: center; vertical-alignment: center;
                        width: parent.width; height: parent.height;
                    }
                }
            }
        }
    }
}

export component AdminCompaniesPage inherits VerticalLayout {
    in property <[AdminCompanyRow]> companies;
    // Formulário de cadastro de estabelecimento (empresa + admin + infos).
    in-out property <string> form-name;
    in-out property <string> form-subdomain;
    in-out property <string> form-admin-name;
    in-out property <string> form-admin-email;
    in-out property <string> form-admin-password;
    in-out property <string> form-phone;
    in-out property <string> form-whatsapp;
    in-out property <string> form-email;
    in-out property <string> form-document;
    in-out property <string> form-discount;
    in-out property <string> form-address;
    in-out property <string> form-neighborhood;
    in-out property <string> form-zip;
    in-out property <string> form-city;
    in-out property <string> form-uf;
    in property <image> logo-image;
    in property <image> cover-image;
    in property <bool> logo-loading;
    in property <bool> cover-loading;
    in property <bool> has-logo;
    in property <bool> has-cover;
    callback save-company();
    callback pick-logo();
    callback pick-cover();
    // Exclusão lógica de uma empresa (super admin). (id, nome)
    callback delete-company(string, string);
    // Suspender/reativar acesso do tenant. (id, novo-active)
    callback set-company-active(string, bool);
    // Abre o detalhe consolidado da empresa. (id)
    callback open-detail(string);
    // Busca/filtro (aplicados no Rust sobre a lista completa).
    in-out property <string> search;
    in-out property <string> filter: "all";
    callback filters-changed();

    // `true` = tela de cadastro; `false` = lista. Estado puro de UI (§3).
    property <bool> show-form: false;

    spacing: 12px;
    alignment: start;

    // ── Cabeçalho: título muda conforme a tela ──
    HorizontalLayout {
        spacing: 12px;
        VerticalLayout {
            horizontal-stretch: 1;
            spacing: 2px;
            Text {
                text: root.show-form ? "Nova empresa" : "Empresas";
                font-size: 20px; font-weight: 800; color: Theme.text-primary;
            }
            Text {
                text: root.show-form
                    ? "Cria a empresa, o administrador inicial e os dados do estabelecimento."
                    : root.companies.length + " empresa(s) cadastrada(s).";
                font-size: 13px; color: Theme.text-secondary;
            }
        }
        // Voltar para a lista (só na tela de cadastro).
        if root.show-form: VerticalLayout {
            alignment: center;
            OutlineBtn {
                label: "Voltar";
                neutral: true;
                width: 110px; height: 34px;
                clicked => { root.show-form = false; }
            }
        }
    }

    // ── Card da barra de ferramentas: busca + filtro + novo ──
    if !root.show-form: Rectangle {
        height: 56px;
        background: Theme.surface;
        border-radius: 10px;
        border-width: 1px;
        border-color: Theme.card-border;
        drop-shadow-blur: 8px;
        drop-shadow-offset-y: 0px;
        drop-shadow-color: Theme.card-shadow;
        HorizontalLayout {
            padding-left: 12px; padding-right: 12px;
            spacing: 10px;
            VerticalLayout {
                horizontal-stretch: 1;
                alignment: center;
                AdminSearchBox {
                    value <=> root.search;
                    placeholder: "Buscar por nome ou subdomínio...";
                    changed => { root.filters-changed(); }
                }
            }
            VerticalLayout {
                alignment: center;
                FilterDropdown {
                    options: [
                        { key: "all",       label: "Todas" },
                        { key: "active",    label: "Ativas" },
                        { key: "suspended", label: "Suspensas" },
                    ];
                    selected <=> root.filter;
                    label: root.filter == "active" ? "Ativas"
                        : (root.filter == "suspended" ? "Suspensas" : "Todas");
                    changed => { root.filters-changed(); }
                }
            }
            VerticalLayout {
                alignment: center;
                AddSquareBtn { clicked => { root.show-form = true; } }
            }
        }
    }

    // ── Lista: UM CARD POR EMPRESA ──
    if !root.show-form && root.companies.length == 0: EmptyState {
        source: @image-url("../assets/empty/not-found.svg");
        title: "Nenhuma empresa";
    }
    if !root.show-form && root.companies.length > 0: Flickable {
        vertical-stretch: 1;
        viewport-width: self.width;
        viewport-height: cards.preferred-height;
        cards := VerticalLayout {
            spacing: 8px;
            alignment: start;
            for c in root.companies: CompanyCard {
                c: c;
                open-detail => { root.open-detail(c.id); }
                toggle-active => { root.set-company-active(c.id, !c.active); }
                remove => { root.delete-company(c.id, c.name); }
            }
        }
    }

    // ── Tela de cadastro (rolável) ──
    if root.show-form: Rectangle {
        vertical-stretch: 1;
        background: Theme.surface;
        border-radius: 12px;
        border-width: 1px;
        border-color: Theme.card-border;
        drop-shadow-blur: 12px;
        drop-shadow-offset-y: 0px;
        drop-shadow-color: Theme.card-shadow;
        Flickable {
            viewport-width: self.width;
                    VerticalLayout {
                        padding: 18px;
                        spacing: 12px;
                        alignment: start;

                        // Identificação
                        FormField {
                            label: "Nome da empresa";
                            value <=> root.form-name;
                            placeholder: "Ex.: Padaria do Zé";
                        }
                        FormField {
                            label: "Subdomínio";
                            value <=> root.form-subdomain;
                            placeholder: "padaria-do-ze";
                        }
                        FormField {
                            label: "CNPJ / CPF";
                            value <=> root.form-document;
                            placeholder: "Somente números";
                        }
                        FormField {
                            label: "Desconto na mensalidade (R$/mês)";
                            value <=> root.form-discount;
                            placeholder: "0,00 — abatido do valor do plano";
                        }

                        // Imagens (logo + capa)
                        HorizontalLayout {
                            spacing: 12px;
                            VerticalLayout {
                                horizontal-stretch: 1;
                                spacing: 4px;
                                Text { text: "Logo"; font-size: 12px; font-weight: 600; color: Theme.text-secondary; }
                                logo-box := Rectangle {
                                    height: 76px;
                                    border-radius: 8px;
                                    border-width: 1px;
                                    border-color: Theme.card-border;
                                    background: Theme.row-alt;
                                    clip: true;
                                    if root.has-logo: Image { source: root.logo-image; image-fit: contain; width: 100%; height: 100%; }
                                    if !root.has-logo && !root.logo-loading: Text { text: "Selecionar"; font-size: 12px; color: Theme.text-secondary; }
                                    if root.logo-loading: Text { text: "..."; font-size: 14px; color: Theme.text-secondary; }
                                    TouchArea { clicked => { root.pick-logo(); } }
                                }
                            }
                            VerticalLayout {
                                horizontal-stretch: 1;
                                spacing: 4px;
                                Text { text: "Capa"; font-size: 12px; font-weight: 600; color: Theme.text-secondary; }
                                cover-box := Rectangle {
                                    height: 76px;
                                    border-radius: 8px;
                                    border-width: 1px;
                                    border-color: Theme.card-border;
                                    background: Theme.row-alt;
                                    clip: true;
                                    if root.has-cover: Image { source: root.cover-image; image-fit: cover; width: 100%; height: 100%; }
                                    if !root.has-cover && !root.cover-loading: Text { text: "Selecionar"; font-size: 12px; color: Theme.text-secondary; }
                                    if root.cover-loading: Text { text: "..."; font-size: 14px; color: Theme.text-secondary; }
                                    TouchArea { clicked => { root.pick-cover(); } }
                                }
                            }
                        }

                        // Contatos
                        Rectangle { height: 1px; background: Theme.border; }
                        Text {
                            text: "CONTATO";
                            font-size: 10px; font-weight: 700; letter-spacing: 1px; color: Theme.text-secondary;
                        }
                        FormField {
                            label: "Telefone";
                            value <=> root.form-phone;
                            placeholder: "(00) 0000-0000";
                        }
                        FormField {
                            label: "WhatsApp";
                            value <=> root.form-whatsapp;
                            placeholder: "(00) 00000-0000";
                        }
                        FormField {
                            label: "E-mail da empresa";
                            value <=> root.form-email;
                            placeholder: "contato@empresa.com";
                        }

                        // Localização
                        Rectangle { height: 1px; background: Theme.border; }
                        Text {
                            text: "LOCALIZAÇÃO";
                            font-size: 10px; font-weight: 700; letter-spacing: 1px; color: Theme.text-secondary;
                        }
                        FormField {
                            label: "Endereço";
                            value <=> root.form-address;
                            placeholder: "Rua e número";
                        }
                        FormField {
                            label: "Bairro";
                            value <=> root.form-neighborhood;
                            placeholder: "Bairro";
                        }
                        HorizontalLayout {
                            spacing: 10px;
                            FormField {
                                horizontal-stretch: 2;
                                label: "Cidade";
                                value <=> root.form-city;
                                placeholder: "Cidade";
                            }
                            FormField {
                                horizontal-stretch: 1;
                                label: "UF";
                                value <=> root.form-uf;
                                placeholder: "SP";
                            }
                        }
                        FormField {
                            label: "CEP";
                            value <=> root.form-zip;
                            placeholder: "00000-000";
                        }

                        // Administrador inicial
                        Rectangle { height: 1px; background: Theme.border; }
                        Text {
                            text: "ADMINISTRADOR INICIAL";
                            font-size: 10px; font-weight: 700; letter-spacing: 1px; color: Theme.text-secondary;
                        }
                        FormField {
                            label: "Nome";
                            value <=> root.form-admin-name;
                            placeholder: "Nome do responsável";
                        }
                        FormField {
                            label: "E-mail";
                            value <=> root.form-admin-email;
                            placeholder: "email@dominio.com";
                        }
                        PasswordField {
                            label: "Senha";
                            value <=> root.form-admin-password;
                            placeholder: "Defina uma senha";
                        }
                        HorizontalLayout {
                            padding-top: 4px;
                            ActionBtn {
                                label: "Cadastrar";
                                width: 100%;
                                clicked => { root.save-company(); }
                            }
                        }
                    }
        }
    }
}
