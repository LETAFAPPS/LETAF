// Painel do administrador — Empresas (tenants) cross-tenant.
// UI sem lógica (§1/§3): a lista vem pronta do Rust (GET /admin/companies).
//
// Estrutura (a pedido): barra de busca + filtro (dropdown) + "+" num card
// próprio; a lista abaixo com UM CARD POR EMPRESA; e o cadastro numa TELA
// separada (alternada por `show-form`, sem sair da aba).
import { Theme } from "../theme.slint";
import { AdminCompanyRow } from "../types.slint";
import { ListSearchBox, ListFilterBtn, FilterOption, ListAddBtn } from "../components/list_toolbar.slint";
import { FormField, PasswordField } from "../components/form_fields.slint";
import { ActionBtn, OutlineBtn } from "../components/buttons.slint";
import { EmptyState } from "../components/empty_state.slint";
import { AssetIcon } from "../components/icons.slint";
import { FormCard, ImagePicker } from "../components/form_card.slint";

// Traduz o status da assinatura para rótulo + cor.
component StatusBadge inherits Rectangle {
    in property <string> status;
    property <bool> active: root.status == "active";
    width: label.preferred-width + 20px;
    height: 22px;
    border-radius: 11px;
    background: root.active ? #2E7D3222 : #9E9E9E22;
    label := Text {
        x: 10px;
        text: root.active ? "Ativa" : (root.status == "none" ? "Sem plano" : "Cancelada");
        font-size: 11px; font-weight: 700;
        color: root.active ? #2E7D32 : Theme.text-secondary;
        vertical-alignment: center;
    }
}

// Card de UMA empresa na lista.
component CompanyCard inherits Rectangle {
    in property <AdminCompanyRow> c;
    callback open-detail();
    callback toggle-active();
    callback remove();

    height: 74px;
    background: Theme.surface;
    border-radius: 10px;
    border-width: 1px;
    border-color: Theme.card-border;
    drop-shadow-blur: 8px;
    drop-shadow-offset-y: 0px;
    drop-shadow-color: Theme.card-shadow;

    HorizontalLayout {
        padding-left: 16px; padding-right: 16px;
        spacing: 12px;

        // Identificação (nome clicável → detalhe) + subdomínio.
        VerticalLayout {
            horizontal-stretch: 3;
            alignment: center;
            spacing: 3px;
            HorizontalLayout {
                spacing: 6px;
                alignment: start;
                name-ta := TouchArea {
                    width: name-txt.preferred-width;
                    height: 20px;
                    clicked => { root.open-detail(); }
                    name-txt := Text {
                        text: root.c.name;
                        font-size: 14px; font-weight: 700;
                        color: name-ta.has-hover ? Theme.btn-accent
                            : (root.c.active ? Theme.text-primary : Theme.text-secondary);
                        overflow: elide; vertical-alignment: center;
                        width: parent.width; height: parent.height;
                    }
                }
                if !root.c.active: Rectangle {
                    width: susp.preferred-width + 12px; height: 18px;
                    border-radius: 5px;
                    background: Theme.danger.transparentize(0.85);
                    y: (parent.height - self.height) / 2;
                    susp := Text {
                        text: "Suspensa"; font-size: 10px; font-weight: 700;
                        color: Theme.danger;
                        horizontal-alignment: center; vertical-alignment: center;
                        width: parent.width; height: parent.height;
                    }
                }
            }
            Text {
                text: root.c.subdomain;
                font-size: 12px; color: Theme.text-secondary; overflow: elide;
            }
        }

        // Plano + status da assinatura.
        VerticalLayout {
            horizontal-stretch: 2;
            alignment: center;
            spacing: 4px;
            Text {
                text: root.c.plan == "monthly" ? "Mensal"
                    : (root.c.plan == "semestral" ? "Semestral"
                        : (root.c.plan == "annual" ? "Anual" : "Sem plano"));
                font-size: 12.5px; color: Theme.text-primary;
            }
            HorizontalLayout { alignment: start; StatusBadge { status: root.c.status; } }
        }

        // Data de criação.
        VerticalLayout {
            horizontal-stretch: 1;
            alignment: center;
            Text {
                text: "criada em " + root.c.created-at;
                font-size: 11.5px; color: Theme.text-secondary;
                horizontal-alignment: right;
            }
        }

        // Ações.
        VerticalLayout {
            alignment: center;
            toggle-ta := TouchArea {
                width: 104px; height: 30px;
                clicked => { root.toggle-active(); }
                Rectangle {
                    x: 0; y: 0; width: parent.width; height: parent.height;
                    border-radius: 8px;
                    border-width: 1.5px;
                    border-color: root.c.active ? #E65100 : #2E7D32;
                    background: toggle-ta.has-hover
                        ? (root.c.active ? #E6510022 : #2E7D3222)
                        : transparent;
                    Text {
                        text: root.c.active ? "Suspender" : "Reativar";
                        font-size: 12px; font-weight: 700;
                        color: root.c.active ? #E65100 : #2E7D32;
                        horizontal-alignment: center; vertical-alignment: center;
                        width: parent.width; height: parent.height;
                    }
                }
            }
        }
        VerticalLayout {
            alignment: center;
            del-ta := TouchArea {
                width: 30px; height: 30px;
                clicked => { root.remove(); }
                Rectangle {
                    x: 0; y: 0; width: parent.width; height: parent.height;
                    border-radius: 6px;
                    border-width: 1px;
                    border-color: del-ta.has-hover ? Theme.danger : transparent;
                    background: del-ta.has-hover ? #FFEBEE : transparent;
                    Text {
                        text: "\u{2715}";
                        font-size: 13px;
                        color: del-ta.has-hover ? Theme.danger : Theme.text-secondary;
                        horizontal-alignment: center; vertical-alignment: center;
                        width: parent.width; height: parent.height;
                    }
                }
            }
        }
    }
}

export component AdminCompaniesPage inherits VerticalLayout {
    in property <[AdminCompanyRow]> companies;
    // Formulário de cadastro de estabelecimento (empresa + admin + infos).
    in-out property <string> form-name;
    in-out property <string> form-subdomain;
    in-out property <string> form-admin-name;
    in-out property <string> form-admin-email;
    in-out property <string> form-admin-password;
    in-out property <string> form-phone;
    in-out property <string> form-whatsapp;
    in-out property <string> form-email;
    in-out property <string> form-document;
    in-out property <string> form-discount;
    in-out property <string> form-address;
    in-out property <string> form-neighborhood;
    in-out property <string> form-zip;
    in-out property <string> form-city;
    in-out property <string> form-uf;
    in property <image> logo-image;
    in property <image> cover-image;
    in property <bool> logo-loading;
    in property <bool> cover-loading;
    in property <bool> has-logo;
    in property <bool> has-cover;
    callback save-company();
    callback pick-logo();
    callback pick-cover();
    // Exclusão lógica de uma empresa (super admin). (id, nome)
    callback delete-company(string, string);
    // Suspender/reativar acesso do tenant. (id, novo-active)
    callback set-company-active(string, bool);
    // Abre o detalhe consolidado da empresa. (id)
    callback open-detail(string);
    // Busca/filtro (aplicados no Rust sobre a lista completa).
    in-out property <string> search;
    in-out property <string> filter: "all";
    callback filters-changed();
    /// CEP digitado: o Rust consulta o serviço de endereços e preenche
    /// cidade/UF. A busca NÃO vive na UI (§1/§3).
    callback cep-changed(string);
    in property <bool> cep-loading: false;

    // `true` = tela de cadastro; `false` = lista. Estado puro de UI (§3).
    property <bool> show-form: false;
    // `true` após a 1ª tentativa de salvar: só então mostramos os erros,
    // para o formulário não nascer todo vermelho.
    property <bool> tentou-salvar: false;

    // Máscara e verificação vêm do Rust (feedback de UX; §11 — backend é a
    // autoridade). O main.slint encaminha ao AdminState; puras para poderem
    // aparecer em expressões de propriedade.
    pure callback mask-field(string, string) -> string;   // (kind, valor)
    pure callback field-error(string, string) -> string;  // (regra, valor)

    // ── Verificação dos campos (erros só após a 1ª tentativa de salvar) ──
    property <string> err-name: root.tentou-salvar ? root.field-error("required", root.form-name) : "";
    property <string> err-subdomain: root.tentou-salvar ? root.field-error("subdomain", root.form-subdomain) : "";
    property <string> err-document: root.tentou-salvar ? root.field-error("document", root.form-document) : "";
    property <string> err-discount: root.tentou-salvar ? root.field-error("money", root.form-discount) : "";
    property <string> err-phone: root.tentou-salvar ? root.field-error("phone", root.form-phone) : "";
    property <string> err-whatsapp: root.tentou-salvar ? root.field-error("phone", root.form-whatsapp) : "";
    property <string> err-address: root.tentou-salvar ? root.field-error("required", root.form-address) : "";
    property <string> err-neighborhood: root.tentou-salvar ? root.field-error("required", root.form-neighborhood) : "";
    property <string> err-cep: root.tentou-salvar ? root.field-error("cep", root.form-zip) : "";
    property <string> err-city: root.tentou-salvar ? root.field-error("required", root.form-city) : "";
    property <string> err-uf: root.tentou-salvar ? root.field-error("uf", root.form-uf) : "";
    property <string> err-company-email: root.tentou-salvar ? root.field-error("email-opt", root.form-email) : "";
    property <string> err-admin-name: root.tentou-salvar ? root.field-error("required", root.form-admin-name) : "";
    property <string> err-admin-email: root.tentou-salvar ? root.field-error("email", root.form-admin-email) : "";
    property <string> err-admin-password: root.tentou-salvar ? root.field-error("password", root.form-admin-password) : "";
    property <bool> form-valido:
        root.err-name == "" && root.err-subdomain == "" && root.err-document == ""
        && root.err-discount == "" && root.err-phone == "" && root.err-whatsapp == ""
        && root.err-address == "" && root.err-neighborhood == "" && root.err-cep == ""
        && root.err-city == "" && root.err-uf == "" && root.err-company-email == ""
        && root.err-admin-name == "" && root.err-admin-email == "" && root.err-admin-password == "";

    spacing: 12px;
    alignment: start;

    // ── Cabeçalho ──
    // Na tela de cadastro, o "voltar" é só um ícone, ACIMA do título e
    // alinhado à esquerda (a pedido).
    if root.show-form: HorizontalLayout {
        alignment: start;
        back-ta := TouchArea {
            width: 30px; height: 30px;
            clicked => { root.show-form = false; }
            Rectangle {
                x: 0; y: 0; width: parent.width; height: parent.height;
                border-radius: 6px;
                background: back-ta.has-hover ? Theme.row-hover : transparent;
                AssetIcon {
                    width: parent.width; height: parent.height; icon-size: 17px;
                    icon-color: back-ta.has-hover ? Theme.btn-accent : Theme.text-secondary;
                    source: @image-url("../assets/icons/1.2/seta-esquerda.svg");
                }
            }
        }
    }
    VerticalLayout {
        spacing: 2px;
        Text {
            text: root.show-form ? "Nova empresa" : "Empresas";
            font-size: 20px; font-weight: 800; color: Theme.text-primary;
        }
        Text {
            text: root.show-form
                ? "Cria a empresa, o administrador inicial e os dados do estabelecimento."
                : root.companies.length + " Empresas Cadastradas.";
            font-size: 13px; color: Theme.text-secondary;
        }
    }

    // ── Card da barra de ferramentas: busca + filtro + novo ──
    if !root.show-form: Rectangle {
        height: 56px;
        background: Theme.surface;
        border-radius: 10px;
        border-width: 1px;
        border-color: Theme.card-border;
        drop-shadow-blur: 8px;
        drop-shadow-offset-y: 0px;
        drop-shadow-color: Theme.card-shadow;
        HorizontalLayout {
            padding-left: 12px; padding-right: 12px;
            spacing: 10px;
            VerticalLayout {
                horizontal-stretch: 1;
                alignment: center;
                ListSearchBox {
                    value <=> root.search;
                    placeholder: "Buscar por nome ou subdomínio...";
                    changed => { root.filters-changed(); }
                }
            }
            VerticalLayout {
                alignment: center;
                ListFilterBtn {
                    options: [
                        { key: "all",       label: "Todas" },
                        { key: "active",    label: "Ativas" },
                        { key: "suspended", label: "Suspensas" },
                    ];
                    selected <=> root.filter;
                    neutral-key: "all";
                    label: root.filter == "active" ? "Ativas"
                        : (root.filter == "suspended" ? "Suspensas" : "Todas");
                    changed => { root.filters-changed(); }
                }
            }
            VerticalLayout {
                alignment: center;
                ListAddBtn { clicked => { root.show-form = true; } }
            }
        }
    }

    // ── Lista: UM CARD POR EMPRESA ──
    // Empty state centralizado no espaço livre da tela.
    if !root.show-form && root.companies.length == 0: Rectangle {
        vertical-stretch: 1;
        VerticalLayout {
            alignment: center;
            EmptyState {
                source: @image-url("../assets/empty/not-found.svg");
                title: "Nenhuma empresa";
            }
        }
    }
    if !root.show-form && root.companies.length > 0: Flickable {
        vertical-stretch: 1;
        viewport-width: self.width;
        viewport-height: cards.preferred-height;
        cards := VerticalLayout {
            spacing: 8px;
            alignment: start;
            for c in root.companies: CompanyCard {
                c: c;
                open-detail => { root.open-detail(c.id); }
                toggle-active => { root.set-company-active(c.id, !c.active); }
                remove => { root.delete-company(c.id, c.name); }
            }
        }
    }

    // ── Tela de cadastro ──
    // Cada seção é um CARD próprio (a pedido); o botão de salvar fica FORA
    // dos cards, alinhado à direita.
    if root.show-form: Flickable {
        vertical-stretch: 1;
        viewport-width: self.width;
        viewport-height: form-col.preferred-height;
        form-col := VerticalLayout {
            spacing: 12px;
            alignment: start;

            // ── Card: identificação ──
            FormCard {
                title: "Identificação";
                VerticalLayout {
                    spacing: 10px;
                    HorizontalLayout {
                        spacing: 10px;
                        FormField {
                            horizontal-stretch: 1;
                            label: "Nome da empresa";
                            value <=> root.form-name;
                            placeholder: "Ex.: Padaria do Zé";
                            icon: @image-url("../assets/icons/1.2/app-maleta.svg");
                            error: root.err-name;
                        }
                        FormField {
                            horizontal-stretch: 1;
                            label: "Subdomínio";
                            value <=> root.form-subdomain;
                            placeholder: "padaria-do-ze";
                            icon: @image-url("../assets/icons/1.2/link.svg");
                            error: root.err-subdomain;
                            edited(v) => { root.form-subdomain = root.mask-field("subdomain", v); }
                        }
                    }
                    HorizontalLayout {
                        spacing: 10px;
                        FormField {
                            horizontal-stretch: 1;
                            label: "CNPJ / CPF";
                            value <=> root.form-document;
                            placeholder: "Somente números";
                            icon: @image-url("../assets/icons/1.2/arquivo.svg");
                            error: root.err-document;
                            force-end-cursor: true;
                            edited(v) => { root.form-document = root.mask-field("document", v); }
                        }
                        FormField {
                            horizontal-stretch: 1;
                            label: "Desconto na mensalidade (R$/mês)";
                            value <=> root.form-discount;
                            placeholder: "0,00 — abatido do plano";
                            icon: @image-url("../assets/icons/1.2/pay-moeda.svg");
                            error: root.err-discount;
                            force-end-cursor: true;
                            edited(v) => { root.form-discount = root.mask-field("money", v); }
                        }
                    }
                }
            }

            // ── Card: imagens ──
            FormCard {
                title: "Imagens";
                HorizontalLayout {
                    spacing: 12px;
                    ImagePicker {
                        horizontal-stretch: 1;
                        label: "Logo";
                        hint: "PNG, JPG ou WebP · quadrado (1:1)";
                        img: root.logo-image;
                        has-img: root.has-logo;
                        loading: root.logo-loading;
                        fit-contain: true;
                        clicked => { root.pick-logo(); }
                    }
                    ImagePicker {
                        horizontal-stretch: 1;
                        label: "Capa";
                        hint: "PNG, JPG ou WebP · panorâmica (16:9)";
                        img: root.cover-image;
                        has-img: root.has-cover;
                        loading: root.cover-loading;
                        fit-contain: false;
                        clicked => { root.pick-cover(); }
                    }
                }
            }

            // ── Card: contato ──
            FormCard {
                title: "Contato";
                VerticalLayout {
                    spacing: 10px;
                    HorizontalLayout {
                        spacing: 10px;
                        FormField {
                            horizontal-stretch: 1;
                            label: "Telefone";
                            value <=> root.form-phone;
                            placeholder: "(00) 0000-0000";
                            icon: @image-url("../assets/icons/1.2/telefone.svg");
                            error: root.err-phone;
                            force-end-cursor: true;
                            edited(v) => { root.form-phone = root.mask-field("phone", v); }
                        }
                        FormField {
                            horizontal-stretch: 1;
                            label: "WhatsApp";
                            value <=> root.form-whatsapp;
                            placeholder: "(00) 00000-0000";
                            icon: @image-url("../assets/icons/1.2/social-whatsapp.svg");
                            error: root.err-whatsapp;
                            force-end-cursor: true;
                            edited(v) => { root.form-whatsapp = root.mask-field("phone", v); }
                        }
                    }
                    FormField {
                        label: "E-mail da empresa";
                        value <=> root.form-email;
                        placeholder: "contato@empresa.com";
                        icon: @image-url("../assets/icons/1.2/email.svg");
                        error: root.err-company-email;
                    }
                }
            }

            // ── Card: localização ──
            FormCard {
                title: "Localização";
                VerticalLayout {
                    spacing: 10px;
                    FormField {
                        label: "Endereço";
                        value <=> root.form-address;
                        placeholder: "Rua e número";
                        icon: @image-url("../assets/icons/1.2/marcador.svg");
                        error: root.err-address;
                    }
                    HorizontalLayout {
                        spacing: 10px;
                        FormField {
                            horizontal-stretch: 2;
                            label: "Bairro";
                            value <=> root.form-neighborhood;
                            placeholder: "Bairro";
                            icon: @image-url("../assets/icons/1.2/marcador.svg");
                            error: root.err-neighborhood;
                        }
                        FormField {
                            horizontal-stretch: 1;
                            label: "CEP";
                            value <=> root.form-zip;
                            placeholder: "00000-000";
                            icon: @image-url("../assets/icons/1.2/marcador.svg");
                            error: root.err-cep;
                            force-end-cursor: true;
                            // Máscara + consulta de CEP (cidade/UF) no Rust (§1/§3).
                            edited(v) => {
                                root.form-zip = root.mask-field("cep", v);
                                root.cep-changed(root.form-zip);
                            }
                        }
                    }
                    HorizontalLayout {
                        spacing: 10px;
                        FormField {
                            horizontal-stretch: 2;
                            label: "Cidade";
                            value <=> root.form-city;
                            placeholder: root.cep-loading ? "Buscando…" : "Cidade";
                            icon: @image-url("../assets/icons/1.2/marcador.svg");
                            error: root.err-city;
                        }
                        FormField {
                            horizontal-stretch: 1;
                            label: "UF";
                            value <=> root.form-uf;
                            placeholder: "SP";
                            error: root.err-uf;
                        }
                    }
                }
            }

            // ── Card: administrador inicial ──
            FormCard {
                title: "Administrador inicial";
                subtitle: "Quem vai acessar o sistema desta empresa.";
                VerticalLayout {
                    spacing: 10px;
                    HorizontalLayout {
                        spacing: 10px;
                        FormField {
                            horizontal-stretch: 1;
                            label: "Nome";
                            value <=> root.form-admin-name;
                            placeholder: "Nome do responsável";
                            icon: @image-url("../assets/icons/1.2/usuario.svg");
                            error: root.err-admin-name;
                        }
                        FormField {
                            horizontal-stretch: 1;
                            label: "E-mail";
                            value <=> root.form-admin-email;
                            placeholder: "email@dominio.com";
                            icon: @image-url("../assets/icons/1.2/email.svg");
                            error: root.err-admin-email;
                        }
                    }
                    PasswordField {
                        label: "Senha";
                        value <=> root.form-admin-password;
                        placeholder: "Defina uma senha (mín. 8 caracteres)";
                    }
                    if root.err-admin-password != "": Text {
                        text: root.err-admin-password;
                        font-size: 11px; color: Theme.danger; wrap: word-wrap;
                    }
                }
            }

            // ── Ação: FORA dos cards, à direita, largura normal ──
            HorizontalLayout {
                padding-top: 2px;
                padding-bottom: 8px;
                alignment: end;
                ActionBtn {
                    label: "Cadastrar";
                    width: 140px; height: 40px;
                    clicked => {
                        root.tentou-salvar = true;
                        // Erros são só UX; o backend revalida (§11).
                        if root.form-valido { root.save-company(); }
                    }
                }
            }
        }
    }
}
