// Painel do administrador — trilha de auditoria (somente leitura).
// UI sem lógica (§1/§3): a lista vem pronta do Rust (GET /admin/audit).
import { Theme } from "../theme.slint";
import { AdminAuditRow } from "../types.slint";
import { EmptyState } from "../components/empty_state.slint";

export component AdminAuditPage inherits VerticalLayout {
    in property <[AdminAuditRow]> entries;
    spacing: 12px;

    Text {
        text: "Auditoria";
        font-size: 20px; font-weight: 800; color: Theme.text-primary;
    }
    Text {
        text: "Últimas ações do super admin (registro imutável).";
        font-size: 13px; color: Theme.text-secondary;
    }

    if root.entries.length == 0: EmptyState {
        source: @image-url("../assets/empty/not-found.svg");
        title: "Nenhuma ação registrada";
    }

    if root.entries.length > 0: Rectangle {
        vertical-stretch: 1;
        background: Theme.surface;
        border-radius: 12px;
        border-width: 1px;
        border-color: Theme.card-border;
        drop-shadow-blur: 12px;
        drop-shadow-offset-y: 0px;
        drop-shadow-color: Theme.card-shadow;
        VerticalLayout {
            padding: 8px;
            HorizontalLayout {
                padding: 10px;
                spacing: 12px;
                Text { text: "QUANDO"; width: 130px; font-size: 11px; font-weight: 700; color: Theme.text-secondary; }
                Text { text: "QUEM"; horizontal-stretch: 1; font-size: 11px; font-weight: 700; color: Theme.text-secondary; }
                Text { text: "AÇÃO"; horizontal-stretch: 1; font-size: 11px; font-weight: 700; color: Theme.text-secondary; }
                Text { text: "ALVO"; horizontal-stretch: 1; font-size: 11px; font-weight: 700; color: Theme.text-secondary; }
                Text { text: "DETALHES"; horizontal-stretch: 2; font-size: 11px; font-weight: 700; color: Theme.text-secondary; }
            }
            Rectangle { height: 1px; background: Theme.border; }
            Flickable {
                vertical-stretch: 1;
                viewport-height: rows.preferred-height;
                rows := VerticalLayout {
                    for e in root.entries: HorizontalLayout {
                        padding: 10px;
                        spacing: 12px;
                        Text { text: e.at; width: 130px; font-size: 12px; color: Theme.text-secondary; vertical-alignment: center; }
                        Text { text: e.actor; horizontal-stretch: 1; font-size: 12px; font-weight: 600; color: Theme.text-primary; overflow: elide; vertical-alignment: center; }
                        Text { text: e.action; horizontal-stretch: 1; font-size: 12px; font-weight: 700; color: Theme.btn-accent; overflow: elide; vertical-alignment: center; }
                        Text { text: e.target == "" ? "—" : e.target; horizontal-stretch: 1; font-size: 12px; color: Theme.text-primary; overflow: elide; vertical-alignment: center; }
                        Text { text: e.details == "" ? "—" : e.details; horizontal-stretch: 2; font-size: 12px; color: Theme.text-secondary; overflow: elide; vertical-alignment: center; }
                    }
                }
            }
        }
    }
}
