import { Theme } from "../theme.slint";
import { OutlineBtn } from "../components/buttons.slint";
import { ModalShell } from "../components/modal_shell.slint";

// ── Modal: confirmação de logout ──────────────────────────────────────────────
//
// Padrão do sistema (AI_RULES.md §3, §8): moldura via `ModalShell` + ações em
// `OutlineBtn` (a principal em `accent`, contorno na cor de destaque).

export component LogoutConfirmModal inherits Rectangle {
    callback close();
    callback do-logout();

    ModalShell {
        width: 100%;
        height: 100%;
        icon: @image-url("../assets/icons/1.2/logout.svg");
        title: "Sair da conta?";
        message: "Você será desconectado e precisará fazer login novamente.";
        card-width: 380px;
        close => { root.close(); }

        HorizontalLayout {
            alignment: center;
            spacing: 10px;

            OutlineBtn {
                label: "Cancelar";
                width: 120px; height: 40px;
                clicked => { root.close(); }
            }
            OutlineBtn {
                label: "Sair";
                accent: true;
                btn-color: Theme.sidebar-sel-bg;
                width: 120px; height: 40px;
                clicked => { root.close(); root.do-logout(); }
            }
        }
    }
}
