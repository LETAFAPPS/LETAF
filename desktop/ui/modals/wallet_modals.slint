import { Theme } from "../theme.slint";
import { AssetIcon } from "../components/icons.slint";
import { Card } from "../components/cards.slint";
import { ActionBtn, OutlineBtn } from "../components/buttons.slint";

// ── Modais da carteira do cliente ────────────────────────────────
//
// Quatro variações compartilham o mesmo esqueleto:
// - depósito (entrada de saldo)
// - saque (saída de saldo, respeita fiado)
// - ajuste manual (aceita +/-, exige justificativa)
// - definir limite de fiado
//
// Para evitar 4 arquivos quase idênticos eu encapsulei no componente
// `WalletFormModal` e exportei wrappers tipados (props/labels prontos).

component WalletFormModal inherits Rectangle {
    in property <string> title;
    in property <string> subtitle;
    in property <string> amount-label;       // "VALOR" | "AJUSTE (+/−)" | "LIMITE DE FIADO"
    in property <string> amount-placeholder; // "0,00"
    in property <bool>   require-notes;       // ajuste manual
    in property <string> confirm-label;       // "Depositar" | "Sacar" | …
    in-out property <string> amount;
    in-out property <string> notes;
    in property <string> error;

    callback close();
    callback confirm();

    background: #00000080;
    TouchArea { clicked => { root.close(); } }
    VerticalLayout {
        alignment: center;
        HorizontalLayout {
            alignment: center;
            Card {
                width: 440px;
                TouchArea { }

                VerticalLayout {
                    padding: 0px; spacing: 0px;

                    // Header
                    Rectangle {
                        background: Theme.surface;
                        VerticalLayout {
                            padding-left: 22px; padding-right: 18px;
                            padding-top: 18px; padding-bottom: 14px;
                            spacing: 4px;
                            HorizontalLayout {
                                spacing: 8px;
                                VerticalLayout {
                                    horizontal-stretch: 1; spacing: 2px;
                                    Text { text: root.title; font-size: 16px; font-weight: 700; color: Theme.text-primary; }
                                    Text { text: root.subtitle; font-size: 11px; color: Theme.text-secondary; }
                                }
                            }
                        }
                    }

                    // Body
                    Rectangle {
                        background: Theme.bg;
                        VerticalLayout {
                            padding: 18px; spacing: 14px;

                            // Amount
                            VerticalLayout {
                                spacing: 6px;
                                Text {
                                    text: root.amount-label;
                                    font-size: 11px; font-weight: 700;
                                    color: Theme.text-secondary;
                                    letter-spacing: 0.5px;
                                }
                                Rectangle {
                                    height: 44px;
                                    border-radius: 8px;
                                    border-width: 1px;
                                    border-color: amount-input.has-focus ? Theme.primary : Theme.border;
                                    background: Theme.surface;
                                    amount-input := TextInput {
                                        x: 12px; y: 0;
                                        width: parent.width - 24px;
                                        height: parent.height;
                                        text <=> root.amount;
                                        font-size: 16px; font-weight: 700;
                                        color: Theme.text-primary;
                                        vertical-alignment: center;
                                        single-line: true;
                                    }
                                    if amount-input.text == "" && !amount-input.has-focus: Text {
                                        x: 12px; y: 0;
                                        height: parent.height;
                                        text: root.amount-placeholder;
                                        font-size: 16px;
                                        color: Theme.text-secondary;
                                        vertical-alignment: center;
                                    }
                                }
                            }

                            // Notes (sempre visível; obrigatória só no ajuste)
                            VerticalLayout {
                                spacing: 6px;
                                Text {
                                    text: root.require-notes ? "JUSTIFICATIVA" : "OBSERVAÇÃO";
                                    font-size: 11px; font-weight: 700;
                                    color: Theme.text-secondary;
                                    letter-spacing: 0.5px;
                                }
                                Rectangle {
                                    height: 64px;
                                    border-radius: 8px;
                                    border-width: 1px;
                                    border-color: notes-input.has-focus ? Theme.primary : Theme.border;
                                    background: Theme.surface;
                                    notes-input := TextInput {
                                        x: 12px; y: 8px;
                                        width: parent.width - 24px;
                                        height: parent.height - 16px;
                                        text <=> root.notes;
                                        font-size: 13px;
                                        color: Theme.text-primary;
                                        wrap: word-wrap;
                                        single-line: false;
                                    }
                                    if notes-input.text == "" && !notes-input.has-focus: Text {
                                        x: 12px; y: 8px;
                                        text: root.require-notes
                                            ? "Explique o motivo do ajuste"
                                            : "Anotações internas";
                                        font-size: 13px;
                                        color: Theme.text-secondary;
                                    }
                                }
                            }

                            if root.error != "": Rectangle {
                                background: #FFEBEE;
                                border-radius: 8px;
                                height: 36px;
                                Text {
                                    x: 12px; y: 0;
                                    width: parent.width - 24px; height: parent.height;
                                    text: root.error;
                                    font-size: 12px; color: #C62828;
                                    vertical-alignment: center;
                                    wrap: word-wrap;
                                }
                            }
                        }
                    }

                    // Footer
                    Rectangle {
                        background: Theme.surface;
                        VerticalLayout {
                            padding-left: 18px; padding-right: 18px;
                            padding-top: 14px; padding-bottom: 14px;
                            HorizontalLayout {
                                spacing: 10px;
                                alignment: end;
                                ActionBtn {
                                    label: root.confirm-label;
                                    clicked => { root.confirm(); }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}

// ── Wrappers tipados ──

export component WalletDepositModal inherits WalletFormModal {
    title: "Depositar Saldo";
    subtitle: "Adiciona crédito na carteira do cliente";
    amount-label: "VALOR DEPOSITADO";
    amount-placeholder: "0,00";
    require-notes: false;
    confirm-label: "Depositar";
}

export component WalletWithdrawModal inherits WalletFormModal {
    title: "Sacar da Carteira";
    subtitle: "Retira saldo · respeita limite de fiado";
    amount-label: "VALOR SACADO";
    amount-placeholder: "0,00";
    require-notes: false;
    confirm-label: "Sacar";
}

export component WalletAdjustModal inherits WalletFormModal {
    title: "Ajuste Manual";
    subtitle: "Use valor negativo para reduzir o saldo (auditoria)";
    amount-label: "AJUSTE (+/−)";
    amount-placeholder: "0,00";
    require-notes: true;
    confirm-label: "Aplicar";
}

export component WalletLimitModal inherits WalletFormModal {
    title: "Definir limite de fiado";
    subtitle: "Quanto o cliente pode ficar devendo";
    amount-label: "LIMITE";
    amount-placeholder: "0,00";
    require-notes: false;
    confirm-label: "Salvar";
}
