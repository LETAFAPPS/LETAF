import { ScrollView } from "std-widgets.slint";
import { AssetIcon } from "../components/icons.slint";
import { Theme } from "../theme.slint";
import { Card } from "../components/cards.slint";
import { ActionBtn, OutlineBtn } from "../components/buttons.slint";
import { EmptyState } from "../components/empty_state.slint";
import { PdvCustomerRow } from "../types.slint";

// ── Modal: selecionar cliente no PDV ──────────────────────────────
//
// Lista buscável de clientes. Filtra por nome, telefone e documento
// (CPF/CNPJ). Operador clica numa linha → seta `pdv-customer-id` e
// `pdv-customer-name` em Rust + fecha o modal.

export component PdvCustomerPickerModal inherits Rectangle {
    in property <[PdvCustomerRow]> rows;
    in-out property <string> search;

    callback close();
    callback search-changed(string);
    callback pick(string);

    background: #00000080;
    TouchArea { clicked => { root.close(); } }

    VerticalLayout {
        alignment: center;
        HorizontalLayout {
            alignment: center;
            Card {
                width: 460px;
                height: 540px;
                TouchArea { }

                VerticalLayout {
                    padding: 0px;
                    spacing: 0px;

                    // Header
                    Rectangle {
                        background: Theme.surface;
                        VerticalLayout {
                            padding-left: 22px; padding-right: 22px;
                            padding-top: 18px; padding-bottom: 14px;
                            HorizontalLayout {
                                spacing: 8px;
                                VerticalLayout {
                                    horizontal-stretch: 1; spacing: 2px;
                                    Text {
                                        text: "Selecionar Cliente";
                                        font-size: 16px; font-weight: 700;
                                        color: Theme.text-primary;
                                    }
                                    Text {
                                        text: "Busque por nome, telefone ou documento.";
                                        font-size: 11px; color: Theme.text-secondary;
                                    }
                                }
                                close-ta := TouchArea {
                                    width: 28px; height: 28px;
                                    clicked => { root.close(); }
                                    Rectangle {
                                        border-radius: 4px;
                                        background: close-ta.has-hover ? Theme.row-hover : transparent;
                                        HorizontalLayout {
                                            alignment: center;
                                            VerticalLayout {
                                                alignment: center;
                                                AssetIcon { width: 14px; height: 14px; icon-size: 14px; icon-color: Theme.text-secondary; source: @image-url("../assets/icons/1.2/fechar.svg"); }
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }

                    // Busca + lista
                    Rectangle {
                        background: Theme.bg;
                        vertical-stretch: 1;
                        VerticalLayout {
                            padding: 14px;
                            spacing: 10px;
                            Rectangle {
                                height: 36px;
                                border-radius: 6px;
                                border-width: 1px;
                                border-color: search-input.has-focus ? Theme.primary : Theme.border;
                                background: Theme.surface;
                                search-input := TextInput {
                                    x: 10px; y: 0;
                                    width: parent.width - 20px;
                                    height: parent.height;
                                    text <=> root.search;
                                    font-size: 13px; color: Theme.text-primary;
                                    vertical-alignment: center;
                                    single-line: true;
                                    edited => { root.search-changed(self.text); }
                                }
                                if root.search == "": Text {
                                    x: 10px; y: 0; height: parent.height;
                                    text: "Buscar…";
                                    font-size: 13px; color: #BDBDBD;
                                    vertical-alignment: center;
                                }
                                Timer {
                                    interval: 80ms;
                                    running: true;
                                    triggered => {
                                        search-input.focus();
                                        self.running = false;
                                    }
                                }
                            }
                            // Sem card revestindo: a lista é composta só
                            // pelos cards de cada cliente (cada um com o
                            // próprio contorno).
                            Rectangle {
                                vertical-stretch: 1;
                                background: transparent;
                                if root.rows.length == 0: VerticalLayout {
                                    padding: 18px;
                                    EmptyState {
                                        source: @image-url("../assets/empty/not-found.svg");
                                        title: "Nenhum cliente";
                                        art-size: 120px;
                                    }
                                }
                                if root.rows.length > 0: ScrollView { vertical-scrollbar-policy: ScrollBarPolicy.always-off; horizontal-scrollbar-policy: ScrollBarPolicy.always-off;
                                    VerticalLayout {
                                        alignment: start;
                                        spacing: 8px;
                                        for c in root.rows: row-ta := TouchArea {
                                            height: 54px;
                                            clicked => { root.pick(c.id); }
                                            Rectangle {
                                                border-radius: 8px;
                                                border-width: 1px;
                                                border-color: row-ta.has-hover ? Theme.primary : Theme.border;
                                                background: row-ta.has-hover ? Theme.row-hover : Theme.surface;
                                                HorizontalLayout {
                                                    padding-left: 12px; padding-right: 12px;
                                                    spacing: 10px;
                                                    VerticalLayout {
                                                        horizontal-stretch: 1; alignment: center;
                                                        spacing: 1px;
                                                        Text {
                                                            text: c.name;
                                                            font-size: 13px; font-weight: 600;
                                                            color: Theme.text-primary;
                                                            overflow: elide;
                                                        }
                                                        Text {
                                                            text: c.phone != "" ? c.phone : (c.document != "" ? c.document : "—");
                                                            font-size: 11px;
                                                            color: Theme.text-secondary;
                                                        }
                                                    }
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}
