import { Theme } from "../theme.slint";
import { Card } from "../components/cards.slint";
import { ActionBtn, OutlineBtn } from "../components/buttons.slint";

// ── Modal: confirmação de exclusão ────────────────────────────────────────────

export component DeleteConfirmModal inherits Rectangle {
    in-out property <string> delete-target-name;

    callback close();
    callback confirm-delete();

    background: #00000060;

    TouchArea { clicked => { root.close(); } }

    VerticalLayout {
        alignment: center;
        HorizontalLayout {
            alignment: center;
            Card {
                width: 380px;
                TouchArea { }

                VerticalLayout {
                    padding: 24px;
                    spacing: 16px;

                    Text {
                        text: "Confirmar Exclusão";
                        font-size: 18px; font-weight: 700;
                        color: Theme.text-primary;
                        horizontal-alignment: center;
                    }

                    Rectangle { height: 1px; background: Theme.border; }

                    Text {
                        text: "Deseja excluir '" + root.delete-target-name + "'?";
                        font-size: 14px;
                        color: Theme.text-secondary;
                        wrap: word-wrap;
                        horizontal-alignment: center;
                    }

                    Text {
                        text: "Esta ação não pode ser desfeita.";
                        font-size: 12px; color: Theme.danger;
                        horizontal-alignment: center;
                    }

                    Rectangle { height: 4px; }

                    HorizontalLayout {
                        alignment: center;
                        spacing: 10px;
                        OutlineBtn { label: "Cancelar"; width: 110px; clicked => { root.close(); } }
                        ActionBtn {
                            label: "Excluir"; bg-color: Theme.danger; text-color: white; width: 110px;
                            clicked => { root.confirm-delete(); root.close(); }
                        }
                    }
                }
            }
        }
    }
}
