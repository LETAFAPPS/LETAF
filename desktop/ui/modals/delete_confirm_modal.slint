import { Theme } from "../theme.slint";
import { OutlineBtn } from "../components/buttons.slint";
import { ModalShell } from "../components/modal_shell.slint";

// ── Modal: confirmação de exclusão ────────────────────────────────────────────
//
// Padrão do sistema (AI_RULES.md §3, §8): moldura via `ModalShell` (overlay,
// card, ícone do sistema, título, mensagem, divisor) + ações em `OutlineBtn`.
// Ação destrutiva em `Theme.danger`; nada de emoji nem cor hardcoded.

export component DeleteConfirmModal inherits Rectangle {
    in-out property <string> delete-target-name;

    callback close();
    callback confirm-delete();

    ModalShell {
        width: 100%;
        height: 100%;
        icon: @image-url("../assets/icons/1.2/lixeira.svg");
        icon-color: Theme.danger;
        title: "Confirmar exclusão";
        message: "Deseja excluir '" + root.delete-target-name + "'? Esta ação não pode ser desfeita.";
        card-width: 400px;
        close => { root.close(); }

        HorizontalLayout {
            alignment: center;
            spacing: 10px;

            OutlineBtn {
                label: "Excluir";
                accent: true;
                btn-color: Theme.danger;
                width: 120px; height: 40px;
                clicked => { root.confirm-delete(); root.close(); }
            }
        }
    }
}
