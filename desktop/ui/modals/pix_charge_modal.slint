import { Theme } from "../theme.slint";
import { AssetIcon } from "../components/icons.slint";
import { Card } from "../components/cards.slint";
import { ActionBtn, OutlineBtn } from "../components/buttons.slint";
import { PixChargeView } from "../types.slint";

// ── Modal: cobrança PIX (Fase 14 — Efi) ──────────────────────────
//
// Regras aplicadas (AI_RULES.md §1, §14):
// - Apenas mostra a `PixChargeView` populada pelo Rust.
// - "Copiar" e "Fechar" disparam callbacks; quem decide o que fazer
//   é a camada Rust (e o gateway via polling).
export component PixChargeModal inherits Rectangle {
    in property <PixChargeView> data;
    /// PNG do QR Code decodificado no Rust. Vazio enquanto a
    /// cobrança está em loading/error.
    in property <image> qr-code-image;

    callback close();
    callback copy-code();

    background: #00000080;

    TouchArea {
        clicked => { root.close(); }
    }

    VerticalLayout {
        alignment: center;
        HorizontalLayout {
            alignment: center;
            Card {
                width: 460px;
                TouchArea { }
                VerticalLayout {
                    padding: 26px;
                    spacing: 14px;

                    // Header
                    HorizontalLayout {
                        VerticalLayout {
                            horizontal-stretch: 1;
                            spacing: 2px;
                            Text {
                                text: "Pagar com PIX";
                                font-size: 18px; font-weight: 800;
                                color: Theme.text-primary;
                            }
                            Text {
                                text: "Aponte a câmera do app do banco para o QR Code";
                                font-size: 11px;
                                color: Theme.text-secondary;
                            }
                        }
                        TouchArea {
                            width: 28px; height: 28px;
                            clicked => { root.close(); }
                            property <bool> hov: self.has-hover;
                            Rectangle {
                                border-radius: 6px;
                                background: parent.hov ? #f0f0f0 : transparent;
                                AssetIcon { width: 16px; height: 16px; icon-size: 16px; icon-color: Theme.text-secondary; source: @image-url("../assets/icons/1.2/fechar.svg"); }
                            }
                        }
                    }

                    Rectangle { height: 1px; background: Theme.border; }

                    // Conteúdo conforme o estado da cobrança.
                    if root.data.kind == "loading": Rectangle {
                        height: 200px;
                        Text {
                            width: parent.width; height: parent.height;
                            text: "Gerando cobrança…";
                            font-size: 13px;
                            color: Theme.text-secondary;
                            horizontal-alignment: center; vertical-alignment: center;
                        }
                    }

                    if root.data.kind == "ready": VerticalLayout {
                        spacing: 14px;

                        // QR Code (PNG decodificado pelo Rust). Slint
                        // não consome data-URL base64 direto, então a
                        // imagem chega via property `qr-code-image`.
                        Rectangle {
                            height: 220px;
                            border-radius: 8px;
                            border-width: 1px;
                            border-color: Theme.card-border;
                            drop-shadow-blur: 12px;
                            drop-shadow-offset-y: 0px;
                            drop-shadow-color: Theme.card-shadow;
                            background: white;
                            Image {
                                width: 200px; height: 200px;
                                x: (parent.width - self.width) / 2;
                                y: (parent.height - self.height) / 2;
                                source: root.qr-code-image;
                                image-fit: contain;
                            }
                        }

                        // Valor
                        HorizontalLayout {
                            spacing: 6px;
                            Text {
                                text: "Valor:";
                                font-size: 12px;
                                color: Theme.text-secondary;
                                vertical-alignment: center;
                            }
                            Text {
                                horizontal-stretch: 1;
                                text: root.data.amount-display;
                                font-size: 14px; font-weight: 800;
                                color: Theme.text-primary;
                                vertical-alignment: center;
                            }
                        }

                        // Copia-cola truncado (clique para copiar)
                        Rectangle {
                            height: 56px;
                            border-radius: 6px;
                            border-width: 1px;
                            border-color: Theme.card-border;
                            drop-shadow-blur: 12px;
                            drop-shadow-offset-y: 0px;
                            drop-shadow-color: Theme.card-shadow;
                            background: #FAFAFA;
                            HorizontalLayout {
                                padding-left: 10px; padding-right: 10px;
                                spacing: 8px;
                                Text {
                                    horizontal-stretch: 1;
                                    text: root.data.pix-copia-cola;
                                    font-size: 11px;
                                    color: Theme.text-primary;
                                    vertical-alignment: center;
                                    overflow: elide;
                                }
                                copy-ta := TouchArea {
                                    width: 90px; height: 32px;
                                    y: (parent.height - 36px) / 2;
                                    clicked => { root.copy-code(); }
                                    Rectangle {
                                        border-radius: 6px;
                                        background: copy-ta.has-hover ? Theme.primary-dark : Theme.primary;
                                        Text {
                                            width: parent.width; height: parent.height;
                                            text: "Copiar";
                                            font-size: 12px; font-weight: 700;
                                            color: white;
                                            horizontal-alignment: center; vertical-alignment: center;
                                        }
                                    }
                                }
                            }
                        }

                        Text {
                            text: "Após pagar, o status atualiza automaticamente em segundos.";
                            font-size: 10px;
                            color: Theme.text-secondary;
                            horizontal-alignment: center;
                        }
                    }

                    if root.data.kind == "paid": VerticalLayout {
                        spacing: 8px;
                        Rectangle {
                            height: 64px;
                            border-radius: 8px;
                            background: #E8F5E9;
                            Text {
                                width: parent.width; height: parent.height;
                                text: "✓ Pagamento confirmado!";
                                font-size: 16px; font-weight: 800;
                                color: #2E7D32;
                                horizontal-alignment: center; vertical-alignment: center;
                            }
                        }
                        Text {
                            text: "A fatura foi marcada como paga.";
                            font-size: 12px;
                            color: Theme.text-secondary;
                            horizontal-alignment: center;
                        }
                    }

                    if root.data.kind == "error": VerticalLayout {
                        spacing: 8px;
                        Rectangle {
                            height: 64px;
                            border-radius: 8px;
                            background: #FFEBEE;
                            Text {
                                width: parent.width; height: parent.height;
                                text: "Não foi possível gerar a cobrança";
                                font-size: 14px; font-weight: 800;
                                color: #C62828;
                                horizontal-alignment: center; vertical-alignment: center;
                            }
                        }
                        Text {
                            text: root.data.message;
                            font-size: 11px;
                            color: Theme.text-secondary;
                            horizontal-alignment: center;
                            wrap: word-wrap;
                        }
                    }

                    Rectangle { height: 4px; }

                    HorizontalLayout {
                        alignment: end;
                        OutlineBtn {
                            label: root.data.kind == "paid" ? "Fechar" : "Cancelar";
                            width: 120px;
                            clicked => { root.close(); }
                        }
                    }
                }
            }
        }
    }
}
