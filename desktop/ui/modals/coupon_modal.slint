import { ScrollView } from "std-widgets.slint";
import { AssetIcon } from "../components/icons.slint";
import { Theme } from "../theme.slint";
import { Card } from "../components/cards.slint";
import { FormField } from "../components/form_fields.slint";
import { ActionBtn, OutlineBtn } from "../components/buttons.slint";

// ── Pill de seleção (tipo de cupom / tipo de desconto) ────────────
component TypePill inherits TouchArea {
    in property <string> label;
    in property <bool> active: false;
    in property <length> pill-width: 120px;
    height: 32px;
    width: root.pill-width;
    Rectangle {
        border-radius: 6px;
        border-width: 1px;
        border-color: root.active ? Theme.primary : (root.has-hover ? Theme.primary : Theme.border);
        background: root.active ? Theme.sidebar-sel-bg : Theme.surface;
        Text {
            text: root.label;
            font-size: 12px;
            font-weight: root.active ? 700 : 500;
            color: root.active ? white : Theme.text-primary;
            horizontal-alignment: center;
            vertical-alignment: center;
            width: parent.width; height: parent.height;
        }
    }
}

// ── Modal: formulário de Cupom (Fase 8) ───────────────────────────
//
// Regras aplicadas (AI_RULES.md §1, §3, §8):
// - Sem lógica de negócio: a UI só lê/escreve propriedades e dispara
//   `add-coupon`/`update-coupon`. Validação real fica no core.
// - Valores numéricos e datas são texto aqui; o Rust converte/valida
//   e devolve mensagens de erro inline.
export component CouponModal inherits Rectangle {
    in-out property <string> editing-id;
    in-out property <string> coupon-title;
    in-out property <string> coupon-code;
    in-out property <string> coupon-type;          // standard|first_purchase|free_shipping
    in-out property <string> coupon-discount-kind; // fixed|percent
    in-out property <string> coupon-discount-value;
    in-out property <string> coupon-min-order;
    in-out property <string> coupon-max-discount;
    in-out property <string> coupon-per-user-limit;
    in-out property <string> coupon-usage-limit;
    in-out property <string> coupon-valid-from;
    in-out property <string> coupon-valid-until;
    in-out property <string> coupon-error-title;
    in-out property <string> coupon-error-code;
    in-out property <string> coupon-error-discount;
    in-out property <string> coupon-error-min;
    in-out property <string> coupon-error-per-user;
    in-out property <string> coupon-error-usage;
    in-out property <string> coupon-error-validity;

    callback close();
    callback add-coupon();
    callback update-coupon();
    /// Aplica a máscara DD/MM/AAAA enquanto o operador digita.
    callback format-date(string) -> string;
    /// Abrir o pop-up do calendário para cada campo de validade.
    /// O Rust posiciona o mês visível e devolve a data via `coupon-cal-pick`.
    callback open-from-cal();
    callback open-until-cal();

    background: #00000060;

    TouchArea {
        clicked => { root.close(); }
    }

    VerticalLayout {
        alignment: center;
        HorizontalLayout {
            alignment: center;
            Card {
                width: 620px;
                TouchArea { }

                VerticalLayout {
                    padding: 24px;
                    spacing: 12px;

                    HorizontalLayout {
                        Text {
                            text: root.editing-id != "" ? "Editar Cupom" : "Novo Cupom";
                            font-size: 18px; font-weight: 700;
                            color: Theme.text-primary;
                            horizontal-stretch: 1; vertical-alignment: center;
                        }
                    }

                    Rectangle { height: 1px; background: Theme.border; }

                    // Tipo de Cupom
                    VerticalLayout {
                        spacing: 4px;
                        Text { text: "Tipo de Cupom"; font-size: 12px; font-weight: 500; color: Theme.text-secondary; }
                        HorizontalLayout {
                            spacing: 10px;
                            TypePill {
                                label: "Padrão"; pill-width: 130px;
                                active: root.coupon-type == "standard";
                                clicked => { root.coupon-type = "standard"; }
                            }
                            TypePill {
                                label: "Primeira Compra"; pill-width: 150px;
                                active: root.coupon-type == "first_purchase";
                                clicked => {
                                    root.coupon-type = "first_purchase";
                                    // Primeira compra ⇒ 1 uso por usuário,
                                    // campo travado.
                                    root.coupon-per-user-limit = "1";
                                    root.coupon-error-per-user = "";
                                }
                            }
                            TypePill {
                                label: "Frete Grátis"; pill-width: 130px;
                                active: root.coupon-type == "free_shipping";
                                clicked => { root.coupon-type = "free_shipping"; }
                            }
                        }
                    }

                    // Linha 1: Título + Código
                    HorizontalLayout {
                        spacing: 14px;
                        VerticalLayout {
                            horizontal-stretch: 1;
                            FormField { label: "Título"; value <=> root.coupon-title; placeholder: "Ex.: Desconto de boas-vindas"; }
                            if root.coupon-error-title != "": Text { text: root.coupon-error-title; font-size: 11px; color: Theme.danger; }
                        }
                        VerticalLayout {
                            width: 200px;
                            FormField { label: "Código do Cupom"; value <=> root.coupon-code; placeholder: "Ex.: BEMVINDO10"; }
                            if root.coupon-error-code != "": Text { text: root.coupon-error-code; font-size: 11px; color: Theme.danger; }
                        }
                    }

                    // Tipo de Desconto + valor (oculto p/ Frete Grátis)
                    if root.coupon-type != "free_shipping": VerticalLayout {
                        spacing: 10px;
                        VerticalLayout {
                            spacing: 4px;
                            Text { text: "Tipo de Desconto"; font-size: 12px; font-weight: 500; color: Theme.text-secondary; }
                            HorizontalLayout {
                                spacing: 10px;
                                TypePill {
                                    label: "Valor (R$)"; pill-width: 130px;
                                    active: root.coupon-discount-kind == "fixed";
                                    clicked => { root.coupon-discount-kind = "fixed"; }
                                }
                                TypePill {
                                    label: "Porcentagem (%)"; pill-width: 150px;
                                    active: root.coupon-discount-kind == "percent";
                                    clicked => { root.coupon-discount-kind = "percent"; }
                                }
                            }
                        }
                        HorizontalLayout {
                            spacing: 14px;
                            VerticalLayout {
                                horizontal-stretch: 1;
                                FormField {
                                    label: root.coupon-discount-kind == "percent" ? "Valor do Desconto (%)" : "Valor do Desconto (R$)";
                                    value <=> root.coupon-discount-value;
                                    placeholder: root.coupon-discount-kind == "percent" ? "Ex.: 15" : "Ex.: 10.00";
                                }
                            }
                            VerticalLayout {
                                horizontal-stretch: 1;
                                FormField { label: "Desconto Máximo (R$)"; value <=> root.coupon-max-discount; placeholder: "0 = sem teto"; }
                            }
                        }
                        if root.coupon-error-discount != "": Text { text: root.coupon-error-discount; font-size: 11px; color: Theme.danger; }
                    }

                    // Linha: mínimo de compra + limites
                    HorizontalLayout {
                        spacing: 14px;
                        VerticalLayout {
                            horizontal-stretch: 1;
                            FormField { label: "Valor Mínimo de Compra (R$)"; value <=> root.coupon-min-order; placeholder: "0 = sem mínimo"; }
                            if root.coupon-error-min != "": Text { text: root.coupon-error-min; font-size: 11px; color: Theme.danger; }
                        }
                        VerticalLayout {
                            horizontal-stretch: 1;
                            // Em "Primeira Compra" o limite é fixo em 1 e
                            // o campo fica travado (não editável).
                            FormField {
                                label: "Limite por Usuário";
                                value <=> root.coupon-per-user-limit;
                                placeholder: "0 = ilimitado";
                                enabled: root.coupon-type != "first_purchase";
                            }
                            if root.coupon-error-per-user != "": Text { text: root.coupon-error-per-user; font-size: 11px; color: Theme.danger; }
                        }
                        VerticalLayout {
                            horizontal-stretch: 1;
                            FormField { label: "Limite Total de Usos"; value <=> root.coupon-usage-limit; placeholder: "0 = ilimitado"; }
                            if root.coupon-error-usage != "": Text { text: root.coupon-error-usage; font-size: 11px; color: Theme.danger; }
                        }
                    }

                    // Validade — clicar abre o CalendarPopup. A data
                    // escolhida volta pelo Rust formatada DD/MM/AAAA.
                    HorizontalLayout {
                        spacing: 14px;
                        VerticalLayout {
                            horizontal-stretch: 1;
                            spacing: 4px;
                            Text {
                                text: "Validade - Início";
                                font-size: 12px; font-weight: 500;
                                color: Theme.text-secondary;
                            }
                            from-ta := TouchArea {
                                height: 32px;
                                clicked => { root.open-from-cal(); }
                                Rectangle {
                                    border-radius: 6px;
                                    border-width: 1px;
                                    border-color: from-ta.has-hover ? Theme.primary : Theme.border;
                                    background: from-ta.has-hover ? Theme.row-hover : Theme.surface;
                                    HorizontalLayout {
                                        padding-left: 10px; padding-right: 10px;
                                        spacing: 8px;
                                        Text {
                                            horizontal-stretch: 1;
                                            text: root.coupon-valid-from != "" ? root.coupon-valid-from : "opcional";
                                            font-size: 13px;
                                            color: root.coupon-valid-from != ""
                                                ? Theme.text-primary
                                                : Theme.text-secondary;
                                            vertical-alignment: center;
                                        }
                                        AssetIcon {
                                            width: 16px; height: 16px; icon-size: 15px;
                                            icon-color: Theme.text-secondary;
                                            source: @image-url("../assets/icons/1.2/calendario.svg");
                                        }
                                    }
                                }
                            }
                        }
                        VerticalLayout {
                            horizontal-stretch: 1;
                            spacing: 4px;
                            Text {
                                text: "Validade - Final";
                                font-size: 12px; font-weight: 500;
                                color: Theme.text-secondary;
                            }
                            until-ta := TouchArea {
                                height: 32px;
                                clicked => { root.open-until-cal(); }
                                Rectangle {
                                    border-radius: 6px;
                                    border-width: 1px;
                                    border-color: until-ta.has-hover ? Theme.primary : Theme.border;
                                    background: until-ta.has-hover ? Theme.row-hover : Theme.surface;
                                    HorizontalLayout {
                                        padding-left: 10px; padding-right: 10px;
                                        spacing: 8px;
                                        Text {
                                            horizontal-stretch: 1;
                                            text: root.coupon-valid-until != "" ? root.coupon-valid-until : "opcional";
                                            font-size: 13px;
                                            color: root.coupon-valid-until != ""
                                                ? Theme.text-primary
                                                : Theme.text-secondary;
                                            vertical-alignment: center;
                                        }
                                        AssetIcon {
                                            width: 16px; height: 16px; icon-size: 15px;
                                            icon-color: Theme.text-secondary;
                                            source: @image-url("../assets/icons/1.2/calendario.svg");
                                        }
                                    }
                                }
                            }
                        }
                    }
                    if root.coupon-error-validity != "": Text { text: root.coupon-error-validity; font-size: 11px; color: Theme.danger; }

                    Rectangle { height: 4px; }

                    HorizontalLayout {
                        alignment: end;
                        spacing: 10px;
                        ActionBtn {
                            label: "Salvar";
                            bg-color: Theme.btn-accent;
                            width: 130px;
                            clicked => {
                                if root.editing-id != "" { root.update-coupon(); } else { root.add-coupon(); }
                            }
                        }
                    }
                }
            }
        }
    }
}
