// Modal "Meu perfil" — o próprio operador vê seus dados e altera as
// credenciais (nome, e-mail e senha). Vale para admin, funcionário e super
// admin. UI sem lógica (§1/§3): dados vêm do Rust (GET /auth/me) e o salvar
// delega ao Rust (PUT /auth/profile). A autoridade é o backend (§11).
//
// Padrão do sistema (§3/§8): moldura via `ModalShell` (ícone do sistema, título,
// mensagem, divisor) + ações em `OutlineBtn` — igual ao modal de caixa fechado.
// Antes tinha header próprio (quadrado laranja com ícone) e "Salvar" preenchido.
import { Theme } from "../theme.slint";
import { FormField, PasswordField } from "../components/form_fields.slint";
import { OutlineBtn } from "../components/buttons.slint";
import { ModalShell } from "../components/modal_shell.slint";

export component ProfileModal inherits Rectangle {
    in property <string> role-label;
    in-out property <string> name;
    in-out property <string> email;
    in-out property <string> new-password;
    in property <string> status;
    in property <bool> busy;
    callback save();
    callback close();

    width: 100%;
    height: 100%;

    ModalShell {
        width: 100%;
        height: 100%;
        icon: @image-url("../assets/icons/1.2/user.svg");
        title: "Meu perfil";
        message: root.role-label;
        card-width: 420px;
        close => { root.close(); }

        VerticalLayout {
            spacing: 12px;

            FormField {
                label: "Nome";
                value <=> root.name;
                placeholder: "Seu nome";
            }
            FormField {
                label: "E-mail";
                value <=> root.email;
                placeholder: "email@dominio.com";
            }
            PasswordField {
                label: "Nova senha";
                value <=> root.new-password;
                placeholder: "Deixe em branco para manter";
            }

            if root.status != "": Text {
                text: root.status;
                font-size: 12px; color: Theme.primary;
                wrap: word-wrap;
                horizontal-alignment: center;
            }

            // Ações juntas (Cancelar colado no Salvar), no padrão do sistema.
            HorizontalLayout {
                alignment: center;
                spacing: 10px;

                OutlineBtn {
                    label: root.busy ? "Salvando…" : "Salvar";
                    accent: true;
                    btn-color: Theme.btn-accent;
                    width: 120px; height: 40px;
                    clicked => { root.save(); }
                }
            }
        }
    }
}
