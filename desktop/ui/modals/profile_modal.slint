// Modal "Meu perfil" — o próprio operador vê seus dados e altera as
// credenciais (nome, e-mail e senha). Vale para admin, funcionário e super
// admin. UI sem lógica (§1/§3): dados vêm do Rust (GET /auth/me) e o salvar
// delega ao Rust (PUT /auth/profile). A autoridade é o backend (§11).
import { Theme } from "../theme.slint";
import { FormField, PasswordField } from "../components/form_fields.slint";
import { ActionBtn, OutlineBtn } from "../components/buttons.slint";
import { PersonIcon } from "../components/icons.slint";

export component ProfileModal inherits Rectangle {
    in property <string> role-label;
    in-out property <string> name;
    in-out property <string> email;
    in-out property <string> new-password;
    in property <string> status;
    in property <bool> busy;
    callback save();
    callback close();

    width: 100%;
    height: 100%;
    background: #00000088;
    // Clique fora fecha.
    TouchArea { clicked => { root.close(); } }

    Rectangle {
        width: 420px;
        height: 452px;
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        border-radius: 16px;
        border-width: 1px;
        border-color: Theme.card-border;
        drop-shadow-blur: 12px;
        drop-shadow-offset-y: 0px;
        drop-shadow-color: Theme.card-shadow;
        background: Theme.surface;
        // Absorve cliques dentro do card (não fecha).
        TouchArea {}

        VerticalLayout {
            padding: 26px;
            spacing: 12px;
            alignment: start;

            HorizontalLayout {
                spacing: 12px;
                Rectangle {
                    width: 52px; height: 52px; border-radius: 14px;
                    background: Theme.sidebar-sel-bg;
                    PersonIcon {
                        icon-size: 26px; icon-color: white;
                        x: (parent.width - self.width) / 2;
                        y: (parent.height - self.height) / 2;
                    }
                }
                VerticalLayout {
                    alignment: center;
                    spacing: 2px;
                    Text { text: "Meu perfil"; font-size: 18px; font-weight: 800; color: Theme.text-primary; }
                    Text { text: root.role-label; font-size: 12px; color: Theme.text-secondary; }
                }
            }

            Rectangle { height: 1px; background: Theme.border; }

            FormField {
                label: "Nome";
                value <=> root.name;
                placeholder: "Seu nome";
            }
            FormField {
                label: "E-mail";
                value <=> root.email;
                placeholder: "email@dominio.com";
            }
            PasswordField {
                label: "Nova senha";
                value <=> root.new-password;
                placeholder: "Deixe em branco para manter";
            }

            if root.status != "": Text {
                text: root.status;
                font-size: 12px; color: Theme.primary;
                wrap: word-wrap;
            }

            Rectangle { vertical-stretch: 1; }

            HorizontalLayout {
                spacing: 10px;
                OutlineBtn {
                    label: "Cancelar";
                    clicked => { root.close(); }
                }
                Rectangle { horizontal-stretch: 1; }
                ActionBtn {
                    label: root.busy ? "Salvando..." : "Salvar";
                    bg-color: Theme.sidebar-sel-bg;
                    clicked => { root.save(); }
                }
            }
        }
    }
}
