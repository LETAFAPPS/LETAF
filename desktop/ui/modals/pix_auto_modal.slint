import { Theme } from "../theme.slint";
import { AssetIcon } from "../components/icons.slint";
import { Card } from "../components/cards.slint";
import { FormField } from "../components/form_fields.slint";
import { ActionBtn, OutlineBtn } from "../components/buttons.slint";

// ── Modal: ativar Pix Automático ─────────────────────────────────
//
// Regras aplicadas (AI_RULES.md §1, §3, §11):
// - Coleta nome + CPF do titular (exigidos pelo mandato BACEN) e
//   dispara `submit`. A máscara de CPF vem de callback no Rust.
// - Após gerar a recorrência, a UI mostra o QR de autorização no
//   modal de cobrança PIX (reaproveitado).

export component PixAutoModal inherits Rectangle {
    in-out property <string> name;
    in-out property <string> cpf;
    in-out property <string> error;
    in property <bool> loading: false;

    callback fmt-cpf-cnpj(string) -> string;
    callback close();
    callback submit();

    background: #00000060;

    TouchArea {
        clicked => { root.close(); }
    }

    VerticalLayout {
        alignment: center;
        HorizontalLayout {
            alignment: center;
            Card {
                width: 480px;
                TouchArea { }
                VerticalLayout {
                    padding: 24px;
                    spacing: 12px;

                    HorizontalLayout {
                        Text {
                            horizontal-stretch: 1;
                            text: "Ativar PIX Automático";
                            font-size: 18px; font-weight: 700;
                            color: Theme.text-primary;
                            vertical-alignment: center;
                        }
                    }

                    Rectangle { height: 1px; background: Theme.border; }

                    Text {
                        text: "Débito automático recorrente. Você autoriza uma única vez no app do seu banco — depois as cobranças são debitadas sozinhas a cada ciclo.";
                        font-size: 11px;
                        color: Theme.text-secondary;
                        wrap: word-wrap;
                    }

                    FormField {
                        label: "Nome do titular da conta";
                        value <=> root.name;
                        placeholder: "Como no banco";
                    }
                    FormField {
                        label: "CPF/CNPJ";
                        value <=> root.cpf;
                        placeholder: "000.000.000-00";
                        force-end-cursor: true;
                        edited(t) => { root.cpf = root.fmt-cpf-cnpj(t); }
                    }

                    if root.error != "": Text {
                        text: root.error;
                        font-size: 11px;
                        color: #E53935;
                        wrap: word-wrap;
                    }

                    Rectangle { height: 4px; }

                    HorizontalLayout {
                        spacing: 10px;
                        Rectangle { horizontal-stretch: 1; background: transparent; }
                        ActionBtn {
                            label: root.loading ? "Gerando…" : "Gerar QR de autorização";
                            bg-color: Theme.btn-accent;
                            width: 210px;
                            clicked => {
                                if !root.loading {
                                    root.submit();
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}
