import { Theme } from "../theme.slint";
import { AssetIcon } from "../components/icons.slint";
import { Card } from "../components/cards.slint";
import { ActionBtn, OutlineBtn } from "../components/buttons.slint";

// ── Modal: abrir caixa ────────────────────────────────────────────
//
// Pede o troco inicial em dinheiro pra começar a sessão. Operador
// vem fixo da sessão atual; troco aceita digitação livre + 5 atalhos
// (50, 100, 150, 200, 300). UI só dispara `confirm`; o Rust valida.

export component CashOpenModal inherits Rectangle {
    in property <string> operator-label;
    in property <string> suggested-display;
    in-out property <string> amount-input;
    in-out property <string> notes-input;

    callback close();
    callback confirm();

    background: #00000080;
    TouchArea { clicked => { root.close(); } }

    VerticalLayout {
        alignment: center;
        HorizontalLayout {
            alignment: center;
            Card {
                width: 460px;
                TouchArea { }

                VerticalLayout {
                    padding: 0px;
                    spacing: 0px;

                    // Header
                    Rectangle {
                        background: Theme.surface;
                        VerticalLayout {
                            padding-left: 22px; padding-right: 22px;
                            padding-top: 18px; padding-bottom: 14px;
                            spacing: 2px;
                            HorizontalLayout {
                                VerticalLayout {
                                    horizontal-stretch: 1; spacing: 2px;
                                    Text {
                                        text: "Abrir Caixa";
                                        font-size: 16px; font-weight: 700;
                                        color: Theme.text-primary;
                                    }
                                    Text {
                                        text: "Informe o troco inicial em dinheiro para começar a operação";
                                        font-size: 11px; color: Theme.text-secondary;
                                        wrap: word-wrap;
                                    }
                                }
                                close-ta := TouchArea {
                                    width: 28px; height: 28px;
                                    clicked => { root.close(); }
                                    Rectangle {
                                        border-radius: 4px;
                                        background: close-ta.has-hover ? Theme.row-hover : transparent;
                                        AssetIcon { width: parent.width; height: parent.height; icon-size: 14px; icon-color: Theme.text-secondary; source: @image-url("../assets/icons/1.2/fechar.svg"); }
                                    }
                                }
                            }
                        }
                    }

                    // Corpo
                    Rectangle {
                        background: Theme.bg;
                        VerticalLayout {
                            padding: 18px;
                            spacing: 14px;

                            // Operador (somente leitura)
                            VerticalLayout {
                                spacing: 6px;
                                Text { text: "Operador"; font-size: 10px; font-weight: 700; color: Theme.text-secondary; letter-spacing: 1px; }
                                Rectangle {
                                    height: 36px;
                                    border-radius: 6px;
                                    border-width: 1px;
                                    border-color: Theme.card-border;
                                    drop-shadow-blur: 12px;
                                    drop-shadow-offset-y: 0px;
                                    drop-shadow-color: Theme.card-shadow;
                                    background: Theme.surface;
                                    Text {
                                        x: 12px; y: 0;
                                        width: parent.width - 24px; height: parent.height;
                                        text: root.operator-label;
                                        font-size: 13px; color: Theme.text-primary;
                                        vertical-alignment: center;
                                    }
                                }
                            }

                            // Troco inicial
                            VerticalLayout {
                                spacing: 6px;
                                Text { text: "Troco inicial"; font-size: 10px; font-weight: 700; color: Theme.text-secondary; letter-spacing: 1px; }
                                Rectangle {
                                    height: 40px;
                                    border-radius: 6px;
                                    border-width: 1px;
                                    border-color: amount-input.has-focus ? Theme.primary : Theme.border;
                                    background: Theme.surface;
                                    HorizontalLayout {
                                        padding-left: 12px; padding-right: 12px;
                                        Text {
                                            text: "R$";
                                            font-size: 13px; font-weight: 600;
                                            color: Theme.text-secondary;
                                            vertical-alignment: center;
                                        }
                                        Rectangle {
                                            horizontal-stretch: 1;
                                            amount-input := TextInput {
                                                x: 10px; y: 0;
                                                width: parent.width - 20px; height: parent.height;
                                                text <=> root.amount-input;
                                                font-size: 14px; font-weight: 600;
                                                color: Theme.text-primary;
                                                vertical-alignment: center;
                                                single-line: true;
                                                input-type: decimal;
                                            }
                                            if root.amount-input == "": Text {
                                                x: 10px; y: 0;
                                                width: parent.width - 20px; height: parent.height;
                                                text: "0,00"; font-size: 14px; color: #BDBDBD;
                                                vertical-alignment: center;
                                            }
                                        }
                                    }
                                    init-timer := Timer {
                                        interval: 80ms; running: true;
                                        triggered => { amount-input.focus(); self.running = false; }
                                    }
                                }
                                // Atalhos
                                HorizontalLayout {
                                    spacing: 6px;
                                    for opt[oi] in [50, 100, 150, 200, 300]: chip-ta := TouchArea {
                                        horizontal-stretch: 1; height: 32px;
                                        clicked => { root.amount-input = opt; }
                                        Rectangle {
                                            border-radius: 6px;
                                            border-width: 1px;
                                            border-color: chip-ta.has-hover ? Theme.primary : Theme.border;
                                            background: chip-ta.has-hover ? Theme.row-hover : Theme.surface;
                                            Text {
                                                width: parent.width; height: parent.height;
                                                text: "R$ " + opt;
                                                font-size: 12px; font-weight: 600;
                                                color: Theme.text-primary;
                                                horizontal-alignment: center; vertical-alignment: center;
                                            }
                                        }
                                    }
                                }
                                // (Removido: texto "Sugestão baseada na média das últimas 5 sessões")
                            }

                            // Observação (opcional)
                            VerticalLayout {
                                spacing: 6px;
                                Text { text: "Observação"; font-size: 10px; font-weight: 700; color: Theme.text-secondary; letter-spacing: 1px; }
                                Rectangle {
                                    height: 36px;
                                    border-radius: 6px;
                                    border-width: 1px;
                                    border-color: notes-input.has-focus ? Theme.primary : Theme.border;
                                    background: Theme.surface;
                                    notes-input := TextInput {
                                        x: 10px; y: 0;
                                        width: parent.width - 20px; height: parent.height;
                                        text <=> root.notes-input;
                                        font-size: 12px; color: Theme.text-primary;
                                        vertical-alignment: center;
                                        single-line: true;
                                    }
                                    if root.notes-input == "": Text {
                                        x: 10px; y: 0;
                                        width: parent.width - 20px; height: parent.height;
                                        text: "Ex: cofre revisado · alimentei troco extra";
                                        font-size: 12px; color: #BDBDBD;
                                        vertical-alignment: center;
                                    }
                                }
                            }

                            // Botões
                            HorizontalLayout {
                                spacing: 10px;
                                alignment: end;
                                OutlineBtn {
                                    label: "Cancelar";
                                    min-width: 110px; height: 40px;
                                    clicked => { root.close(); }
                                }
                                ActionBtn {
                                    label: "Abrir Caixa";
                                    bg-color: Theme.sidebar-sel-bg;
                                    min-width: 140px; height: 40px;
                                    clicked => { root.confirm(); }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}
