import { Theme } from "../theme.slint";
import { AssetIcon } from "../components/icons.slint";
import { Card } from "../components/cards.slint";
import { ActionBtn, OutlineBtn } from "../components/buttons.slint";
import { FormField } from "../components/form_fields.slint";

// ── Modal: abrir caixa ────────────────────────────────────────────
//
// Pede o troco inicial em dinheiro pra começar a sessão. Operador vem fixo da
// sessão atual; troco aceita digitação livre + 5 atalhos (50, 100, 150, 200,
// 300). UI só dispara `confirm`; o Rust valida.
//
// Segue o PADRÃO de modal de formulário do sistema (ver category_modal):
// superfície ÚNICA (Card branco), padding 24px, header + divisor, e o
// `FormField` compartilhado nos campos simples. Sem "corpo bege" separado.

export component CashOpenModal inherits Rectangle {
    in property <string> operator-label;
    in property <string> suggested-display;
    in-out property <string> amount-input;
    in-out property <string> notes-input;

    callback close();
    callback confirm();

    background: #00000060;
    TouchArea { clicked => { root.close(); } }

    VerticalLayout {
        alignment: center;
        HorizontalLayout {
            alignment: center;
            Card {
                width: 460px;
                // Absorve cliques dentro do card (não fecha o modal).
                TouchArea { }

                VerticalLayout {
                    padding: 24px;
                    spacing: 14px;

                    // ── Header ──
                    HorizontalLayout {
                        VerticalLayout {
                            horizontal-stretch: 1;
                            spacing: 2px;
                            Text {
                                text: "Abrir Caixa";
                                font-size: 18px; font-weight: 700;
                                color: Theme.text-primary;
                            }
                            Text {
                                text: "Informe o troco inicial em dinheiro para começar a operação";
                                font-size: 12px; color: Theme.text-secondary;
                                wrap: word-wrap;
                            }
                        }
                    }

                    Rectangle { height: 1px; background: Theme.border; }

                    // ── Operador (somente leitura) ──
                    VerticalLayout {
                        spacing: 4px;
                        Text { text: "Operador"; font-size: 12px; font-weight: 500; color: Theme.text-secondary; }
                        Rectangle {
                            height: 32px;
                            border-radius: 6px;
                            border-width: 1px;
                            border-color: Theme.border;
                            background: Theme.row-hover;
                            opacity: 0.6;
                            Text {
                                x: 8px; y: 0;
                                width: parent.width - 16px; height: parent.height;
                                text: root.operator-label;
                                font-size: 13px; color: Theme.text-primary;
                                vertical-alignment: center;
                            }
                        }
                    }

                    // ── Troco inicial ──
                    VerticalLayout {
                        spacing: 4px;
                        Text { text: "Troco inicial"; font-size: 12px; font-weight: 500; color: Theme.text-secondary; }
                        Rectangle {
                            height: 40px;
                            border-radius: 6px;
                            border-width: 1px;
                            border-color: amount-input.has-focus ? Theme.primary : Theme.border;
                            background: Theme.surface;
                            HorizontalLayout {
                                padding-left: 10px; padding-right: 10px;
                                Text {
                                    text: "R$";
                                    font-size: 13px; font-weight: 600;
                                    color: Theme.text-secondary;
                                    vertical-alignment: center;
                                }
                                Rectangle {
                                    horizontal-stretch: 1;
                                    amount-input := TextInput {
                                        x: 8px; y: 0;
                                        width: parent.width - 16px; height: parent.height;
                                        text <=> root.amount-input;
                                        font-size: 14px; font-weight: 600;
                                        color: Theme.text-primary;
                                        vertical-alignment: center;
                                        single-line: true;
                                        input-type: decimal;
                                    }
                                    if root.amount-input == "": Text {
                                        x: 8px; y: 0;
                                        width: parent.width - 16px; height: parent.height;
                                        text: "0,00"; font-size: 14px; color: #BDBDBD;
                                        vertical-alignment: center;
                                    }
                                }
                            }
                            init-timer := Timer {
                                interval: 80ms; running: true;
                                triggered => { amount-input.focus(); self.running = false; }
                            }
                        }
                        // Atalhos de valor
                        HorizontalLayout {
                            spacing: 6px;
                            for opt[oi] in [50, 100, 150, 200, 300]: chip-ta := TouchArea {
                                horizontal-stretch: 1; height: 32px;
                                clicked => { root.amount-input = opt; }
                                Rectangle {
                                    border-radius: 6px;
                                    border-width: 1px;
                                    border-color: chip-ta.has-hover ? Theme.primary : Theme.border;
                                    background: chip-ta.has-hover ? Theme.row-hover : Theme.surface;
                                    Text {
                                        width: parent.width; height: parent.height;
                                        text: "R$ " + opt;
                                        font-size: 12px; font-weight: 600;
                                        color: Theme.text-primary;
                                        horizontal-alignment: center; vertical-alignment: center;
                                    }
                                }
                            }
                        }
                    }

                    // ── Observação (opcional) ──
                    FormField {
                        label: "Observação";
                        value <=> root.notes-input;
                        placeholder: "Ex: cofre revisado · alimentei troco extra";
                    }

                    // ── Ações ──
                    HorizontalLayout {
                        spacing: 10px;
                        alignment: end;
                        ActionBtn {
                            label: "Abrir Caixa";
                            bg-color: Theme.btn-accent;
                            min-width: 140px; height: 40px;
                            clicked => { root.confirm(); }
                        }
                    }
                }
            }
        }
    }
}
