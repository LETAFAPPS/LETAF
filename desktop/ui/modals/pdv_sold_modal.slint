import { Theme } from "../theme.slint";
import { Card } from "../components/cards.slint";
import { ActionBtn, OutlineBtn } from "../components/buttons.slint";

// ── Modal: pedido criado no PDV (pós-venda) ───────────────────────
//
// Aparece após `order_service::create_pdv` retornar com sucesso.
// Mostra o número do pedido e oferece atalhos para imprimir
// comanda do cliente e comanda da cozinha (reutilizando o fluxo
// existente `print_receipt_now`). Fechar sem clicar volta o PDV
// pronto para a próxima venda.

export component PdvSoldModal inherits Rectangle {
    in property <string> order-number;
    in property <string> total-display;

    callback close();
    callback print-receipt();
    callback print-kitchen();

    background: #00000080;
    TouchArea { clicked => { root.close(); } }

    // Enter (ou Esc) fecha o modal. O FocusScope recebe o foco ao abrir
    // (Timer) pra capturar as teclas mesmo sem clicar.
    fs := FocusScope {
        key-pressed(e) => {
            if (e.text == Key.Return) { root.close(); accept }
            else if (e.text == Key.Escape) { root.close(); accept }
            else { reject }
        }
    }
    Timer {
        interval: 1ms; running: true;
        triggered => { fs.focus(); self.running = false; }
    }

    VerticalLayout {
        alignment: center;
        HorizontalLayout {
            alignment: center;
            Card {
                width: 400px;
                TouchArea { }

                VerticalLayout {
                    padding: 0px;
                    spacing: 0px;

                    // Header verde (sucesso)
                    Rectangle {
                        background: #2E7D32;
                        height: 70px;
                        VerticalLayout {
                            alignment: center;
                            Text {
                                text: "✓ Venda Finalizada";
                                font-size: 18px; font-weight: 800;
                                color: white;
                                horizontal-alignment: center;
                            }
                            Text {
                                text: "Pedido #" + root.order-number;
                                font-size: 12px; font-weight: 600;
                                color: white;
                                horizontal-alignment: center;
                            }
                        }
                    }

                    // Body
                    Rectangle {
                        background: Theme.surface;
                        VerticalLayout {
                            padding: 22px;
                            spacing: 14px;
                            Text {
                                text: "Total: " + root.total-display;
                                font-size: 16px; font-weight: 700;
                                color: Theme.text-primary;
                                horizontal-alignment: center;
                            }
                            Text {
                                text: "O pedido já está em PREPARANDO no Kanban. Imprimir comandas?";
                                font-size: 12px;
                                color: Theme.text-secondary;
                                horizontal-alignment: center;
                                wrap: word-wrap;
                            }
                            HorizontalLayout {
                                spacing: 8px;
                                OutlineBtn {
                                    label: "Comanda Cliente";
                                    horizontal-stretch: 1; height: 40px;
                                    clicked => { root.print-receipt(); }
                                }
                                OutlineBtn {
                                    label: "Cozinha";
                                    horizontal-stretch: 1; height: 40px;
                                    clicked => { root.print-kitchen(); }
                                }
                            }
                            ActionBtn {
                                label: "Fechar";
                                bg-color: Theme.sidebar-sel-bg;
                                horizontal-stretch: 1; height: 40px;
                                clicked => { root.close(); }
                            }
                        }
                    }
                }
            }
        }
    }
}
