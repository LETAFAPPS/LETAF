import { Theme } from "../theme.slint";
import { OutlineBtn } from "../components/buttons.slint";
import { ModalShell } from "../components/modal_shell.slint";

// ── Modal: confirmar troca de plano com recorrência ativa ────────
//
// Regras aplicadas (AI_RULES.md §1, §3, §8, §11):
// - UI só exibe a mensagem (montada no Rust) e dispara confirm/close.
// - "Cancelar e trocar" faz, em um passo: cancela a recorrência no
//   gateway + troca o plano (o Rust orquestra).
// - Padrão do sistema: moldura via `ModalShell` + ações em `OutlineBtn`.

export component PlanChangeConfirmModal inherits Rectangle {
    in property <string> message;
    in property <bool> loading: false;

    callback close();
    callback confirm();

    ModalShell {
        width: 100%;
        height: 100%;
        icon: @image-url("../assets/icons/1.2/subscription.svg");
        title: "Trocar de plano";
        message: root.message;
        card-width: 460px;
        close => { root.close(); }

        HorizontalLayout {
            alignment: center;
            spacing: 10px;

            OutlineBtn {
                label: "Voltar";
                width: 120px; height: 40px;
                clicked => { root.close(); }
            }
            OutlineBtn {
                label: root.loading ? "Processando…" : "Cancelar e trocar";
                accent: true;
                btn-color: Theme.sidebar-sel-bg;
                width: 190px; height: 40px;
                clicked => {
                    if !root.loading {
                        root.confirm();
                    }
                }
            }
        }
    }
}
