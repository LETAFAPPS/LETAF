// Modal do carrinho (PDV) — lista de itens com editar (qtd) e excluir.
// Aberto ao clicar no pill "N itens · R$" ao lado da busca.
// Regras (AI_RULES.md §3): UI só renderiza + dispara callbacks; toda a
// lógica de carrinho vive no Rust (pdv::*).
import { ScrollView } from "std-widgets.slint";
import { Theme } from "../theme.slint";
import { PdvCartRow } from "../types.slint";
import { AssetIcon } from "../components/icons.slint";
import { EmptyState } from "../components/empty_state.slint";

export component PdvCartModal inherits Rectangle {
    in property <[PdvCartRow]> cart;
    in property <string> total-display;
    callback inc(string);
    callback dec(string);
    callback remove(string);
    callback close();

    width: 100%;
    height: 100%;
    background: #0000009e;
    // Clique fora fecha.
    TouchArea { clicked => { root.close(); } }

    Rectangle {
        width: 480px;
        height: min(640px, parent.height - 80px);
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        border-radius: 16px;
        border-width: 1px;
        border-color: Theme.card-border;
        drop-shadow-blur: 24px;
        drop-shadow-color: #00000040;
        background: Theme.surface;
        // Absorve cliques dentro do card (não fecha).
        TouchArea {}

        VerticalLayout {
            padding: 20px;
            spacing: 12px;

            HorizontalLayout {
                Text {
                    text: "Itens do Carrinho";
                    font-size: 16px; font-weight: 800;
                    color: Theme.text-primary;
                    horizontal-stretch: 1;
                    vertical-alignment: center;
                }
            }

            if root.cart.length == 0: Rectangle {
                vertical-stretch: 1;
                EmptyState {
                    source: @image-url("../assets/empty/empty-cart.svg");
                    title: "Carrinho vazio";
                    subtitle: "Adicione itens para começar";
                }
            }

            if root.cart.length > 0: ScrollView { vertical-scrollbar-policy: ScrollBarPolicy.always-off; horizontal-scrollbar-policy: ScrollBarPolicy.always-off;
                vertical-stretch: 1;
                VerticalLayout {
                    alignment: start;
                    padding: 4px;
                    spacing: 8px;
                    for it in root.cart: Rectangle {
                        border-radius: 10px;
                        border-width: 1px;
                        border-color: Theme.card-border;
                        drop-shadow-blur: 6px;
                        drop-shadow-offset-y: 0px;
                        drop-shadow-color: Theme.card-shadow;
                        background: Theme.surface;
                        VerticalLayout {
                            padding: 10px;
                            spacing: 6px;
                            HorizontalLayout {
                                spacing: 8px;
                                VerticalLayout {
                                    horizontal-stretch: 1;
                                    spacing: 1px;
                                    Text { text: it.name; font-size: 13px; font-weight: 600; color: Theme.text-primary; overflow: elide; }
                                    if it.addons-summary != "": Text { text: it.addons-summary; font-size: 11px; color: Theme.text-secondary; wrap: word-wrap; }
                                }
                                Text { text: it.line-total-display; font-size: 13px; font-weight: 700; color: Theme.primary; vertical-alignment: center; }
                            }
                            HorizontalLayout {
                                spacing: 6px;
                                dec-ta := TouchArea {
                                    width: 32px; height: 28px;
                                    clicked => { root.dec(it.line-id); }
                                    Rectangle {
                                        border-radius: 6px; border-width: 1px;
                                        border-color: dec-ta.has-hover ? Theme.primary : Theme.border;
                                        background: dec-ta.has-hover ? Theme.row-hover : Theme.surface;
                                        Text { text: "−"; font-size: 15px; font-weight: 700; color: Theme.text-primary; width: parent.width; height: parent.height; horizontal-alignment: center; vertical-alignment: center; }
                                    }
                                }
                                Rectangle {
                                    width: 42px; height: 28px; border-radius: 6px; border-width: 1px;
                                    border-color: Theme.card-border; background: Theme.surface;
                                    Text { text: it.qty; font-size: 13px; font-weight: 600; color: Theme.text-primary; width: parent.width; height: parent.height; horizontal-alignment: center; vertical-alignment: center; }
                                }
                                inc-ta := TouchArea {
                                    width: 32px; height: 28px;
                                    clicked => { root.inc(it.line-id); }
                                    Rectangle {
                                        border-radius: 6px; border-width: 1px;
                                        border-color: inc-ta.has-hover ? Theme.primary : Theme.border;
                                        background: inc-ta.has-hover ? Theme.row-hover : Theme.surface;
                                        Text { text: "+"; font-size: 15px; font-weight: 700; color: Theme.text-primary; width: parent.width; height: parent.height; horizontal-alignment: center; vertical-alignment: center; }
                                    }
                                }
                                Rectangle { horizontal-stretch: 1; }
                            }
                        }
                    }
                }
            }

            Rectangle { height: 1px; background: Theme.border; }
            HorizontalLayout {
                Text { text: "Total"; font-size: 14px; font-weight: 700; color: Theme.text-primary; horizontal-stretch: 1; vertical-alignment: center; }
                Text { text: root.total-display; font-size: 16px; font-weight: 800; color: #2E7D32; vertical-alignment: center; }
            }
        }
    }
}
