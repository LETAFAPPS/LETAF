# ── Servidor ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://user:password@localhost:5432/letaf
SERVER_PORT=3000
JWT_SECRET=your-secret-key-here
CORS_ORIGINS=http://localhost:8080,http://demo.localhost:8080

# Super admin de plataforma (painel /admin). A senha inicial NUNCA é
# hardcoded: no primeiro boot, se ainda não existir nenhum super admin, o
# servidor cria um usando PLATFORM_ADMIN_PASSWORD. Sem essa variável o super
# admin NÃO é criado (fail-closed) e o painel fica inacessível até defini-la.
# PLATFORM_ADMIN_EMAIL é opcional (default admin@letaf.app). Troque a senha
# após o primeiro login.
PLATFORM_ADMIN_EMAIL=admin@letaf.app
PLATFORM_ADMIN_PASSWORD=

# ── Desktop (runtime) ─────────────────────────────────────────────────────────
# URL do servidor para sincronização e autenticação do desktop.
LETAF_SERVER_URL=http://localhost:3000

# ── Web frontend (build time) ─────────────────────────────────────────────────
# Porta do servidor usada pelo frontend web para montar a URL base da API.
# Definir como variável de ambiente antes de `dx build` ou `trunk build`.
# Exemplo: LETAF_SERVER_PORT=3000 dx build --release
LETAF_SERVER_PORT=3000

# ── Efi Bank (PIX) ────────────────────────────────────────────────────────────
# EFI_ENV: "homologacao" (sandbox) ou "producao".
# EFI_P12_PATH: caminho para o certificado .p12 fornecido pela Efi.
# EFI_P12_PASSWORD: senha do .p12 (vazio se sem senha).
# EFI_PIX_KEY: chave PIX da empresa (CNPJ, e-mail, telefone ou aleatória).
EFI_ENV=homologacao
EFI_CLIENT_ID=
EFI_CLIENT_SECRET=
EFI_P12_PATH=
EFI_P12_PASSWORD=
EFI_PIX_KEY=
# EFI_PIX_WEBHOOK_HMAC: segredo p/ autenticar o webhook PIX. Configure o
# MESMO valor no painel da Efi (HMAC do webhook) — ela anexa `?hmac=` à
# URL. Quando definido, o servidor REJEITA webhooks sem o hmac correto
# (protege contra confirmação de pagamento forjada). Recomendado em prod.
EFI_PIX_WEBHOOK_HMAC=

# APP_UPDATES_DIR: diretório onde ficam o `manifest.json` (metadados da
# última versão do desktop) e os binários servidos por `/app/download/*`.
# Default `updates`. Publicar uma nova versão = editar o manifest + soltar
# o binário aqui (sem recompilar o servidor). Ver DEPLOY.md.
APP_UPDATES_DIR=updates

# ── Efi Bank (Cartão recorrente — API Cobranças) ──────────────────────────────
# API distinta do PIX: base própria, OAuth em /v1/authorize, SEM .p12.
# Reutiliza EFI_ENV. Se a mesma aplicação Efi tiver escopo de Cobranças,
# pode deixar EFI_COBRANCAS_CLIENT_* vazios (cai para EFI_CLIENT_*).
# As credenciais da API Cobranças são as MESMAS do PIX (a aplicação Efi
# tem os dois escopos) — pode deixar EFI_COBRANCAS_CLIENT_* vazios.
# EFI_PAYEE_CODE: "Identificador de Conta" da Efi (OBRIGATÓRIO p/ cartão —
#   tokenização). Pegue no painel da Efi. Sem ele, /subscription/card* → 503.
# EFI_NOTIFICATION_URL: OPCIONAL. URL PÚBLICA deste servidor + /webhooks/efi
#   (em dev use um túnel, ex.: https://<sub>.ngrok.io/webhooks/efi).
#   Sem ela o cartão funciona; só o webhook de cobrança recorrente fica inativo.
EFI_COBRANCAS_CLIENT_ID=
EFI_COBRANCAS_CLIENT_SECRET=
EFI_PAYEE_CODE=
EFI_NOTIFICATION_URL=
